<Window x:Class="K2.Core.ButtonActionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:K2.Core"
        Title="{loc:Get dlg_title}"
        Height="520" Width="580"
        MinHeight="420" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Style="{DynamicResource K2WindowStyle}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LblHeader" Grid.Row="0"
                   Text="{loc:Get dlg_button_label}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Text="{loc:Get dlg_action_type}" Margin="0,0,0,4"/>
        <ComboBox  Grid.Row="2" x:Name="CbType"
                   SelectionChanged="CbType_SelectionChanged">
            <ComboBoxItem Content="{loc:Get act_none}"                  Tag="none"/>
            <ComboBoxItem Content="{loc:Get act_url}"              Tag="url"/>
            <ComboBoxItem Content="{loc:Get act_exec}"   Tag="exec"/>
            <ComboBoxItem Content="{loc:Get act_folder}"           Tag="folder"/>
            <ComboBoxItem Content="{loc:Get act_browser}"          Tag="browser"/>
            <ComboBoxItem Content="{loc:Get act_profile}"        Tag="profile"/>
            <ComboBoxItem Content="{loc:Get act_oscmd}"        Tag="oscmd"/>
            <ComboBoxItem Content="{loc:Get act_media}"             Tag="media"/>
            <ComboBoxItem Content="{loc:Get act_mouse}"          Tag="mouse"/>
            <ComboBoxItem Content="{loc:Get act_keys}"   Tag="keys"/>
            <ComboBoxItem Content="{loc:Get act_command}"         Tag="command"/>
            <ComboBoxItem Content="{loc:Get act_text}"            Tag="text"/>
            <ComboBoxItem Content="{loc:Get act_pyscript}"         Tag="pyscript"/>
        </ComboBox>

        <!-- Content area: standard panel OR Python Script panel -->
        <Grid Grid.Row="3" Margin="0,12,0,0">

            <!-- Standard panel (all types except pyscript) -->
            <Grid x:Name="StandardPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="LblPayload" Grid.Row="0" Text="{loc:Get dlg_value}" Margin="0,0,0,4"/>
                <TextBox   x:Name="TxtPayload" Grid.Row="1"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           VerticalScrollBarVisibility="Auto"
                           FontFamily="Consolas"
                           MinHeight="60"/>
            </Grid>

            <!-- Open program / file panel -->
            <Grid x:Name="ExecPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{loc:Get exec_path_label}" Margin="0,0,0,4"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" Margin="0,0,8,0"
                            VerticalAlignment="Center" Background="#22222A" CornerRadius="4">
                        <Image x:Name="ImgExecIcon" Width="24" Height="24" Stretch="Uniform"/>
                    </Border>
                    <TextBox x:Name="TxtExecPath" Grid.Column="1"
                             VerticalContentAlignment="Center"
                             FontFamily="Consolas"
                             TextChanged="TxtExecPath_TextChanged"/>
                    <Button  x:Name="BtnExecBrowse" Grid.Column="2"
                             Content="{loc:Get browse}" Padding="10,2" Margin="6,0,0,0"
                             Click="BtnExecBrowse_Click"/>
                </Grid>

                <TextBlock Grid.Row="2" Text="{loc:Get recent_paths}" Margin="0,0,0,4" Foreground="#9A9AA2"/>
                <ListBox x:Name="LstExecRecent" Grid.Row="3"
                         SelectionChanged="LstExecRecent_SelectionChanged"/>
            </Grid>

            <!-- Open folder panel -->
            <Grid x:Name="FolderPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{loc:Get folder_path_label}" Margin="0,0,0,4"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtFolderPath" Grid.Column="0"
                             VerticalContentAlignment="Center"
                             FontFamily="Consolas"/>
                    <Button  x:Name="BtnFolderBrowse" Grid.Column="1"
                             Content="{loc:Get browse}" Padding="10,2" Margin="6,0,0,0"
                             Click="BtnFolderBrowse_Click"/>
                </Grid>

                <TextBlock Grid.Row="2" Text="{loc:Get recent_paths}" Margin="0,0,0,4" Foreground="#9A9AA2"/>
                <ListBox x:Name="LstFolderRecent" Grid.Row="3"
                         SelectionChanged="LstFolderRecent_SelectionChanged"/>
            </Grid>

            <!-- Open browser panel -->
            <Grid x:Name="BrowserPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel x:Name="PnlBrowserChoices" Grid.Row="0" Margin="0,0,0,4"/>

                <RadioButton x:Name="RbBrowserOther" Grid.Row="1" Content="{loc:Get browser_other}"
                             GroupName="BrowserChoice" Margin="0,2,0,6" Checked="BrowserChoice_Changed"/>

                <Grid Grid.Row="2" Margin="18,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtBrowserOtherPath" Grid.Column="0"
                             VerticalContentAlignment="Center" FontFamily="Consolas"/>
                    <Button  x:Name="BtnBrowserOtherBrowse" Grid.Column="1"
                             Content="{loc:Get browse}" Padding="10,2" Margin="6,0,0,0"
                             Click="BtnBrowserOtherBrowse_Click"/>
                </Grid>

                <TextBlock Grid.Row="3" Text="{loc:Get browser_url_label}" Margin="0,0,0,4"/>
                <TextBox   x:Name="TxtBrowserUrl" Grid.Row="4" VerticalContentAlignment="Center"/>
            </Grid>

            <!-- Switch profile panel -->
            <Grid x:Name="ProfilePanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{loc:Get profile_targets_label}" Margin="0,0,0,6"/>

                <StackPanel x:Name="PnlProfileRows" Grid.Row="1"/>

                <Button x:Name="BtnProfileAddRow" Grid.Row="2" Content="{loc:Get profile_add_target}"
                        HorizontalAlignment="Left" Padding="10,4" Margin="0,6,0,0"
                        Click="BtnProfileAddRow_Click"/>
            </Grid>

            <!-- Simple selector panel (system command / media key / mouse action) -->
            <Grid x:Name="ComboPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="LblComboPanel" Grid.Row="0" Margin="0,0,0,4"/>
                <ComboBox  x:Name="CbComboValue" Grid.Row="1"/>
            </Grid>

            <!-- Keys panel -->
            <Grid x:Name="KeysPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{loc:Get keys_modifiers_label}" Margin="0,0,0,4"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="ChkKeyCtrl"  Content="Ctrl"  Margin="0,0,16,0"/>
                    <CheckBox x:Name="ChkKeyShift" Content="Shift" Margin="0,0,16,0"/>
                    <CheckBox x:Name="ChkKeyAlt"   Content="Alt"   Margin="0,0,16,0"/>
                    <CheckBox x:Name="ChkKeyWin"   Content="Win"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="{loc:Get keys_key_label}" Margin="0,0,0,4"/>
                <ComboBox  x:Name="CbKeyValue" Grid.Row="3" IsEditable="True"/>

                <TextBlock Grid.Row="4" Margin="0,8,0,0"
                           TextWrapping="Wrap" Foreground="#9A9AA2"
                           Text="{loc:Get keys_win_hint}"/>
            </Grid>

            <!-- Python Script panel -->
            <Grid x:Name="PyPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton x:Name="RbFile"   Content=".py File"
                                 GroupName="PyMode" Margin="0,0,18,0"
                                 Checked="PyMode_Changed"/>
                    <RadioButton x:Name="RbInline" Content="{loc:Get py_inline}"
                                 GroupName="PyMode"
                                 Checked="PyMode_Changed"/>
                </StackPanel>

                <!-- File mode: path + Browse -->
                <Grid x:Name="PathRow" Grid.Row="1" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtPath" Grid.Column="0"
                             VerticalContentAlignment="Center"
                             FontFamily="Consolas"/>
                    <Button  x:Name="BtnBrowse" Grid.Column="1"
                             Content="{loc:Get py_browse}" Padding="10,2" Margin="6,0,0,0"
                             Click="BtnBrowse_Click"/>
                </Grid>

                <!-- Inline mode: code editor -->
                <TextBox x:Name="TxtCode" Grid.Row="2"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" MinHeight="80"/>

                <Grid Grid.Row="3" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Get py_args}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox   x:Name="TxtArgs" Grid.Column="1"
                               FontFamily="Consolas"
                               VerticalContentAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="4" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Get py_timeout}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox   x:Name="TxtTimeout" Grid.Column="1" Width="70"
                               Text="60" VerticalContentAlignment="Center"/>
                </Grid>

                <TextBlock Grid.Row="5" Margin="0,8,0,0"
                           TextWrapping="Wrap" Foreground="#9A9AA2"
                           Text="{loc:Get py_hint}"/>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{loc:Get cancel}" Width="90" Padding="6,2"  Click="BtnCancel_Click"/>
            <Button Content="{loc:Get save}"   Width="90" Padding="6,2" Margin="8,0,0,0"
                    IsDefault="True"  Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
