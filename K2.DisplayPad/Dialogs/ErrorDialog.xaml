<Window x:Class="K2.DisplayPad.Dialogs.ErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:K2.Core;assembly=K2.Core"
        Title="K2 — Errore"
        Height="420" Width="720"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Topmost="True"
        Style="{StaticResource K2WindowStyle}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LblHeader" Grid.Row="0"
                   Text="Si e' verificato un errore"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

        <TextBox  x:Name="TxtMessage" Grid.Row="1"
                  IsReadOnly="True"
                  FontFamily="Consolas" FontSize="12"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  TextWrapping="NoWrap"
                  AcceptsReturn="True"/>

        <TextBlock x:Name="LblHint" Grid.Row="2"
                   Margin="0,8,0,0"
                   Foreground="#9A9AA2"
                   FontStyle="Italic"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Copia"      Width="100" Padding="6,2" Click="BtnCopy_Click"/>
            <Button Content="Apri log…"  Width="100" Padding="6,2" Margin="8,0,0,0" Click="BtnOpenLog_Click"/>
            <Button Content="{loc:Get ok}"         Width="100" Padding="6,2" Margin="8,0,0,0"
                    IsDefault="True"     IsCancel="True"           Click="BtnOk_Click"/>
        </StackPanel>
    </Grid>
</Window>
