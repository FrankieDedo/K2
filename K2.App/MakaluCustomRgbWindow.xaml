<Window x:Class="K2.App.MakaluCustomRgbWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:K2.Core;assembly=K2.Core"
        Title="{loc:Get makalu_custom_title}"
        Height="500" Width="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource K2WindowStyle}">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- hint -->
            <RowDefinition Height="340"/>   <!-- LED canvas -->
            <RowDefinition Height="Auto"/>  <!-- brightness -->
            <RowDefinition Height="Auto"/>  <!-- apply/close -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Get makalu_custom_hint}" TextWrapping="Wrap"
                   Foreground="{StaticResource K2TextMutedBrush}" FontStyle="Italic" FontSize="11"
                   Margin="0,0,0,8"/>

        <Border Grid.Row="1" Background="#111115" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="6">
            <Canvas x:Name="CvsLeds" Width="300" Height="330" ClipToBounds="True"/>
        </Border>

        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,8">
            <TextBlock Text="{loc:Get brightness}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <Slider x:Name="SldBrightness" Minimum="0" Maximum="100" Width="150" Value="100"
                    TickFrequency="25" IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                    ValueChanged="SldBrightness_ValueChanged" VerticalAlignment="Center"/>
            <TextBlock x:Name="LblBrightness" Text="100%" Margin="6,0,0,0" VerticalAlignment="Center" MinWidth="36"/>
        </WrapPanel>

        <DockPanel Grid.Row="3">
            <TextBlock x:Name="LblStatus" DockPanel.Dock="Left" VerticalAlignment="Center"
                       FontSize="11" Foreground="{StaticResource K2TextMutedBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{loc:Get makalu_apply}" Click="BtnApply_Click" Padding="10,4" Margin="0,0,6,0"/>
                <Button Content="{loc:Get makalu_close}" Click="BtnClose_Click" Padding="10,4"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
