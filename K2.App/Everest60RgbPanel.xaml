<UserControl x:Class="K2.App.Everest60RgbPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:K2.Core;assembly=K2.Core">
    <!-- "Lighting" section content for the Everest 60 tab, its own UserControl —
         DIRECT child of MainWindow.xaml (same pattern as Makalu's
         MakaluRgbSettingsPanel/MakaluDpiRemapPanel; see MakaluDpiRemapPanel.xaml
         for why not to nest it inside another custom control). Preset effect +
         side ring + per-key custom lighting are stacked together under one
         always-visible section (merged from 3 separate SECTIONS entries into
         one "Lighting" entry) — mirrors how Everest Max stacks its preset
         effect and "Custom Lighting (per-key)" blocks in one RGB & Lighting
         panel (MainWindow.xaml PnlSecRgb) instead of separate tabs. -->
    <Grid x:Name="SecLighting">
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260">
            <StackPanel>
                <!-- Preset RGB effect -->
                <TextBlock Text="{loc:Get rgb_lighting}" FontWeight="Bold" Margin="0,0,0,8"/>
                <!-- Same grouping/order as Everest Max's PnlSecRgb (effect, speed,
                     direction, rainbow — no sync, unsupported by this device):
                     merged into one WrapPanel 2026-07-14, was speed on its own row.
                     Brightness lives in MainWindow's shared top-right bar (BrEverest60),
                     not here — same convention as Everest Max/MacroPad/DisplayPad, see
                     MainWindow.SectionNav.cs. MainWindow calls SetBrightness() on change. -->
                <!-- Row 1: effect/speed/backlight switch (no Sync — unsupported by this device).
                     Backlight uses SetBacklightForcedOff (raw "Off" effect resend, no real
                     firmware on/off toggle on this device — see its doc comment), same
                     mechanism the auto-off idle timer already uses. -->
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="{loc:Get rgb_effect}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CbEv60Effect" Width="120" Margin="0,0,12,0"
                              SelectionChanged="CbEv60Effect_SelectionChanged"/>
                    <StackPanel x:Name="PnlEv60Speed" Orientation="Horizontal" Margin="0,0,12,0">
                        <TextBlock Text="{loc:Get rgb_speed}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="SldEv60Speed" Minimum="0" Maximum="100" Width="120"
                                TickFrequency="25" IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                                ValueChanged="SldEv60Speed_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LblEv60Speed" Text="50%" VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="36"/>
                    </StackPanel>
                    <TextBlock Text="{loc:Get led_backlight_label}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <CheckBox x:Name="CkEv60Backlight" Style="{StaticResource K2InlineSwitch}"
                        VerticalAlignment="Center" IsChecked="True" Click="CkEv60Backlight_Click"/>
                </WrapPanel>
                <!-- Backlight auto-off — moved here from MainWindow's Settings panel
                     (user request 2026-07-21), sized like the rest of this panel. -->
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="CkEv60AutoOffEnable" Content="{loc:Get backlight_auto_off_enable}"
                      Click="CkEv60AutoOffEnable_Click" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock Text="{loc:Get backlight_auto_off_seconds}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtEv60AutoOffSeconds" Width="70" TextAlignment="Center"
                     LostFocus="TxtEv60AutoOffSeconds_LostFocus" Text="5" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Get unit_seconds}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </WrapPanel>
                <!-- Row 2: direction (only when the effect supports it) -->
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <StackPanel x:Name="PnlEv60Direction" Orientation="Horizontal">
                        <TextBlock Text="{loc:Get rgb_direction}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Border Style="{StaticResource K2SegmentedGroupBorder}">
                            <UniformGrid x:Name="GridEv60Direction" Rows="1"/>
                        </Border>
                    </StackPanel>
                </WrapPanel>
                <!-- Row 3: color mode (Single/Double/Rainbow, one mutually-exclusive
                     vertical radio group) + swatches. -->
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Orientation="Vertical" Margin="0,0,20,0" VerticalAlignment="Center">
                        <RadioButton x:Name="RbEv60ColorSingle" Content="{loc:Get rgb_single}" GroupName="Ev60ColorMode"
                                     Margin="0,0,0,6" Checked="RbEv60ColorMode_Checked" ToolTip="{loc:Get rgb_single_tip}"/>
                        <RadioButton x:Name="RbEv60ColorDouble" Content="{loc:Get rgb_double}" GroupName="Ev60ColorMode"
                                     Margin="0,0,0,6" Checked="RbEv60ColorMode_Checked" ToolTip="{loc:Get rgb_double_tip}"/>
                        <RadioButton x:Name="RbEv60Rainbow" Content="{loc:Get rgb_rainbow}" GroupName="Ev60ColorMode"
                                     Checked="RbEv60ColorMode_Checked" ToolTip="{loc:Get rgb_rainbow_tip}"/>
                    </StackPanel>
                    <StackPanel x:Name="PnlEv60Color1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="{loc:Get rgb_primary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Button x:Name="BtnEv60Color1" Width="30" Height="30" Background="#900000"
                                BorderThickness="2" BorderBrush="#3A3A40" Click="BtnEv60Color_Click" Tag="1"/>
                    </StackPanel>
                    <StackPanel x:Name="PnlEv60Color2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Get rgb_secondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Button x:Name="BtnEv60Color2" Width="30" Height="30" Background="#1A1A1E"
                                BorderThickness="2" BorderBrush="#3A3A40" Click="BtnEv60Color_Click" Tag="2"/>
                    </StackPanel>
                </WrapPanel>

                <!-- Side ring + Key Lighting (paint) — hidden for now (2026-07-14,
                     user request: hide LED painting/ring sections on every device
                     with a Lighting section). Elements stay in the tree (code-behind
                     still references them) so re-enabling is a one-line Visibility flip. -->
                <StackPanel x:Name="PnlEv60SideRingSection" Visibility="Collapsed">
                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,10,0,8"/>
                <TextBlock Text="{loc:Get ev60_side_ring}" FontWeight="Bold" Margin="0,0,0,8"/>
                <WrapPanel Orientation="Horizontal">
                    <Button x:Name="BtnEv60SideColor" Width="30" Height="30" Background="#900000"
                            BorderThickness="2" BorderBrush="#3A3A40" Click="BtnEv60SideColor_Click"
                            Margin="0,0,10,0"/>
                    <Button x:Name="BtnEv60SideApply" Content="{loc:Get ev60_side_apply}"
                            Click="BtnEv60SideApply_Click" Padding="8,4"/>
                </WrapPanel>
                <TextBlock Text="{loc:Get ev60_side_hint}" TextWrapping="Wrap"
                           Foreground="{StaticResource K2TextMutedBrush}" FontStyle="Italic" FontSize="11"
                           Margin="0,8,0,0" MaxWidth="640"/>
                </StackPanel>

                <!-- Per-key custom lighting ("Key Lighting"): paint mode over the
                     64-key overlay above (CvsEv60Keyboard in MainWindow.xaml). No
                     live device readback exists for this raw-HID board (no
                     GetColorData equivalent) — the preview is software-only: a key
                     shows its picked color as soon as it's painted/applied. Mirrors
                     Everest Max's "Custom Lighting (per-key)" block
                     (MainWindow.CustomLighting.cs). -->
                <StackPanel x:Name="PnlEv60KeyLightingSection" Visibility="Collapsed">
                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,10,0,8"/>
                <TextBlock Text="{loc:Get ev60_key_lighting}" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock Text="{loc:Get ev60_key_lighting_hint}"
                           Foreground="#9A9AA2" FontStyle="Italic"
                           TextWrapping="Wrap" Margin="0,0,0,6"/>
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <CheckBox x:Name="CkEv60CustomPaint" Content="{loc:Get custom_paint_mode}"
                              Foreground="White" Margin="0,0,12,0"
                              Checked="CkEv60CustomPaint_Checked"
                              Unchecked="CkEv60CustomPaint_Checked"/>
                    <TextBlock Text="{loc:Get custom_color}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button x:Name="BtnEv60CustomBrushColor" Width="30" Height="30"
                            Background="#900000" BorderThickness="2"
                            BorderBrush="#3A3A40" Click="BtnEv60CustomBrushColor_Click"/>
                </WrapPanel>
                <WrapPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Get brightness}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="SldEv60CustomBrightness" Minimum="0" Maximum="100" Width="120"
                            TickFrequency="25" IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                            VerticalAlignment="Center" ValueChanged="SldEv60CustomBrightness_ValueChanged"/>
                    <TextBlock x:Name="LblEv60CustomBrightness" Text="100%" VerticalAlignment="Center" Margin="6,0,16,0" MinWidth="36"/>
                    <Button x:Name="BtnEv60CustomApply" Content="{loc:Get apply_to_device}" Padding="8,2" Margin="0,0,4,0"
                            Click="BtnEv60CustomApply_Click" Style="{StaticResource K2IconAccentButton}" Tag="&#xE73E;"/>
                    <Button x:Name="BtnEv60CustomClear" Content="{loc:Get custom_clear}" Padding="8,2"
                            Click="BtnEv60CustomClear_Click" Style="{StaticResource K2IconButton}" Tag="&#xE74D;"/>
                </WrapPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
