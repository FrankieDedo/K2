<UserControl x:Class="K2.App.MakaluDpiRemapPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:K2.Core;assembly=K2.Core">
    <!-- "Key Binding" (button remap) section content — DIRECT child of
         MainWindow.xaml (MainWindow.Makalu.cs toggles SecRemap directly).
         Despite the class name (kept for now to limit churn), DPI no longer
         lives here — its levels list moved into MakaluRgbSettingsPanel's
         Settings section. Do not nest this inside another custom
         UserControl (a "shell" wrapping this + MakaluRgbSettingsPanel) —
         that specific nesting was tried 2026-07-10 and appeared to crash,
         though the WinDbg session that eventually root-caused the *real*
         bug that day (a plain null-ref in MkSection_Changed/
         SldMkDpi_ValueChanged firing before dependent fields were assigned
         — see MainWindow.Makalu.cs and _mkSuppress above) suggests the
         "nesting" theory may itself have been a misdiagnosis of the same
         root cause, never independently re-verified after the real fix.
         Treat nesting as unconfirmed-risky, not proven-safe, until someone
         actually retests it. -->
    <Grid>
        <!-- Remap ("Key Binding" in the sidebar — DPI used to live here too,
             now moved into MakaluRgbSettingsPanel's Settings section, see
             MainWindow.xaml). This is the default Makalu section (see
             InitMkSectionNav), so it starts Visible, not Collapsed — the
             sibling sections in MakaluRgbSettingsPanel (SecRgb/SecSettings)
             both start Collapsed to match. -->
        <Grid x:Name="SecRemap">
            <StackPanel>
                <TextBlock Text="{loc:Get makalu_remap_title}" FontWeight="Bold" Margin="0,0,0,14"/>
                <WrapPanel x:Name="PnlMkRemapButtons" Orientation="Horizontal" Margin="0,0,0,12"/>
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="{loc:Get makalu_remap_category}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CbMkRemapCategory" Width="110" Margin="0,0,12,0"
                              SelectionChanged="CbMkRemapCategory_SelectionChanged"/>
                    <TextBlock Text="{loc:Get makalu_remap_function}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CbMkRemapFunction" Width="150"/>
                </WrapPanel>
                <WrapPanel x:Name="PnlMkSniper" Orientation="Horizontal" Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock Text="{loc:Get makalu_remap_sniper_dpi}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="SldMkSniperDpi" Minimum="50" Maximum="19000" Width="160"
                            ValueChanged="SldMkSniperDpi_ValueChanged" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMkSniperDpi" Width="70" Margin="8,0,0,0" TextAlignment="Center"
                             KeyDown="TxtMkSniperDpi_KeyDown" LostFocus="TxtMkSniperDpi_LostFocus"/>
                </WrapPanel>
                <WrapPanel Orientation="Horizontal">
                    <Button x:Name="BtnMkRemapApply" Content="{loc:Get makalu_apply}" Click="BtnMkRemapApply_Click" Padding="8,4" Margin="0,0,6,0"/>
                    <TextBlock x:Name="LblMkRemapStatus" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource K2TextMutedBrush}"/>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <!-- Remap-left-button safety confirm overlay (auto-revert countdown) -->
        <Border x:Name="PnlMkRemapConfirm" Panel.ZIndex="20"
                Background="#CC000000" Visibility="Collapsed">
            <Border Background="#1E1E24" BorderBrush="#3A3A40" BorderThickness="1" CornerRadius="8"
                    Padding="20" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="LblMkRemapConfirmText" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnMkRemapKeep" Content="{loc:Get makalu_remap_keep_btn}"
                                Click="BtnMkRemapKeep_Click" Padding="10,5" Margin="0,0,8,0"/>
                        <Button x:Name="BtnMkRemapRevert" Content="{loc:Get makalu_remap_revert_btn}"
                                Click="BtnMkRemapRevert_Click" Padding="10,5"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
