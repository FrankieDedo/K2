<UserControl x:Class="K2.App.Everest60KeyBindingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:K2.Core;assembly=K2.Core">
    <!-- "Key Binding" section content for the Everest 60 tab — DIRECT child of
         MainWindow.xaml (same reasoning as Everest60RgbPanel/MakaluDpiRemapPanel:
         see MakaluDpiRemapPanel.xaml for why not nested). Unlike Makalu's remap
         (which draws its own hotspot dots on the device image), this reuses the
         64-key overlay already built for lighting (CvsEv60Keyboard in
         MainWindow.xaml/MainWindow.Everest60.cs) as the key picker: clicking a
         key while this section is active calls SelectKey() below.
         2026-07-14 (second pass, explicit user request — "same popup, same
         options and mappings as Everest Max"): this is no longer a raw
         firmware remap. Key Binding now goes through the SAME
         K2.Core.ButtonActionDialog and the same K2Action catalog as Everest
         Max/MacroPad/DisplayPad, via Ev60ActionHost/ButtonActionEngine (owned
         by MainWindow.Everest60.cs) — same hint+list+Configure/Remove layout
         as Everest Max's Key Binding section (MainWindow.xaml
         PnlSecKeyMapping/LvEvKeys). Physical key presses are reported by the
         vendor SDK's key callback (Everest60SdkService.KeyEvent) and executed
         through the same engine — see MainWindow.Everest60.cs's OnEv60Key.
         2026-07-14 (third pass, explicit user request — "make the mapped-keys
         box exactly like Everest Max"): root is now a Grid (not a StackPanel)
         with an Auto/Auto/*/Auto row split, same reasoning as Everest Max's
         PnlSecKeyMapping (MainWindow.xaml) — a StackPanel always sizes a child
         to its natural height, so LvEv60Keys previously needed a fixed
         MaxHeight (260) and left dead space below it; a Grid's "*" row
         actually stretches the ListView to fill the Border, exactly like
         Everest Max's LvEvKeys. This only takes effect because the panel's
         host (MainWindow.xaml) no longer wraps it in a shared ScrollViewer
         either — see the matching 2026-07-14 note there. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- title -->
            <RowDefinition Height="Auto"/> <!-- hint -->
            <RowDefinition Height="*"/>    <!-- list + buttons: fills remaining height -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Get ev60_key_binding}" FontWeight="Bold" Margin="0,0,0,6"/>
        <TextBlock Grid.Row="1" Text="{loc:Get ev60_key_binding_hint}"
                   Foreground="#9A9AA2" FontStyle="Italic"
                   TextWrapping="Wrap" Margin="0,0,0,8"/>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="170"/>
            </Grid.ColumnDefinitions>
            <ListView Grid.Column="0" x:Name="LvEv60Keys" Margin="0,0,8,0"
                      SelectionChanged="LvEv60Keys_SelectionChanged">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter Property="Background" Value="#900000"/>
                                <Setter Property="Foreground" Value="#10302F"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Display}" FontFamily="Consolas" Padding="2"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <Button x:Name="BtnEv60Configure" Content="{loc:Get ev_configure}" Padding="8,4"
                        Click="BtnEv60Configure_Click" HorizontalAlignment="Stretch" Margin="0,0,0,4"
                        IsEnabled="False"/>
                <Button x:Name="BtnEv60Remove" Content="{loc:Get ev_remove}" Padding="8,4"
                        Click="BtnEv60Remove_Click" HorizontalAlignment="Stretch"
                        IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
