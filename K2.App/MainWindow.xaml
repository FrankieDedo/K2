                                                        </WrapPanel>

                                                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                            <CheckBox x:Name="CkEvKeycapEditMode" Content="{loc:Get settings_keycap_edit_individual}"
                                                              Click="CkEvKeycapEditMode_Click" Margin="0,5,0,0"/>
                                                        </WrapPanel>
                                                        <TextBlock Text="{loc:Get settings_keycap_edit_individual_hint}" Foreground="#9A9AA2"
                                                               TextWrapping="Wrap" Margin="0,3,0,10" FontSize="12"/>


                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Grid.Column="1">

                                                        <!-- Moved above Game Mode + Reset defaults button removed
                                                         (planned to come back later as a shared control for all
                                                         devices, not just Everest Max) per user request
                                                         2026-07-21. -->
                                                        <TextBlock Text="{loc:Get keyboard_language_layout}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                            <TextBlock Text="{loc:Get ev_layout}" VerticalAlignment="Center"
                                                           FontWeight="SemiBold" Margin="0,0,6,0"/>
                                                            <ComboBox x:Name="CbEvKeyboardLayout" Width="200" Height="25" VerticalAlignment="Center"/>
                                                        </WrapPanel>

                                                        <TextBlock Text="{loc:Get settings_game_mode}" FontWeight="SemiBold" Margin="0,0,0,6"
                                                           ToolTip="{loc:Get settings_game_mode_tip}"/>
                                                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                            <CheckBox x:Name="CkGameModeShiftTab" Content="{loc:Get settings_disable_shift_tab}" Click="CkGameMode_Click" Height="25" Margin="0,0,10,0"/>
                                                            <CheckBox x:Name="CkGameModeAltF4" Content="{loc:Get settings_disable_alt_f4}" Click="CkGameMode_Click" Height="25" Margin="0,0,10,0"/>
                                                            <CheckBox x:Name="CkGameModeWinKey" Content="{loc:Get settings_disable_win_key}" Click="CkGameMode_Click" Height="25" Margin="0,0,10,0"/>
                                                            <CheckBox x:Name="CkGameModeAltTab" Content="{loc:Get settings_disable_alt_tab}" Click="CkGameMode_Click" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,0" Height="25"/>
                                                        </WrapPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="440"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="{loc:Get settings_indicator_leds}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                                                <WrapPanel Orientation="Horizontal">
                                                                    <CheckBox x:Name="CkCoreIndicatorLed" Height="25" Content="{loc:Get settings_enable_core_led}"
                                                              Click="CkCoreIndicatorLed_Click"/>
                                                                </WrapPanel>
                                                            </StackPanel>


                                                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="232,0,0,0" Width="307">
                                                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                    <TextBlock Text="{loc:Get settings_keyboard_color}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                                                </WrapPanel>
                                                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                    <Border Style="{StaticResource K2SegmentedGroupBorder}" Width="140">
                                                                        <UniformGrid Rows="1">
                                                                            <RadioButton x:Name="RbEvKbColorSilver" Content="{loc:Get color_silver}" GroupName="EvKbColor" Style="{StaticResource K2SegmentedButton}" Checked="RbEvKbColor_Checked" themes:K2Segment.CornerRadius="6,0,0,6"/>
                                                                            <RadioButton x:Name="RbEvKbColorBlack" Content="{loc:Get color_black}" GroupName="EvKbColor" Style="{StaticResource K2SegmentedButton}" Checked="RbEvKbColor_Checked" themes:K2Segment.CornerRadius="0,6,6,0"/>
                                                                        </UniformGrid>
                                                                    </Border>
                                                                </WrapPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </ScrollViewer>

                                            <!-- ── USB RECORDER (debug only) ── (own ScrollViewer, same reason
                                             as Display Dial/Settings above) -->
                                            <ScrollViewer x:Name="PnlSecUsb" Visibility="Collapsed"
                                                      VerticalScrollBarVisibility="Auto" Grid.RowSpan="2">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                                        <TextBlock Text="{loc:Get usb_interface}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <ComboBox x:Name="CbUsbInterface" Width="200" Margin="0,0,8,0"/>
                                                        <Button x:Name="BtnUsbRefresh" Content="{loc:Get usb_detect}" Padding="6,2"
                                                        Margin="0,0,8,0" Click="BtnUsbRefresh_Click"
                                                        Style="{StaticResource K2IconButton}" Tag="&#xE72C;"/>
                                                        <TextBlock Text="{loc:Get usb_label}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBox x:Name="TxtUsbLabel" Width="120" Margin="0,0,8,0" Text="basecamp"/>
                                                        <Button x:Name="BtnUsbRecord" Content="Start" Padding="8,2"
                                                        Click="BtnUsbRecord_Click"
                                                        Style="{StaticResource K2IconAccentButton}" Tag="&#xE7C8;"/>
                                                    </WrapPanel>
                                                    <TextBlock Grid.Row="1" x:Name="LblUsbStatus" Margin="0,0,0,4"
                                                       FontStyle="Italic" Foreground="#9A9AA2"
                                                       Text="{loc:Get usb_ready}"/>
                                                    <Expander Grid.Row="2" Header="{loc:Get usb_results}" IsExpanded="False"
                                                      x:Name="ExpUsbResults" Visibility="Collapsed">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="100"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBox Grid.Row="0" x:Name="TxtUsbResults"
                                                             IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                                             VerticalScrollBarVisibility="Auto"
                                                             HorizontalScrollBarVisibility="Auto"
                                                             TextWrapping="NoWrap" AcceptsReturn="True"/>
                                                            <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                                <Button x:Name="BtnUsbSave"       Content="{loc:Get usb_save_report}" Padding="6,2" Margin="0,0,6,0" Click="BtnUsbSave_Click"/>
                                                                <Button x:Name="BtnUsbOpenFolder" Content="{loc:Get act_folder}"      Padding="6,2"                   Click="BtnUsbOpenFolder_Click"/>
                                                            </WrapPanel>
                                                        </Grid>
                                                    </Expander>
                                                </Grid>
                                            </ScrollViewer>

                                        </Grid>
                                        <!-- end section panels grid -->

                                        <!-- SDK Log: debug only, always at bottom of settings panel -->
                                        <GroupBox Grid.Row="1" x:Name="GbEvLog" Header="{loc:Get ev_sdk_log}"
                                              Visibility="Collapsed" Margin="0,10,0,0">
                                            <TextBox x:Name="TxtEvLog"
                                                 IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 TextWrapping="NoWrap" AcceptsReturn="True"
                                                 MaxHeight="100"/>
                                        </GroupBox>
                                    </Grid>
                                </Border>
                                <!-- end settings panel -->

                            </Grid>
                            <!-- end right column -->

                            <!-- Common actions (same rule for all devices): uniform width/height,
                             vertical stack, grouped Profile / Import / Device -->
                            <Border Grid.Column="2" Background="#111115" CornerRadius="6"
                                Margin="8,0,0,0" Padding="10" VerticalAlignment="Top">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{loc:Get profile}"
                                               Style="{StaticResource K2SideGroupHeader}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" x:Name="BtnEvProfileMenu"
                                            Style="{StaticResource MacroRowIconButton}" Tag="&#xE712;"
                                            ToolTip="{loc:Get profile}" Click="BtnEvProfileMenu_Click"/>
                                    </Grid>
                                    <ListBox x:Name="LstEvProfile" Style="{StaticResource K2SideProfileList}"
                                         SelectionChanged="LstEvProfile_SelectionChanged"/>

                                    <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                    <TextBlock Text="{loc:Get device}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <Button x:Name="BtnEvRename" Content="{loc:Get rename_device}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8D3;"
                                        Click="BtnEvRename_Click"/>
                                    <Button x:Name="BtnEvRestoreDefaults" Content="{loc:Get restore_defaults}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE777;"
                                        Click="BtnEvRestoreDefaults_Click"/>

                                    <StackPanel x:Name="PnlEvDebugGroup" Visibility="Collapsed">
                                        <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                        <TextBlock Text="{loc:Get debug_group}" Style="{StaticResource K2SideGroupHeader}"/>
                                        <Button x:Name="BtnEvRefresh" Content="{loc:Get refresh}"
                                            Style="{StaticResource K2SideActionButton}" Tag="&#xE72C;"
                                            Click="BtnEvRefresh_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <!-- end 3-pane -->
                    </Grid>
                </Grid>
                <!-- end PnlEverest -->

                <!-- ==================== Everest 60 (raw-HID lighting only) ==================== -->
                <!-- ==================== Everest 60 ====================
                 Same 3-column pattern as Makalu (see MainWindow.Makalu.cs
                 for the lessons learned about XAML-load-time event firing —
                 RbEv60SecRgb.IsChecked is set in InitEv60SectionNav, not
                 XAML). Device image is decorative only (no clickable
                 hotspots): unlike Makalu, no per-key/per-button remap
                 protocol exists for this device (raw-HID, firmware remap
                 never reverse-engineered — see architectural note above). -->
                <Grid x:Name="PnlEverest60" Visibility="Collapsed">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <!-- Fixed (not Auto): keeps the sidebar/content start position
                             identical across devices — same rule as PnlEverest. Connected
                             status + Refresh moved to the common-actions Debug group (see
                             PnlEv60DebugGroup below); this toolbar is debug-only like the
                             other devices', just with nothing to show yet for this one. -->
                            <RowDefinition Height="32"/>
                            <!-- toolbar -->
                            <RowDefinition Height="*"/>
                            <!-- sections/image/common columns -->
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <!-- sidebar -->
                                <ColumnDefinition Width="*"/>
                                <!-- image + section content -->
                                <!-- Fixed at 218, NOT Auto: Auto let a NoWrap log TextBox (now removed)
                                 drive the column's width to whatever its longest line needed, so it
                                 kept growing as new log lines came in. 218 = the Border's own
                                 Margin.Left="8" + its 210px desired width (190px buttons + 10px
                                 padding each side) — same effective pixel width Everest Max/MacroPad/
                                 DisplayPad's Auto column resolves to (safe there only because none of
                                 their common-actions content is unbounded-width). -->
                                <ColumnDefinition Width="218"/>
                                <!-- common actions -->
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: specific sections -->
                            <Border Grid.Column="0" Background="#111115" CornerRadius="6"
                                Margin="0,0,8,0" Padding="4">
                                <StackPanel>
                                    <TextBlock Text="SECTIONS" FontSize="9" Foreground="#4A4A58"
                                           Margin="14,8,0,6" FontWeight="Bold"/>
                                    <RadioButton x:Name="RbEv60SecKeyBinding"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev60_key_binding}" GroupName="Ev60Sections"
                                             Checked="Ev60Section_Changed"/>
                                    <RadioButton x:Name="RbEv60SecLighting"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get rgb_lighting}" GroupName="Ev60Sections"
                                             Checked="Ev60Section_Changed"/>
                                    <RadioButton x:Name="RbEv60SecSettings"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_settings}" GroupName="Ev60Sections"
                                             Checked="Ev60Section_Changed"/>
                                </StackPanel>
                            </Border>

                            <!-- CENTER: device image (top, fixed height) + selected section content (bottom, grows) -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <!-- Fixed height across all devices, matching MacroPad's box height
                                     when rotated to vertical orientation (Positioning section,
                                     90°/270°): the canvas is 510x370, but RotateTransform swaps its
                                     rendered footprint to 370x510, so 510 + 8px padding each side = 526
                                     is the tallest a device box needs to be. -->
                                    <RowDefinition Height="526"/>
                                    <!-- device -->
                                    <RowDefinition Height="*"/>
                                    <!-- section content: grows with window height -->
                                </Grid.RowDefinitions>

                                <!-- Interactive keyboard overlay: 64 paintable main-board keys (Key
                                 Lighting section, per-key custom color) over the flat everest60_board.png
                                 panel — same technique as Everest Max's CvsEvKeyboard/keybg.png. The
                                 numpad accessory is decorative-only (no known LED/remap protocol for
                                 it — see Everest60KeyboardLayout.Numpad); presence and side (left/right)
                                 are auto-detected via Everest60SdkNative.GetSubDeviceInfo and polled by
                                 Ev60RefreshStatus (MainWindow.Everest60.cs) — CvsEv60Numpad is moved to
                                 either side of SpEv60Layout and BrushEv60NumpadBg mirrored for "right"
                                 (no separate right-side art exists — see EV60_NumpadLeft.png, no
                                 EV60_NumpadRight.png in Base Camp's own assets). -->
                                <Border Grid.Row="0" Background="#18181C" CornerRadius="6" Padding="8">
                                    <StackPanel x:Name="SpEv60Layout" Orientation="Horizontal"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- +20% zoom on request, same as Everest Max's SpEvLayout:
                                         LayoutTransform (not RenderTransform) so the Grid/Border
                                         re-measures at the scaled size and WPF's hit-testing keeps
                                         mapping clicks to the right Button automatically — no changes
                                         needed to Everest60KeyboardLayout's X/Y/W/H math. -->
                                        <StackPanel.LayoutTransform>
                                            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                        </StackPanel.LayoutTransform>
                                        <Canvas x:Name="CvsEv60Numpad" Width="154" Height="186"
                                            ClipToBounds="True" Margin="0,0,6,0"
                                            Visibility="Collapsed">
                                            <Canvas.Background>
                                                <ImageBrush x:Name="BrushEv60NumpadBg"
                                                        ImageSource="Assets/everest60_numpad.png" Stretch="Fill"/>
                                            </Canvas.Background>
                                        </Canvas>
                                        <Canvas x:Name="CvsEv60Keyboard" Width="504" Height="186"
                                            ClipToBounds="True">
                                            <Canvas.Background>
                                                <ImageBrush ImageSource="Assets/everest60_board.png" Stretch="Fill"/>
                                            </Canvas.Background>
                                        </Canvas>
                                    </StackPanel>
                                </Border>

                                <!-- Bottom section panel: grows with the window (Row="*" above); MinHeight
                                 keeps its old fixed size as a floor so it doesn't collapse below the
                                 tallest section (RGB Lighting / Side Ring). -->
                                <Border Grid.Row="1" Background="#14141A"
                                    BorderBrush="#2A2A32" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,8,0,0"
                                    MinHeight="150">
                                    <!-- 2026-07-14: no more shared ScrollViewer wrapping all three
                                         sections — same reasoning as Everest Max's BdrEvSettingsPanel
                                         (see its comment): a ScrollViewer gives its content infinite
                                         available height, so Ev60KeyBindingPanel's Grid "*" row could
                                         never actually stretch LvEv60Keys to fill this Border (user
                                         request: "make the mapped-keys box exactly like Everest Max").
                                         Each section now owns its own overflow instead: Ev60RgbPanel
                                         already had its own internal ScrollViewer (MaxHeight=260);
                                         PnlEv60Settings gets one here, on the section root itself, same
                                         pattern as Everest Max's PnlSecRgb/PnlSecDial/PnlSecSettings
                                         (ScrollViewer IS the named/toggled element). -->
                                    <Grid>
                                        <!-- All three default Collapsed: InitEv60SectionNav (code-behind)
                                             sets RbEv60SecKeyBinding.IsChecked=true at startup, which fires
                                             Ev60Section_Changed -> ShowEv60Section(Ev60KeyBindingPanel) —
                                             but ShowEv60Section only COLLAPSES the previously active panel
                                             (none yet, on first run), it never assumes the others start
                                             hidden. Ev60RgbPanel previously had no explicit Visibility here
                                             (implicit default = Visible), so it stayed visible underneath
                                             Ev60KeyBindingPanel until the user manually clicked into
                                             Lighting once — visible as both sections' content overlapping
                                             on first opening the Everest 60 tab. -->
                                        <local:Everest60RgbPanel x:Name="Ev60RgbPanel" Loaded="Ev60RgbPanel_Loaded" Visibility="Collapsed"/>
                                        <local:Everest60KeyBindingPanel x:Name="Ev60KeyBindingPanel" Visibility="Collapsed"/>

                                        <!-- ── SETTINGS ── Keycap Appearance: purely cosmetic, same
                                             on-screen-only semantics as MainWindow.KeycapAppearance.cs
                                             for Everest Max (no live LED tick blend modes here, since
                                             this raw-HID board has no GetColorData-equivalent readback
                                             to blend with — just a static base/text color choice).
                                             Layout: locale legend selector (Everest60KeyboardLayout.GetMainBoard),
                                             same physical 64-key board for every locale (no ISO variant on this
                                             hardware — confirmed no backtick/ISO-102 key) — only the printed
                                             legends change, LED index/physical position stays fixed. -->
                                        <ScrollViewer x:Name="PnlEv60Settings"
                                                      VerticalScrollBarVisibility="Auto" Visibility="Collapsed">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{loc:Get settings_keycap_group}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <TextBlock Text="{loc:Get settings_keycap_color}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <RadioButton x:Name="RbEv60KeycapBlack" Content="{loc:Get settings_keycap_black}"
                                                             GroupName="Ev60KeycapColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbEv60KeycapColor_Checked"/>
                                                        <RadioButton x:Name="RbEv60KeycapWhite" Content="{loc:Get settings_keycap_white}"
                                                             GroupName="Ev60KeycapColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbEv60KeycapColor_Checked"/>
                                                        <RadioButton x:Name="RbEv60KeycapCustom" Content="{loc:Get settings_keycap_custom}"
                                                             GroupName="Ev60KeycapColor" VerticalAlignment="Center"
                                                             Margin="0,0,6,0" Checked="RbEv60KeycapColor_Checked"/>
                                                        <Button x:Name="BtnEv60KeycapCustomColor" Width="30" Height="30"
                                                        Background="#404040" BorderThickness="2" BorderBrush="#3A3A40"
                                                        Click="BtnEv60KeycapCustomColor_Click" Margin="5,0,0,0"/>
                                                    </WrapPanel>
                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="{loc:Get settings_keycap_text_color}" VerticalAlignment="Center" Margin="0,0,6,0" Padding="0,0,18,0"/>
                                                        <RadioButton x:Name="RbEv60KeycapTextBlack" Content="{loc:Get settings_keycap_black}"
                                                             GroupName="Ev60KeycapTextColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbEv60KeycapTextColor_Checked"/>
                                                        <RadioButton x:Name="RbEv60KeycapTextWhite" Content="{loc:Get settings_keycap_white}"
                                                             GroupName="Ev60KeycapTextColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbEv60KeycapTextColor_Checked"/>
                                                        <RadioButton x:Name="RbEv60KeycapTextCustom" Content="{loc:Get settings_keycap_custom}"
                                                             GroupName="Ev60KeycapTextColor" VerticalAlignment="Center"
                                                             Margin="0,0,6,0" Checked="RbEv60KeycapTextColor_Checked"/>
                                                        <Button x:Name="BtnEv60KeycapTextColor" Width="30" Height="30"
                                                        Background="White" BorderThickness="2" BorderBrush="#3A3A40"
                                                        Click="BtnEv60KeycapTextColor_Click" Margin="5,0,0,0"/>
                                                    </WrapPanel>
                                                    <!-- Keycap style: imported from Everest Max's Settings section
                                                 (settings_keycap_style/CbEvKeycapStyle). No live LED tick to
                                                 blend with on this raw-HID board, so the "live" signal each
                                                 style blends with is the Key Lighting section's painted
                                                 per-key color instead (see ApplyEv60KeycapAppearanceToAllKeys) —
                                                 applies to the numpad too (always the "off" baseline there,
                                                 since it's never painted). -->
                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="{loc:Get settings_keycap_style}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <ComboBox x:Name="CbEv60KeycapStyle" Width="240"
                                                          SelectionChanged="CbEv60KeycapStyle_SelectionChanged" Margin="4,0,0,0"/>
                                                    </WrapPanel>
                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <CheckBox x:Name="CkEv60KeycapTranslucentLegend" Content="{loc:Get settings_keycap_translucent_legend}"
                                                          Click="CkEv60KeycapTranslucentLegend_Click"/>
                                                    </WrapPanel>

                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                        <CheckBox x:Name="CkEv60KeycapEditMode" Content="{loc:Get settings_keycap_edit_individual}"
                                                          Click="CkEv60KeycapEditMode_Click" Margin="0,5,0,0"/>
                                                    </WrapPanel>
                                                    <TextBlock Text="{loc:Get settings_keycap_edit_individual_hint}" Foreground="#9A9AA2"
                                                       TextWrapping="Wrap" Margin="0,3,0,10" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{loc:Get keyboard_language_layout}" FontWeight="SemiBold" Margin="0,0  ,0,10"/>
                                                    <WrapPanel Orientation="Horizontal">
                                                        <TextBlock Text="{loc:Get ev_layout}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                                        <ComboBox x:Name="CbEv60KeyboardLayout" Width="200" Margin="0,0,16,0"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Grid>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- RIGHT: generic settings — Profile/Import/Export now backed by
                             Everest60Store (see MainWindow.Everest60.cs), same pattern as
                             Everest Max's LstEvProfile block. Device rename via AppSettings unchanged. -->
                            <Border Grid.Column="2" Background="#111115" CornerRadius="6"
                                Margin="8,0,0,0" Padding="10" VerticalAlignment="Top">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{loc:Get profile}"
                                               Style="{StaticResource K2SideGroupHeader}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" x:Name="BtnEv60ProfileMenu"
                                            Style="{StaticResource MacroRowIconButton}" Tag="&#xE712;"
                                            ToolTip="{loc:Get profile}" Click="BtnEv60ProfileMenu_Click"/>
                                    </Grid>
                                    <ListBox x:Name="LstEv60Profile" Style="{StaticResource K2SideProfileList}"
                                         SelectionChanged="LstEv60Profile_SelectionChanged"/>

                                    <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                    <TextBlock Text="{loc:Get device}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <Button x:Name="BtnEv60Rename" Content="{loc:Get rename_device}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8AC;"
                                        Click="BtnEv60Rename_Click"/>
                                    <Button x:Name="BtnEv60RestoreDefaults" Content="{loc:Get restore_defaults}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE777;"
                                        Click="BtnEv60RestoreDefaults_Click"/>

                                    <!-- Debug group: same position/pattern as PnlEvDebugGroup/PnlMpDebugGroup/
                                     PnlDpDebugGroup (right after Device, toggled by ApplyEv60DebugMode).
                                     Connected status + manual Refresh moved here from the toolbar above —
                                     the 3s poll (Ev60RefreshStatus) keeps updating LblEv60Status regardless
                                     of whether this group is visible. -->
                                    <StackPanel x:Name="PnlEv60DebugGroup" Visibility="Collapsed">
                                        <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                        <TextBlock Text="{loc:Get debug_group}" Style="{StaticResource K2SideGroupHeader}"/>
                                        <TextBlock x:Name="LblEv60Status" Text="{loc:Get ev60_status_disconnected}"
                                               FontWeight="Bold" Margin="0,0,0,6"/>
                                        <Button x:Name="BtnEv60Refresh" Content="{loc:Get ev60_refresh}"
                                            Style="{StaticResource K2SideActionButton}" Tag="&#xE72C;"
                                            Click="BtnEv60Refresh_Click"/>
                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
                <!-- end PnlEverest60 -->

                <!-- ==================== Makalu (mouse) ====================
                 Sections (RGB Lighting/DPI/Remap/Settings) at left, device
                 image with clickable remap hotspots + selected section
                 content in the middle, generic Profile/Import/Export/Device
                 column at right — same pattern as MacroPad/Everest/
                 DisplayPad. Section content is split into two UserControls
                 (MakaluRgbSettingsPanel, MakaluDpiRemapPanel), kept as
                 DIRECT MainWindow children (not nested inside another
                 custom control — see MakaluDpiRemapPanel.xaml for why that
                 specific nesting is unsafe).

                 The "Invalid Program: attempted to call a UnmanagedCallersOnly
                 method from managed code" crash this layout used to trigger
                 (2026-07-10, root-caused with WinDbg+SOS) was NOT a JIT/CLR
                 bug: it was RbMkSecRgb's IsChecked="True" firing Checked
                 synchronously mid-InitializeComponent(), before MkRgbSettings
                 (declared later in this file) was assigned — a plain null
                 ref that .NET's crash reporter mislabeled with that generic
                 message. Fixed by setting IsChecked in code (see
                 InitMkSectionNav in MainWindow.Makalu.cs) instead of XAML.
                 A second instance of the same pattern (Slider.Minimum
                 coercing Value during load, firing ValueChanged before a
                 later-declared TextBox was assigned) was found and fixed in
                 MakaluDpiRemapPanel. See CHANGELOG.md 2026-07-10 for the
                 full WinDbg session — any new event handler wired to a
                 property that gets a literal value in XAML needs to guard
                 against firing before InitializeComponent() finishes. -->
                <Grid x:Name="PnlMakalu" Visibility="Collapsed">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <!-- Fixed (not Auto): keeps the sidebar/content start position
                             identical across devices — same rule as PnlEverest. Connected
                             status + Refresh moved to the common-actions Debug group (see
                             PnlMkDebugGroup below); this toolbar is debug-only like the
                             other devices', just with nothing to show yet for this one. -->
                            <RowDefinition Height="32"/>
                            <!-- toolbar -->
                            <RowDefinition Height="*"/>
                            <!-- sections/image/common columns -->
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <!-- sidebar -->
                                <ColumnDefinition Width="*"/>
                                <!-- image + section content -->
                                <!-- Fixed at 218, NOT Auto: a NoWrap log TextBox lives in this column
                                 (TxtMkLog) — Auto would let it drive the column's width to whatever
                                 its longest line needs, growing further with every new log line (the
                                 exact bug hit on Everest 60's identical column, see MainWindow.xaml's
                                 Everest 60 grid). 218 = the Border's own Margin.Left="8" + its 210px
                                 desired width (190px buttons + 10px padding each side) — same
                                 effective pixel width Everest Max/MacroPad/DisplayPad's Auto column
                                 resolves to (safe there only because none of their common-actions
                                 content is unbounded-width). -->
                                <ColumnDefinition Width="218"/>
                                <!-- common actions -->
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: specific sections -->
                            <Border Grid.Column="0" Background="#111115" CornerRadius="6"
                                Margin="0,0,8,0" Padding="4">
                                <StackPanel>
                                    <TextBlock Text="SECTIONS" FontSize="9" Foreground="#4A4A58"
                                           Margin="14,8,0,6" FontWeight="Bold"/>
                                    <!-- Order matches MacroPad/DisplayPad/Everest 60: Key Binding
                                     first (also the default section, see InitMkSectionNav),
                                     device-specific Lighting in the middle, Settings last. DPI
                                     is no longer a section of its own — its levels list now
                                     lives inside Settings (right column), same as Base Camp's
                                     own Makalu Settings page.
                                     IsChecked is set in code (InitMkSectionNav), not here: WPF fires
                                     Checked synchronously the moment BAML sets IsChecked="True", i.e.
                                     mid-way through InitializeComponent() — MkRgbSettings/MkDpiRemap
                                     (declared later in this file) aren't assigned yet at that point,
                                     so MkSection_Changed would null-ref. Root-caused via WinDbg+SOS,
                                     see CHANGELOG.md 2026-07-10. -->
                                    <RadioButton x:Name="RbMkSecRemap"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_key_binding}" GroupName="MkSections"
                                             Checked="MkSection_Changed"/>
                                    <RadioButton x:Name="RbMkSecRgb"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get rgb_lighting}" GroupName="MkSections"
                                             Checked="MkSection_Changed"/>
                                    <RadioButton x:Name="RbMkSecSettings"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get makalu_settings_title}" GroupName="MkSections"
                                             Checked="MkSection_Changed"/>
                                </StackPanel>
                            </Border>

                            <!-- CENTER: interactive device image (top, fixed height) + selected section content (bottom, grows) -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <!-- Fixed height across all devices, matching MacroPad's box height
                                     when rotated to vertical orientation (Positioning section,
                                     90°/270°): the canvas is 510x370, but RotateTransform swaps its
                                     rendered footprint to 370x510, so 510 + 8px padding each side = 526
                                     is the tallest a device box needs to be — comfortably fits the
                                     mouse image's 422px height too. -->
                                    <RowDefinition Height="526"/>
                                    <!-- device -->
                                    <RowDefinition Height="*"/>
                                    <!-- section content: grows with window height -->
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#18181C" CornerRadius="6" Padding="8">
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- LED ring preview host — BEHIND the Image on purpose: the ring
                                         area in makalu_mouse.png is a genuinely TRANSPARENT cutout (not
                                         painted pixels, confirmed 2026-07-12), so the colored ring is
                                         rendered underneath and shows through the gap, same as how the
                                         real backlit ring/Base Camp's own overlay works. See
                                         BuildMkLedRing in MainWindow.Makalu.cs. Only relevant while the
                                         Lighting section is active — ImgMkMouse switches back to the
                                         opaque makalu_mouse_rainbow.png (no cutout) for every other
                                         section, see MkSection_Changed/MkUpdateMouseImage. -->
                                        <Canvas x:Name="CvsMkRingBack" Width="190" Height="422"/>
                                        <Image x:Name="ImgMkMouse" Source="Assets/makalu_mouse.png" Width="190" Stretch="Uniform"/>
                                        <!-- Hotspots positioned in BuildMkHotspots (Canvas coords match
                                         the Image's rendered 190×422 size at Stretch=Uniform). -->
                                        <Canvas x:Name="CvsMkHotspots" Width="190" Height="422"/>
                                    </Grid>
                                </Border>

                                <!-- Bottom section panel: grows with the window (Row="*" above); MinHeight
                                 keeps its old fixed size as a floor so it doesn't collapse below the
                                 tallest section (RGB / DPI / Remap / Settings). Both controls are
                                 ALWAYS present (siblings in the same cell); each toggles its own
                                 SecXxx children's Visibility, so only the active section is ever painted. -->
                                <Border Grid.Row="1" Background="#14141A"
                                    BorderBrush="#2A2A32" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,8,0,0"
                                    MinHeight="180">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <Grid>
                                            <local:MakaluRgbSettingsPanel x:Name="MkRgbSettings"/>
                                            <local:MakaluDpiRemapPanel x:Name="MkDpiRemap"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Grid>

                            <!-- RIGHT: generic settings — Profile/Import/Export now backed by
                             MakaluStore (see MainWindow.Makalu.cs), same pattern as Everest Max's
                             LstEvProfile block. Device rename via AppSettings unchanged. -->
                            <Border Grid.Column="2" Background="#111115" CornerRadius="6"
                                Margin="8,0,0,0" Padding="10" VerticalAlignment="Top">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{loc:Get profile}"
                                               Style="{StaticResource K2SideGroupHeader}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" x:Name="BtnMkProfileMenu"
                                            Style="{StaticResource MacroRowIconButton}" Tag="&#xE712;"
                                            ToolTip="{loc:Get profile}" Click="BtnMkProfileMenu_Click"/>
                                    </Grid>
                                    <ListBox x:Name="LstMkProfile" Style="{StaticResource K2SideProfileList}"
                                         SelectionChanged="LstMkProfile_SelectionChanged"/>

                                    <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                    <TextBlock Text="{loc:Get device}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <Button x:Name="BtnMkRename" Content="{loc:Get rename_device}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8AC;"
                                        Click="BtnMkRename_Click"/>
                                    <Button x:Name="BtnMkRestoreDefaults" Content="{loc:Get restore_defaults}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE777;"
                                        Click="BtnMkRestoreDefaults_Click"/>

                                    <!-- Debug group: same position/pattern as PnlEvDebugGroup/PnlMpDebugGroup/
                                     PnlDpDebugGroup (right after Device, toggled by ApplyMkDebugMode).
                                     Connected status + manual Refresh moved here from the toolbar above —
                                     the 3s poll (MkRefreshStatus) keeps updating LblMkStatus regardless
                                     of whether this group is visible. -->
                                    <StackPanel x:Name="PnlMkDebugGroup" Visibility="Collapsed">
                                        <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                        <TextBlock Text="{loc:Get debug_group}" Style="{StaticResource K2SideGroupHeader}"/>
                                        <TextBlock x:Name="LblMkStatus" Text="{loc:Get makalu_status_disconnected}"
                                               FontWeight="Bold" Margin="0,0,0,6"/>
                                        <Button x:Name="BtnMkRefresh" Content="{loc:Get makalu_refresh}"
                                            Style="{StaticResource K2SideActionButton}" Tag="&#xE72C;"
                                            Click="BtnMkRefresh_Click"/>
                                    </StackPanel>

                                    <!-- Log: debug only, same gating as GbEvLog (Everest) — toggled by
                                     ApplyMkDebugMode, see MainWindow.Makalu.cs. -->
                                    <StackPanel x:Name="PnlMkLog" Visibility="Collapsed">
                                        <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                        <TextBlock Text="{loc:Get makalu_log}" Style="{StaticResource K2SideGroupHeader}"/>
                                        <Border Background="#0F0F13" BorderBrush="#2A2A32" BorderThickness="1"
                                            CornerRadius="6" Padding="6" Height="110">
                                            <TextBox x:Name="TxtMkLog" IsReadOnly="True" FontFamily="Consolas" FontSize="10"
                                                 VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                                                 Background="Transparent" BorderThickness="0"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
                <!-- end PnlMakalu -->

                <!-- ==================== MacroPad ==================== -->
                <Grid x:Name="PnlMacroPad" Visibility="Collapsed">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <!-- toolbar (fixed, see PnlEverest) -->
                            <RowDefinition Height="*"/>
                            <!-- main area -->
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <!-- Debug-only: open/close driver manually -->
                            <Button x:Name="BtnOpen"    Content="{loc:Get open_driver}"     Click="BtnOpen_Click"
                                Style="{StaticResource K2IconAccentButton}" Tag="&#xE768;" Visibility="Collapsed"/>
                            <Button x:Name="BtnClose"   Content="{loc:Get close_driver}"    Margin="8,0,0,0" Click="BtnClose_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE711;" Visibility="Collapsed"/>
                            <!-- Debug-only: AP controls -->
                            <Button x:Name="BtnApOn"   Content="AP Enable ON"  Padding="10,4" Visibility="Collapsed" Click="BtnApOn_Click"/>
                            <Button x:Name="BtnApOff"  Content="AP Enable OFF" Padding="10,4" Margin="6,0,0,0" Visibility="Collapsed" Click="BtnApOff_Click"/>
                            <Separator x:Name="SepMpApDbg" Margin="10,0" Visibility="Collapsed"/>
                            <!-- Debug-only: remap keys (see project rule) -->
                            <Button x:Name="BtnMapKeys" Content="{loc:Get remap_keys}" Click="BtnMapKeys_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE765;" Visibility="Collapsed"/>
                            <TextBlock x:Name="LblSdk" Margin="16,6,0,0" FontStyle="Italic" Foreground="#9A9AA2" Visibility="Collapsed"/>
                        </WrapPanel>

                        <!-- ── sidebar (specific) | canvas + settings | common actions | debug ── -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <!-- sidebar -->
                                <ColumnDefinition Width="*"/>
                                <!-- canvas + settings -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- common actions (all devices) -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- debug -->
                            </Grid.ColumnDefinitions>

                            <!-- Left sidebar: device-specific section navigation -->
                            <Border Grid.Column="0" Background="#111115" CornerRadius="6"
                                Margin="0,0,8,0" Padding="4">
                                <StackPanel>
                                    <TextBlock Text="SECTIONS" FontSize="9" Foreground="#4A4A58"
                                           Margin="14,8,0,6" FontWeight="Bold"/>
                                    <RadioButton x:Name="RbMpSecKeyBinding"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_key_binding}" GroupName="MpSections"
                                             IsChecked="True" Checked="MpSection_Changed"/>
                                    <RadioButton x:Name="RbMpSecLed"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get rgb_lighting}" GroupName="MpSections"
                                             Checked="MpSection_Changed"/>
                                    <RadioButton x:Name="RbMpSecSettings"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_settings}" GroupName="MpSections"
                                             Checked="MpSection_Changed"/>
                                </StackPanel>
                            </Border>

                            <!-- Middle: keys canvas (top) + settings panel (bottom).
                             No margin here (matches PnlEverest): the gap before the
                             common-actions column comes from that column's own left
                             margin, so this box is exactly as wide as Everest's. -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <!-- Fixed height across all devices: matches this canvas (510x370)
                                     rotated to vertical orientation (Positioning section, 90°/270°) —
                                     RotateTransform swaps its rendered footprint to 370x510, so
                                     510 + 8px padding each side = 526 is the tallest this box (and
                                     therefore every device's box) needs to be. -->
                                    <RowDefinition Height="526"/>
                                    <!-- device -->
                                    <RowDefinition Height="*"/>
                                    <!-- settings: grows with window height -->
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#18181C" CornerRadius="6" Padding="8">
                                    <Canvas x:Name="CvsMacroKeys" Width="510" Height="370" ClipToBounds="True"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas.Background>
                                            <ImageBrush ImageSource="Assets/mkd_bg.png" Stretch="Fill"/>
                                        </Canvas.Background>
                                    </Canvas>
                                </Border>

                                <!-- Bottom settings panel: grows with the window (Row="*" above); MinHeight
                                 keeps its old fixed size as a floor so it doesn't collapse below the
                                 tallest section (Key Binding / Orientation / LED Lighting). NOTE: no
                                 outer ScrollViewer anymore — see the matching comment on
                                 BdrEvSettingsPanel (Everest Max) for why; each section here now owns
                                 its own overflow behavior instead (Key Binding's Grid+ListView stretch
                                 for real; Orientation/LED Lighting/Settings each got their own
                                 ScrollViewer). -->
                                <Border x:Name="BdrMpSettingsPanel" Grid.Row="1" Background="#14141A"
                                    BorderBrush="#2A2A32" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,8,0,0"
                                    MinHeight="130">
                                    <Grid>

                                        <!-- ── KEY BINDING (keys are configured directly on the grid above;
                                         this list mirrors what's mapped, same list+column layout as
                                         Everest Max's Key Binding section — LvMpKeys only lists keys
                                         that HAVE an action, unlike the always-12 grid above). A Grid
                                         (not StackPanel) with an explicit Auto/* row split: StackPanel
                                         always sizes children to their natural height regardless of
                                         available space, so it can never stretch LvMpKeys to fill. ── -->
                                        <Grid x:Name="PnlMpSecKeyBinding" Visibility="Collapsed">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <!-- hint text -->
                                                <RowDefinition Height="*"/>
                                                <!-- list + buttons: fills remaining height -->
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{loc:Get key_binding_hint}" Foreground="#9A9AA2"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="170"/>
                                                </Grid.ColumnDefinitions>
                                                <ListView Grid.Column="0" x:Name="LvMpKeys" Margin="0,0,8,0"
                                                      SelectionChanged="LvMpKeys_SelectionChanged">
                                                    <ListView.ItemContainerStyle>
                                                        <Style TargetType="ListViewItem">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                    <Setter Property="Background" Value="#900000"/>
                                                                    <Setter Property="Foreground" Value="#10302F"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListView.ItemContainerStyle>
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Display}" FontFamily="Consolas" Padding="2"/>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                                    <Button x:Name="BtnMpConfigure" Content="{loc:Get ev_configure}"
                                                        Padding="8,4" Click="BtnMpConfigure_Click"
                                                        HorizontalAlignment="Stretch" Margin="0,0,0,4"
                                                        IsEnabled="False"/>
                                                    <Button x:Name="BtnMpRemoveAction" Content="{loc:Get ev_remove}"
                                                        Padding="8,4" Click="BtnMpRemoveAction_Click"
                                                        IsEnabled="False"
                                                        HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                        <!-- ── LED LIGHTING ── (own ScrollViewer) -->
                                        <ScrollViewer x:Name="PnlMpSecLed"
                                                  VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                                            <StackPanel>
                                                <!-- Preset effects row 1 (same grouping/order as Everest Max's
                                             PnlSecRgb: effect, speed, direction, rainbow, sync — see
                                             MainWindow.xaml PnlSecRgb) -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Height="27" Margin="0,0,0,15">
                                                        <TextBlock Text="{loc:Get rgb_effect}" VerticalAlignment="Center"/>
                                                        <ComboBox x:Name="CbMacroEffect" Width="140" Margin="26,0,12,0"
                                                      SelectionChanged="CbMacroEffect_SelectionChanged"
                                                      DropDownOpened="CbMacroEffect_DropDownOpened"
                                                      DropDownClosed="CbMacroEffect_DropDownClosed" Height="25"/>
                                                        <StackPanel x:Name="PnlMpSpeed" Orientation="Horizontal" >
                                                            <TextBlock Text="{loc:Get rgb_speed}" VerticalAlignment="Center" />
                                                            <Slider x:Name="SldMacroSpeed" Minimum="0" Maximum="100" Width="110"
                                                        TickFrequency="25" IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                                                        ValueChanged="SldMacroSpeed_ValueChanged" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                            <TextBlock x:Name="LblMacroSpeed" Text="50%" VerticalAlignment="Center"  MinWidth="36" Margin="10,0,0,0"/>
                                                        </StackPanel>




                                                        <TextBlock Text="{loc:Get led_backlight_label}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <CheckBox x:Name="CkMacroBacklight" Style="{StaticResource K2InlineSwitch}"
                                                            VerticalAlignment="Center" IsChecked="True" Click="CkMacroBacklight_Click"/>


                                                    </StackPanel>

                                                    <CheckBox Grid.Column="1"  x:Name="CkMacroSync" Content="{loc:Get led_sync_profiles}" Click="CkMacroSync_Click" Width="159" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                                </Grid>


                                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <StackPanel x:Name="PnlMpDirection" Orientation="Horizontal" Margin="0,0,12,0">
                                                        <TextBlock Text="{loc:Get rgb_direction}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <Border Style="{StaticResource K2SegmentedGroupBorder}">
                                                            <UniformGrid x:Name="GridMacroDirection" Rows="1"/>
                                                        </Border>
                                                    </StackPanel>
                                                </WrapPanel>
                                                <!-- Preset effects row 2: color mode (Single/Double/Rainbow, one
                                             mutually-exclusive vertical radio group) + swatches + on/off. -->
                                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <StackPanel Orientation="Vertical" Margin="0,0,20,0" VerticalAlignment="Center">
                                                        <RadioButton x:Name="RbMacroColorSingle" Content="{loc:Get rgb_single}" GroupName="MacroColorMode"
                                                            Margin="0,0,0,6" Checked="RbMacroColorMode_Checked" ToolTip="{loc:Get rgb_single_tip}"/>
                                                        <RadioButton x:Name="RbMacroColorDouble" Content="{loc:Get rgb_double}" GroupName="MacroColorMode"
                                                            Margin="0,0,0,6" Checked="RbMacroColorMode_Checked" ToolTip="{loc:Get rgb_double_tip}"/>
                                                        <RadioButton x:Name="RbMacroRainbow" Content="{loc:Get rgb_rainbow}" GroupName="MacroColorMode"
                                                            Checked="RbMacroColorMode_Checked" ToolTip="{loc:Get rgb_rainbow_tip}"/>
                                                    </StackPanel>
                                                    <StackPanel x:Name="PnlMacroColor1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                                                        <TextBlock Text="{loc:Get rgb_primary}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                        <Button x:Name="BtnMacroColor1" Width="30" Height="30"
                                                        Background="#900000" BorderThickness="2"
                                                        BorderBrush="#3A3A40" Click="BtnMacroColor_Click" Tag="1"/>
                                                    </StackPanel>
                                                    <StackPanel x:Name="PnlMacroColor2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{loc:Get rgb_secondary}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                        <Button x:Name="BtnMacroColor2" Width="30" Height="30"
                                                        Background="#1A1A1E" BorderThickness="2"
                                                        BorderBrush="#3A3A40" Click="BtnMacroColor_Click" Tag="2"/>
                                                    </StackPanel>
                                                </WrapPanel>
                                                <!-- Backlight auto-off — moved here from Settings (user request
 2026-07-21), sized like the rest of this panel. -->
                                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <CheckBox x:Name="CkMacroAutoOffEnable" Content="{loc:Get backlight_auto_off_enable}"
      Click="CkMacroAutoOffEnable_Click" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                                    <TextBlock Text="{loc:Get backlight_auto_off_seconds}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="TxtMacroAutoOffSeconds" Width="70" TextAlignment="Center"
     LostFocus="TxtMacroAutoOffSeconds_LostFocus" Text="5" VerticalAlignment="Center" Height="25" Padding="3,2,3,0"/>
                                                    <TextBlock Text="{loc:Get unit_seconds}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <!-- ── SETTINGS (keycap appearance, same as Everest) ── (own ScrollViewer) -->
                                        <ScrollViewer x:Name="PnlMpSecSettings" Visibility="Collapsed"
                                                  VerticalScrollBarVisibility="Auto">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{loc:Get settings_keycap_group}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <TextBlock Text="{loc:Get settings_keycap_color}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <RadioButton x:Name="RbMpKeycapBlack" Content="{loc:Get settings_keycap_black}"
                                                             GroupName="MpKeycapColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbMpKeycapColor_Checked"/>
                                                        <RadioButton x:Name="RbMpKeycapWhite" Content="{loc:Get settings_keycap_white}"
                                                             GroupName="MpKeycapColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbMpKeycapColor_Checked"/>
                                                        <RadioButton x:Name="RbMpKeycapCustom" Content="{loc:Get settings_keycap_custom}"
                                                             GroupName="MpKeycapColor" VerticalAlignment="Center"
                                                             Margin="0,0,6,0" Checked="RbMpKeycapColor_Checked"/>
                                                        <Button x:Name="BtnMpKeycapCustomColor" Width="30" Height="30"
                                                        Background="#404040" BorderThickness="2" BorderBrush="#3A3A40"
                                                        Click="BtnMpKeycapCustomColor_Click"/>
                                                    </WrapPanel>
                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="{loc:Get settings_keycap_text_color}" VerticalAlignment="Center" Margin="0,0,6,0" Padding="0,0,18,0"/>
                                                        <RadioButton x:Name="RbMpKeycapTextBlack" Content="{loc:Get settings_keycap_black}"
                                                             GroupName="MpKeycapTextColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbMpKeycapTextColor_Checked"/>
                                                        <RadioButton x:Name="RbMpKeycapTextWhite" Content="{loc:Get settings_keycap_white}"
                                                             GroupName="MpKeycapTextColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbMpKeycapTextColor_Checked"/>
                                                        <RadioButton x:Name="RbMpKeycapTextCustom" Content="{loc:Get settings_keycap_custom}"
                                                             GroupName="MpKeycapTextColor" VerticalAlignment="Center"
                                                             Margin="0,0,6,0" Checked="RbMpKeycapTextColor_Checked"/>
                                                        <Button x:Name="BtnMpKeycapTextColor" Width="30" Height="30"
                                                        Background="White" BorderThickness="2" BorderBrush="#3A3A40"
                                                        Click="BtnMpKeycapTextColor_Click"/>
                                                    </WrapPanel>
                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="{loc:Get settings_keycap_style}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <ComboBox x:Name="CbMpKeycapStyle" Width="240"
                                                          SelectionChanged="CbMpKeycapStyle_SelectionChanged" Margin="4,0,0,0"/>
                                                    </WrapPanel>
                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <CheckBox x:Name="CkMpKeycapTranslucentLegend" Content="{loc:Get settings_keycap_translucent_legend}"
                                                          Click="CkMpKeycapTranslucentLegend_Click"/>
                                                    </WrapPanel>

                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                        <CheckBox x:Name="CkMpKeycapEditMode" Content="{loc:Get settings_keycap_edit_individual}"
                                                          Click="CkMpKeycapEditMode_Click" Margin="0,5,0,0"/>
                                                    </WrapPanel>
                                                    <TextBlock Text="{loc:Get settings_keycap_edit_individual_hint}" Foreground="#9A9AA2"
                                                           TextWrapping="Wrap" Margin="0,3,0,10" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{loc:Get positioning}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <WrapPanel Orientation="Horizontal">
                                                        <ComboBox x:Name="CbMacroRotation" Width="190"
                                                          SelectionChanged="CbMacroRotation_SelectionChanged"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Grid>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Common actions (same rule for all devices): uniform width/height,
                             vertical stack, grouped Profile / Import / Device.
                             Left-only margin (not on the device box) mirrors PnlEverest exactly,
                             so column 1 keeps the same width in both. The gap before the (normally
                             collapsed) debug column lives on that column's own left margin instead,
                             so it doesn't cost width here in the common (non-debug) case. -->
                            <Border Grid.Column="2" Background="#111115" CornerRadius="6"
                                Margin="8,0,0,0" Padding="10" VerticalAlignment="Top">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{loc:Get profile}"
                                               Style="{StaticResource K2SideGroupHeader}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" x:Name="BtnMpProfileMenu"
                                            Style="{StaticResource MacroRowIconButton}" Tag="&#xE712;"
                                            ToolTip="{loc:Get profile}" Click="BtnMpProfileMenu_Click"/>
                                    </Grid>
                                    <ListBox x:Name="LstMpProfile" Style="{StaticResource K2SideProfileList}"
                                         SelectionChanged="LstMpProfile_SelectionChanged"/>

                                    <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                    <TextBlock Text="{loc:Get device}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <Button x:Name="BtnMpRename" Content="{loc:Get rename_device}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8D3;"
                                        Click="BtnMpRename_Click"/>
                                    <Button x:Name="BtnMpRestoreDefaults" Content="{loc:Get restore_defaults}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE777;"
                                        Click="BtnMpRestoreDefaults_Click"/>

                                    <StackPanel x:Name="PnlMpDebugGroup" Visibility="Collapsed">
                                        <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                        <TextBlock Text="{loc:Get debug_group}" Style="{StaticResource K2SideGroupHeader}"/>
                                        <Button x:Name="BtnRefresh" Content="{loc:Get refresh}"
                                            Style="{StaticResource K2SideActionButton}" Tag="&#xE72C;"
                                            Click="BtnRefresh_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Debug panel: visible only in debug mode -->
                            <Grid x:Name="PnlMpDebugRight" Grid.Column="3" Width="380" Visibility="Collapsed" Margin="8,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <GroupBox x:Name="GbMpDevices" Grid.Row="0" Header="{loc:Get mp_connected_devices}">
                                    <ListView x:Name="LvDevices" Height="120">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Device"  Width="90"  DisplayMemberBinding="{Binding Label}"/>
                                                <GridViewColumn Header="{loc:Get dp_fw}"    Width="55"  DisplayMemberBinding="{Binding FirmwareVersion}"/>
                                                <GridViewColumn Header="VID"     Width="60"  DisplayMemberBinding="{Binding Vid}"/>
                                                <GridViewColumn Header="PID"     Width="60"  DisplayMemberBinding="{Binding Pid}"/>
                                                <GridViewColumn Header="Prof."   Width="45"  DisplayMemberBinding="{Binding CurrentProfile}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </GroupBox>
                                <GroupBox x:Name="GbMpLog" Grid.Row="1" Header="{loc:Get mp_event_log}" Margin="0,8,0,0">
                                    <TextBox x:Name="TxtLog"
                                         IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap" AcceptsReturn="True"/>
                                </GroupBox>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                <!-- end PnlMacroPad -->

                <!-- ==================== DisplayPad ==================== -->
                <Grid x:Name="PnlDisplayPad" Visibility="Collapsed">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <!-- toolbar (fixed, see PnlEverest) -->
                            <RowDefinition Height="*"/>
                            <!-- main area -->
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <!-- Debug-only: open/close driver manually -->
                            <Button x:Name="BtnDpOpen"    Content="{loc:Get open_driver}"    Click="BtnDpOpen_Click"
                                Style="{StaticResource K2IconAccentButton}" Tag="&#xE768;" Visibility="Collapsed"/>
                            <Button x:Name="BtnDpClose"   Content="{loc:Get close_driver}"   Margin="8,0,0,0" Click="BtnDpClose_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE711;" Visibility="Collapsed"/>
                            <Separator x:Name="SepDpOpenDbg" Margin="10,0" Visibility="Collapsed"/>
                            <!-- Folder navigation: interface-only, independent of any physical/software
                             key's "Back" action — always available to leave a sub-page even if the
                             user removes/never assigns a Back key inside it. Visible only when inside
                             a sub-page (toggled by UpdateDpBreadcrumb); accent-styled so it isn't missed. -->
                            <Button x:Name="BtnDpBack" Content="{loc:Get dp_back}"
                                Margin="0,0,0,0" Style="{StaticResource K2IconAccentButton}" Tag="&#xE72B;"
                                Click="BtnDpBack_Click" Visibility="Collapsed"/>
                            <TextBlock x:Name="LblDpBreadcrumb" Text="" VerticalAlignment="Center"
                                   Margin="6,0,0,0" Foreground="#9A9AA2" FontStyle="Italic"/>
                            <!-- Debug-only: remap/reset keys (see project rule) -->
                            <Separator x:Name="SepDpMapKeysDbg" Margin="10,0" Visibility="Collapsed"/>
                            <Button x:Name="BtnDpMapKeys"  Content="{loc:Get remap_keys}"    Click="BtnDpMapKeys_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE765;" Visibility="Collapsed"/>
                            <Button x:Name="BtnDpResetAll" Content="{loc:Get dp_reset_keys}" Margin="8,0,0,0" Click="BtnDpResetAll_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE777;" Visibility="Collapsed"/>
                            <TextBlock x:Name="LblDpSdk" Margin="16,6,0,0" FontStyle="Italic" Foreground="#9A9AA2" Visibility="Collapsed"/>
                        </WrapPanel>

                        <!-- ── sidebar (specific) | canvas + settings | common actions | debug ── -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <!-- sidebar -->
                                <ColumnDefinition Width="*"/>
                                <!-- canvas + settings -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- common actions (all devices) -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- debug -->
                            </Grid.ColumnDefinitions>

                            <!-- Left sidebar: device-specific section navigation -->
                            <Border Grid.Column="0" Background="#111115" CornerRadius="6"
                                Margin="0,0,8,0" Padding="4">
                                <StackPanel>
                                    <TextBlock Text="SECTIONS" FontSize="9" Foreground="#4A4A58"
                                           Margin="14,8,0,6" FontWeight="Bold"/>
                                    <RadioButton x:Name="RbDpSecKeyBinding"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_key_binding}" GroupName="DpSections"
                                             IsChecked="True" Checked="DpSection_Changed"/>
                                    <RadioButton x:Name="RbDpSecPages"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get dp_pages}" GroupName="DpSections"
                                             Checked="DpSection_Changed"/>
                                    <RadioButton x:Name="RbDpSecSettings"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_settings}" GroupName="DpSections"
                                             Checked="DpSection_Changed"/>
                                </StackPanel>
                            </Border>

                            <!-- Middle: keys canvas (top) + settings panel (bottom).
                             No margin here (matches PnlEverest): the gap before the
                             common-actions column comes from that column's own left
                             margin, so this box is exactly as wide as Everest's. -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <!-- Fixed height across all devices: matches MacroPad's identical
                                     510x370 canvas rotated to vertical orientation (Positioning
                                     section, 90°/270°) — RotateTransform swaps its rendered footprint
                                     to 370x510, so 510 + 8px padding each side = 526 is the tallest
                                     a device box needs to be. -->
                                    <RowDefinition Height="526"/>
                                    <!-- device -->
                                    <RowDefinition Height="*"/>
                                    <!-- settings: grows with window height -->
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#18181C" CornerRadius="6" Padding="8">
                                    <Canvas x:Name="CvsDpKeys" Width="510" Height="370" ClipToBounds="True"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas.Background>
                                            <ImageBrush ImageSource="Assets/mkd_bg.png" Stretch="Fill"/>
                                        </Canvas.Background>
                                    </Canvas>
                                </Border>

                                <!-- Bottom settings panel: grows with the window (Row="*" above); MinHeight
                                 keeps its old fixed size as a floor so it doesn't collapse below the
                                 tallest section (Key Binding / Rotation / Pages). NOTE: no outer
                                 ScrollViewer anymore — see the matching comment on BdrEvSettingsPanel
                                 (Everest Max)/BdrMpSettingsPanel (MacroPad) for why; each section now
                                 owns its own overflow behavior instead (Key Binding's Grid+ListView
                                 stretches for real, same disposition as every other device's Key
                                 Binding section except Makalu; Rotation/Pages each got their own
                                 ScrollViewer). -->
                                <Border Grid.Row="1" Background="#14141A"
                                    BorderBrush="#2A2A32" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,8,0,0"
                                    MinHeight="90">
                                    <Grid>

                                        <!-- ── KEY BINDING (keys are configured directly on the grid above;
                                         this list mirrors what's mapped, same list+column layout as
                                         Everest Max/MacroPad's Key Binding section — LvDpKeys only
                                         lists keys that HAVE an action, unlike the always-12 grid
                                         above). A Grid (not StackPanel) with an explicit Auto/* row
                                         split: StackPanel always sizes children to their natural
                                         height regardless of available space, so it can never stretch
                                         LvDpKeys to fill. ── -->
                                        <Grid x:Name="PnlDpSecKeyBinding" Visibility="Collapsed">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <!-- hint text -->
                                                <RowDefinition Height="*"/>
                                                <!-- list + buttons: fills remaining height -->
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{loc:Get key_binding_hint}" Foreground="#9A9AA2"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="170"/>
                                                </Grid.ColumnDefinitions>
                                                <ListView Grid.Column="0" x:Name="LvDpKeys" Margin="0,0,8,0"
                                                      SelectionChanged="LvDpKeys_SelectionChanged">
                                                    <ListView.ItemContainerStyle>
                                                        <Style TargetType="ListViewItem">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                    <Setter Property="Background" Value="#900000"/>
                                                                    <Setter Property="Foreground" Value="#10302F"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListView.ItemContainerStyle>
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ListDisplay}" FontFamily="Consolas" Padding="2"/>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                                    <Button x:Name="BtnDpConfigure" Content="{loc:Get ev_configure}"
                                                        Padding="8,4" Click="BtnDpConfigure_Click"
                                                        HorizontalAlignment="Stretch" Margin="0,0,0,4"
                                                        IsEnabled="False"/>
                                                    <Button x:Name="BtnDpRemoveAction" Content="{loc:Get ev_remove}"
                                                        Padding="8,4" Click="BtnDpRemoveAction_Click"
                                                        HorizontalAlignment="Stretch"
                                                        IsEnabled="False"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                        <!-- ── SETTINGS (positioning/rotation — DisplayPad's only device
                                         setting so far) ── (own ScrollViewer, same reasoning as
                                         MacroPad's Settings) -->
                                        <ScrollViewer x:Name="PnlDpSecSettings" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="{loc:Get positioning}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <ComboBox x:Name="CbDpRotation" Width="190" Margin="0,0,12,0"
                                                      SelectionChanged="CbDpRotation_SelectionChanged"/>
                                                    <Button x:Name="BtnDpRotateCcw" Content="{loc:Get dp_rotate_icons_ccw}" Margin="0,0,6,0"
                                                    Style="{StaticResource K2IconButton}" Tag="&#xE14A;" Height="30"
                                                    Click="BtnDpRotateCcw_Click"/>
                                                    <Button x:Name="BtnDpRotateCw"  Content="{loc:Get dp_rotate_icons_cw}"
                                                    Style="{StaticResource K2IconButton}" Tag="&#xE14A;" Height="30"
                                                    Click="BtnDpRotateCw_Click"/>
                                                </StackPanel>

                                                <TextBlock Text="{loc:Get backlight_auto_off_group}" FontWeight="SemiBold" Margin="0,14,0,6"/>
                                                <WrapPanel Orientation="Horizontal">
                                                    <CheckBox x:Name="CkDpAutoOffEnable" Height="25" Content="{loc:Get backlight_auto_off_enable}"
                                                      Click="CkDpAutoOffEnable_Click" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                                    <TextBlock Text="{loc:Get backlight_auto_off_seconds}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="TxtDpAutoOffSeconds" Width="70" TextAlignment="Center"
                                                     LostFocus="TxtDpAutoOffSeconds_LostFocus" Height="25" Text="5" VerticalAlignment="Center" Padding="5,2,5,0"/>
                                                    <TextBlock Text="{loc:Get unit_seconds}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <!-- ── PAGES (folder sub-pages created for this device+profile) ── (own ScrollViewer) -->
                                        <ScrollViewer x:Name="PnlDpSecPages" Visibility="Collapsed"
                                                  VerticalScrollBarVisibility="Auto">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock x:Name="LblDpNoPages" Text="{loc:Get dp_no_pages}"
                                                   Foreground="#9A9AA2" TextWrapping="Wrap" Visibility="Collapsed"/>
                                                <ItemsControl x:Name="LstDpPages">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Vertical"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border x:Name="RowBorder" Padding="6,3" CornerRadius="4"
                                                            Background="Transparent">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                                       Foreground="#CCCCCC" VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                                    <Button x:Name="BtnRowDelete" Grid.Column="1"
                                                                    Content="{loc:Get dp_delete_page}"
                                                                    Style="{StaticResource K2IconButton}" Tag="&#xE74D;"
                                                                    Visibility="Collapsed" Margin="8,0,0,0"
                                                                    CommandParameter="{Binding PageId}"
                                                                    Click="BtnDpDeletePage_Click"/>
                                                                </Grid>
                                                            </Border>
                                                            <DataTemplate.Triggers>
                                                                <Trigger SourceName="RowBorder" Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="BtnRowDelete" Property="Visibility" Value="Visible"/>
                                                                    <Setter TargetName="RowBorder" Property="Background" Value="#1E1E24"/>
                                                                </Trigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Common actions (same rule for all devices): uniform width/height,
                             vertical stack, grouped Profile / Import / Device.
                             Left-only margin (not on the device box) mirrors PnlEverest exactly,
                             so column 1 keeps the same width in both. The gap before the (normally
                             collapsed) debug column lives on that column's own left margin instead,
                             so it doesn't cost width here in the common (non-debug) case. -->
                            <Border Grid.Column="2" Background="#111115" CornerRadius="6"
                                Margin="8,0,0,0" Padding="10" VerticalAlignment="Top">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{loc:Get profile}"
                                               Style="{StaticResource K2SideGroupHeader}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" x:Name="BtnDpProfileMenu"
                                            Style="{StaticResource MacroRowIconButton}" Tag="&#xE712;"
                                            ToolTip="{loc:Get profile}" Click="BtnDpProfileMenu_Click"/>
                                    </Grid>
                                    <ListBox x:Name="LstDpProfile" Style="{StaticResource K2SideProfileList}"
                                         SelectionChanged="LstDpProfile_SelectionChanged"/>

                                    <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                    <TextBlock Text="{loc:Get dp_fullscreen_group}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <Button x:Name="BtnDpFullscreen" Content="{loc:Get dp_fullscreen_set}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE91B;"
                                        Click="BtnDpFullscreen_Click"/>
                                    <Button x:Name="BtnDpFullscreenClear" Content="{loc:Get dp_fullscreen_clear}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE74D;"
                                        Click="BtnDpFullscreenClear_Click"/>

                                    <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                    <TextBlock Text="{loc:Get device}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <Button x:Name="BtnDpRename" Content="{loc:Get rename_device}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8D3;"
                                        Click="BtnDpRename_Click"/>
                                    <Button x:Name="BtnDpRestoreDefaults" Content="{loc:Get restore_defaults}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE777;"
                                        Click="BtnDpRestoreDefaults_Click"/>

                                    <StackPanel x:Name="PnlDpDebugGroup" Visibility="Collapsed">
                                        <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                        <TextBlock Text="{loc:Get debug_group}" Style="{StaticResource K2SideGroupHeader}"/>
                                        <Button x:Name="BtnDpRefresh" Content="{loc:Get refresh}"
                                            Style="{StaticResource K2SideActionButton}" Tag="&#xE72C;"
                                            Click="BtnDpRefresh_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Debug panel: visible only in debug mode -->
                            <Grid x:Name="PnlDpDebugRight" Grid.Column="3" Width="380" Visibility="Collapsed" Margin="8,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <GroupBox x:Name="GbDpDevices" Grid.Row="0" Header="{loc:Get dp_connected_devices}">
                                    <ListView x:Name="LvDpDevices" Height="120">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Device"         Width="100" DisplayMemberBinding="{Binding Label}"/>
                                                <GridViewColumn Header="{loc:Get dp_fw}" Width="80"  DisplayMemberBinding="{Binding FirmwareVersion}"/>
                                                <GridViewColumn Header="{loc:Get dp_lum}" Width="60" DisplayMemberBinding="{Binding Brightness}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </GroupBox>
                                <GroupBox x:Name="GbDpLog" Grid.Row="1" Header="{loc:Get dp_log}" Margin="0,8,0,0">
                                    <TextBox x:Name="TxtDpLog"
                                         IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap" AcceptsReturn="True"/>
                                </GroupBox>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                <!-- end PnlDisplayPad -->

                <!-- ==================== Macro (top-level section) ==================== -->
                <Grid x:Name="PnlMacro" Visibility="Collapsed">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{loc:Get keyboard_macro}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Macro library (always visible) — same look as the device
                             "SECTIONS" sidebar: dark rounded card, accent-highlighted
                             selection, stretching to fill the column's full height.
                             New/Delete above the card, Import below it. -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{loc:Get macro_library}" Style="{StaticResource K2SideGroupHeader}"/>
                                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button x:Name="BtnMacroNew"       Content="{loc:Get macro_new}"       Padding="8,2" Margin="0,0,4,0" Click="BtnMacroNew_Click"       Style="{StaticResource K2IconButton}" Tag="&#xE710;"/>
                                    <Button x:Name="BtnMacroDuplicate" Content="{loc:Get macro_duplicate}" Padding="8,2" Margin="0,0,4,0" Click="BtnMacroDuplicate_Click" Style="{StaticResource K2IconButton}" Tag="&#xE8C8;"/>
                                    <Button x:Name="BtnMacroDelete"    Content="{loc:Get delete}"          Padding="8,2" Click="BtnMacroDelete_Click"    Style="{StaticResource K2IconButton}" Tag="&#xE74D;"/>
                                </WrapPanel>
                                <Border Grid.Row="2" Background="#111115" CornerRadius="6" Padding="4">
                                    <ListBox x:Name="LbMacros"
                                         Background="Transparent" BorderThickness="0"
                                         ItemContainerStyle="{StaticResource MacroLibraryItemStyle}"
                                         SelectionChanged="LbMacros_SelectionChanged"
                                         DisplayMemberPath="Name">
                                        <!-- Bare-bones template (no default WPF/Fluent chrome): the
                                         stock ListBox template has its own "disabled" visual state
                                         that paints a system-light/white background regardless of
                                         the Background set above, and its fixed-size chrome doesn't
                                         stretch to fill a "*" row the way this bare ScrollViewer
                                         does. Same technique as LvMacroInputs below. -->
                                        <ListBox.Template>
                                            <ControlTemplate TargetType="ListBox">
                                                <ScrollViewer Background="Transparent" Padding="2"
                                                          CanContentScroll="False">
                                                    <ItemsPresenter/>
                                                </ScrollViewer>
                                            </ControlTemplate>
                                        </ListBox.Template>
                                    </ListBox>
                                </Border>
                                <Button Grid.Row="3" x:Name="BtnMacroImportBC" Content="{loc:Get macro_import_bc}"
                                    Padding="8,2" Margin="0,6,0,0" Click="BtnMacroImportBC_Click"
                                    Style="{StaticResource K2IconButton}" Tag="&#xE8B5;"
                                    HorizontalAlignment="Left"/>
                            </Grid>

                            <!-- Selected macro editor -->
                            <Grid x:Name="SpMacroSettings" Grid.Column="2" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="{loc:Get macro_name}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="TxtMacroName" Width="220"
                                         Background="#2A2A2E" Foreground="White"
                                         TextChanged="TxtMacroName_TextChanged"/>
                                </WrapPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="190"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Settings column: Devices / Delay / Playback, stacked -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Get macro_section_devices}" Style="{StaticResource K2SideGroupHeader}"/>
                                        <CheckBox x:Name="CkMacroMouse" Content="{loc:Get macro_record_mouse}"
                                              Margin="0,0,0,6" Click="CkMacroDevice_Click"/>
                                        <CheckBox x:Name="CkMacroMouseMovement" Content="{loc:Get macro_record_mouse_movement}"
                                              Margin="20,0,0,6" FontSize="12" Click="CkMacroDevice_Click"/>
                                        <CheckBox x:Name="CkMacroKeyboard" Content="{loc:Get macro_record_keyboard}"
                                              Margin="0,0,0,18" Click="CkMacroDevice_Click"/>

                                        <TextBlock Text="{loc:Get macro_delay}" Style="{StaticResource K2SideGroupHeader}"/>
                                        <RadioButton x:Name="RbMacroDelayRecorded" GroupName="MacroDelayGroup"
                                                 Content="{loc:Get macro_delay_recorded}"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroDelay_Checked"/>
                                        <RadioButton x:Name="RbMacroDelayCustom" GroupName="MacroDelayGroup"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroDelay_Checked">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{loc:Get macro_delay_custom}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="TxtMacroCustomDelay" Width="66" Margin="8,0,4,0"
                                                     Padding="5,2" Background="#2A2A2E" Foreground="White"
                                                     TextChanged="TxtMacroCustomDelay_TextChanged"/>
                                                <TextBlock Text="ms" VerticalAlignment="Center" Opacity="0.7"/>
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="RbMacroDelayNone" GroupName="MacroDelayGroup"
                                                 Content="{loc:Get macro_delay_none}" Margin="0,0,0,18"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroDelay_Checked"/>

                                        <TextBlock Text="{loc:Get macro_playback}" Style="{StaticResource K2SideGroupHeader}"/>
                                        <RadioButton x:Name="RbMacroPlaybackOnce" GroupName="MacroPlaybackGroup"
                                                 Content="{loc:Get macro_playback_once}"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroPlayback_Checked"/>
                                        <RadioButton x:Name="RbMacroPlaybackHold" GroupName="MacroPlaybackGroup"
                                                 Content="{loc:Get macro_playback_held}"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroPlayback_Checked"/>
                                        <RadioButton x:Name="RbMacroPlaybackRepeat" GroupName="MacroPlaybackGroup"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroPlayback_Checked">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{loc:Get macro_repeat_short}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="TxtMacroRepeatN" Width="66" Margin="8,0,4,0"
                                                     Padding="5,2" Background="#2A2A2E" Foreground="White"
                                                     TextChanged="TxtMacroRepeatN_TextChanged"/>
                                                <TextBlock Text="{loc:Get macro_times_suffix}" VerticalAlignment="Center" Opacity="0.7"/>
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="RbMacroPlaybackToggle" GroupName="MacroPlaybackGroup"
                                                 Content="{loc:Get macro_playback_toggle}"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroPlayback_Checked"/>
                                    </StackPanel>

                                    <!-- Inputs / commands -->
                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{loc:Get macro_section_inputs}"
                                                   Style="{StaticResource K2SideGroupHeader}" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="1" x:Name="CkMacroShowPressRelease"
                                                  Content="{loc:Get macro_show_press_release}"
                                                  Tag="&#xE7C8;" Style="{StaticResource K2ToggleRow}"
                                                  Click="CkMacroShowPressRelease_Click"/>
                                        </Grid>

                                        <Border Grid.Row="1" Background="#18181C" BorderBrush="{StaticResource K2BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" MinHeight="260">
                                            <ListView x:Name="LvMacroInputs" Background="Transparent" BorderThickness="0"
                                                  ScrollViewer.CanContentScroll="False">
                                                <ListView.Template>
                                                    <ControlTemplate TargetType="ListView">
                                                        <ScrollViewer Background="Transparent" Padding="4">
                                                            <ItemsPresenter/>
                                                        </ScrollViewer>
                                                    </ControlTemplate>
                                                </ListView.Template>
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Focusable" Value="False"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListViewItem">
                                                                    <ContentPresenter/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#232328" CornerRadius="6" Margin="4,3" Padding="10,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="24"/>
                                                                    <ColumnDefinition Width="16"/>
                                                                    <ColumnDefinition Width="22"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Number}"
                                                                       Foreground="#68686E" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Style="{StaticResource MacroPressIndicatorStyle}"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding Glyph}"
                                                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                       Foreground="#9A9AA2" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding Label}"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                                <TextBlock Grid.Column="4" Text="{Binding DelayMs, StringFormat={}{0} ms}"
                                                                       Foreground="#68686E" FontSize="11"
                                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                                <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="10,0,0,0">
                                                                    <Button Tag="&#xE70E;" CommandParameter="{Binding}" Click="BtnMacroInputMoveUp_Click"
                                                                        Style="{StaticResource MacroRowIconButton}" ToolTip="{loc:Get macro_move_up}"/>
                                                                    <Button Tag="&#xE70D;" CommandParameter="{Binding}" Click="BtnMacroInputMoveDown_Click"
                                                                        Style="{StaticResource MacroRowIconButton}" ToolTip="{loc:Get macro_move_down}"/>
                                                                    <Button Tag="&#xE74D;" CommandParameter="{Binding}" Click="BtnMacroInputDelete_Click"
                                                                        Style="{StaticResource MacroRowIconButton}" ToolTip="{loc:Get macro_delete_input}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Border>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button x:Name="BtnMacroRecord" Content="{loc:Get macro_start_recording}"
                                                Padding="12,6" Margin="0,0,8,0" Click="BtnMacroRecord_Click"
                                                Style="{StaticResource K2IconAccentButton}" Tag="&#xE7C8;"/>
                                            <Button x:Name="BtnMacroPlay" Content="{loc:Get macro_play}"
                                                Padding="10,6" Margin="0,0,8,0" Click="BtnMacroPlay_Click"
                                                Style="{StaticResource K2IconButton}" Tag="&#xE768;"/>
                                            <Button x:Name="BtnMacroStop" Content="{loc:Get stop}"
                                                Padding="10,6" Margin="0,0,8,0" Click="BtnMacroStop_Click"
                                                Style="{StaticResource K2IconButton}" Tag="&#xE71A;"/>
                                            <TextBlock x:Name="TblMacroInputCount" Text="0 actions"
                                                   VerticalAlignment="Center" Foreground="#808080" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Assigned to -->
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="{loc:Get macro_section_assigned}" Style="{StaticResource K2SideGroupHeader}"
                                               ToolTip="{loc:Get macro_assigned_help}"/>
                                        <ItemsControl x:Name="LvMacroAssignments">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#232328" CornerRadius="6" Margin="0,0,0,6" Padding="8,6">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding KeyLabel}" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding Subtitle}" Foreground="#808088"
                                                                   FontSize="11" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock x:Name="TblMacroNotAssigned" Text="{loc:Get macro_not_assigned}"
                                               Foreground="#606068" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                <!-- end PnlMacro -->

                <!-- ==================== General Settings ==================== -->
                <Grid x:Name="PnlSettings" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24" MaxWidth="480" HorizontalAlignment="Left">
                            <TextBlock Text="{loc:Get tab_settings}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                            <GroupBox x:Name="GbAppBcImport" Header="{loc:Get settings_bc_import_group}" Margin="0,0,0,20">
                                <StackPanel Margin="8">
                                    <Button x:Name="BtnAppImportFromBaseCamp" Content="{loc:Get settings_bc_import_btn}"
                                    Padding="8,4" HorizontalAlignment="Left"
                                    Click="BtnAppImportFromBaseCamp_Click"
                                    Style="{StaticResource K2IconButton}" Tag="&#xE8B5;"/>
                                    <TextBlock Text="{loc:Get settings_bc_import_hint}" Foreground="#9A9AA2"
                                       TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox x:Name="GbAppBcDllFolder" Header="{loc:Get settings_bc_dll_group}" Margin="0,0,0,20">
                                <StackPanel Margin="8">
                                    <TextBlock Text="{loc:Get settings_bc_dll_hint}" Foreground="#9A9AA2"
                                       TextWrapping="Wrap" Margin="0,0,0,8" FontSize="12"/>

                                    <RadioButton x:Name="RbBcDllAuto" Content="{loc:Get settings_bc_dll_radio_auto}"
                                         GroupName="BcDllMode" Margin="0,4" Checked="RbBcDllMode_Checked"/>
                                    <TextBlock x:Name="TxtBcDetected" Foreground="#9A9AA2"
                                       TextWrapping="Wrap" Margin="20,0,0,10" FontSize="12"/>

                                    <RadioButton x:Name="RbBcDllManual" Content="{loc:Get settings_bc_dll_radio_manual}"
                                         GroupName="BcDllMode" Margin="0,4" Checked="RbBcDllMode_Checked"/>
                                    <TextBox x:Name="TxtBcDllFolder" IsReadOnly="True" Margin="20,4,0,8"/>
                                    <Button x:Name="BtnBcDllFolderBrowse" Content="{loc:Get settings_bc_dll_browse}"
                                    Padding="8,4" HorizontalAlignment="Left" Margin="20,0,0,0"
                                    Click="BtnBcDllFolderBrowse_Click"
                                    Style="{StaticResource K2IconButton}" Tag="&#xE8DA;"/>

                                    <TextBlock x:Name="TxtBcDllStatus" Foreground="#9A9AA2"
                                       TextWrapping="Wrap" Margin="0,8,0,0" FontSize="12"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox x:Name="GbAppGeneral" Header="{loc:Get settings_general}" Margin="0,0,0,20">
                                <StackPanel Margin="8">
                                    <CheckBox x:Name="CkCloseToTray" Content="{loc:Get settings_close_to_tray}"
                                      Click="CkCloseToTray_Click" FontSize="14"/>
                                    <CheckBox x:Name="CkK2Autostart" Content="{loc:Get settings_k2_autostart}"
                                      Click="CkK2Autostart_Click" FontSize="14" Margin="0,12,0,0"/>
                                    <TextBlock Text="{loc:Get settings_k2_autostart_hint}" Foreground="#9A9AA2"
                                       TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>
                                    <CheckBox x:Name="CkStartMinToTray" Content="{loc:Get settings_start_min_tray}"
                                      Click="CkStartMinToTray_Click" FontSize="14" Margin="0,12,0,0"/>
                                    <TextBlock Text="{loc:Get settings_start_min_tray_hint}" Foreground="#9A9AA2"
                                       TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>
                                    <Button x:Name="BtnAppExportLog" Content="{loc:Get settings_export_log_btn}"
                                    Padding="8,4" HorizontalAlignment="Left" Margin="0,16,0,0"
                                    Click="BtnAppExportLog_Click"
                                    Style="{StaticResource K2IconButton}" Tag="&#xE898;"/>
                                    <TextBlock Text="{loc:Get settings_export_log_hint}" Foreground="#9A9AA2"
                                       TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox x:Name="GbAppFont" Header="{loc:Get settings_font_family}" Margin="0,0,0,20">
                                <StackPanel Margin="8">
                                    <ComboBox x:Name="CmbAppFont" Width="220" HorizontalAlignment="Left"
                                      SelectionChanged="CmbAppFont_SelectionChanged"/>
                                    <TextBlock Text="{loc:Get settings_font_family_hint}" Foreground="#9A9AA2"
                                       TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12"/>
                                </StackPanel>
                            </GroupBox>

                            <CheckBox x:Name="CkAppDebugMode" Content="{loc:Get settings_debug_mode}"
                              Click="CkAppDebugMode_Click" FontSize="14"/>
                            <TextBlock Text="{loc:Get settings_debug_mode_hint}" Foreground="#9A9AA2"
                               TextWrapping="Wrap" Margin="20,4,0,20" FontSize="12"/>

                            <!-- Native USB engines (DisplayPad/Everest raw-HID) are hardcoded ON —
                         see AppSettings.DisplayPadNativeEngine. The Debug Mode opt-out
                         checkboxes that used to live here were removed 2026-07-16. -->

                            <GroupBox x:Name="GbAppLogLevel" Header="{loc:Get settings_log_level}" Margin="0,4,0,0">
                                <StackPanel Margin="8">
                                    <RadioButton x:Name="RbLogOff"     Content="{loc:Get log_off}"
                                         GroupName="AppLogLevel" Margin="0,4" Checked="RbLogLevel_Checked"/>
                                    <RadioButton x:Name="RbLogNormal"  Content="{loc:Get log_normal}"
                                         GroupName="AppLogLevel" Margin="0,4" Checked="RbLogLevel_Checked"/>
                                    <RadioButton x:Name="RbLogVerbose" Content="{loc:Get log_verbose}"
                                         GroupName="AppLogLevel" Margin="0,4" Checked="RbLogLevel_Checked"/>
                                </StackPanel>
                            </GroupBox>

                            <CheckBox x:Name="CkAutoStopBaseCamp" Content="{loc:Get settings_auto_stop_bc}"
                              Click="CkAutoStopBaseCamp_Click" FontSize="14" Margin="0,20,0,0"/>
                            <TextBlock Text="{loc:Get settings_auto_stop_bc_hint}" Foreground="#9A9AA2"
                               TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>

                            <CheckBox x:Name="CkKillBcWorker" Content="{loc:Get settings_kill_bc_worker}"
                              Click="CkKillBcWorker_Click" FontSize="14" Margin="0,16,0,0"/>
                            <TextBlock Text="{loc:Get settings_kill_bc_worker_hint}" Foreground="#9A9AA2"
                               TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>

                            <CheckBox x:Name="CkRestartBcOnClose" Content="{loc:Get settings_restart_bc_on_close}"
                              Click="CkRestartBcOnClose_Click" FontSize="14" Margin="0,16,0,0"/>
                            <TextBlock Text="{loc:Get settings_restart_bc_on_close_hint}" Foreground="#9A9AA2"
                               TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>

                            <CheckBox x:Name="CkBcAutostart" Content="{loc:Get settings_bc_autostart}"
                              Click="CkBcAutostart_Click" FontSize="14" Margin="0,16,0,0"/>
                            <TextBlock x:Name="TxtBcAutostartHint" Text="{loc:Get settings_bc_autostart_hint}"
                               Foreground="#9A9AA2" TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>

                            <GroupBox x:Name="GbAppDanger" Header="{loc:Get settings_danger_zone}"
                              Margin="0,24,0,0" BorderBrush="{StaticResource K2DangerBrush}">
                                <StackPanel Margin="8">
                                    <Button x:Name="BtnAppRestoreDefaults" Content="{loc:Get restore_defaults_app}"
                                    Padding="8,4" HorizontalAlignment="Left"
                                    Click="BtnAppRestoreDefaults_Click"
                                    Style="{StaticResource K2IconButton}" Tag="&#xE777;"/>
                                    <TextBlock Text="{loc:Get restore_defaults_app_hint}" Foreground="#9A9AA2"
                                       TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                <!-- end PnlSettings -->

            </Grid>
            <!-- end content panels -->
        </Grid>
        <!-- end outer device Grid -->

        <!-- Status bar -->
        <StatusBar Grid.Row="1" Margin="0,8,0,0">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True"/>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem DockPanel.Dock="Right" Padding="0,0,4,0">
                <Button x:Name="BtnLang" Click="BtnLang_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Padding="6,2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F310; "/>
                        <TextBlock x:Name="TxtLangLabel" Text="EN"/>
                    </StackPanel>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="English"    Tag="en" Click="MnuLang_Click"/>
                            <MenuItem Header="Italiano"   Tag="it" Click="MnuLang_Click"/>
                            <MenuItem Header="Español"    Tag="es" Click="MnuLang_Click"/>
                            <MenuItem Header="Français"   Tag="fr" Click="MnuLang_Click"/>
                            <MenuItem Header="Deutsch"    Tag="de" Click="MnuLang_Click"/>
                            <MenuItem Header="Português"  Tag="pt" Click="MnuLang_Click"/>
                            <MenuItem Header="Polski"     Tag="pl" Click="MnuLang_Click"/>
                            <MenuItem Header="日本語"      Tag="ja" Click="MnuLang_Click"/>
                            <MenuItem Header="中文"        Tag="zh" Click="MnuLang_Click"/>
                            <MenuItem Header="한국어"      Tag="ko" Click="MnuLang_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="LblStatus" Text="{loc:Get driver_not_opened}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Hardware-busy overlay — shown while a blocking device write (NDK/Display Dial
             picture upload, etc.) is in flight, so the app reads as "waiting", not frozen.
             Toggled via RunHwBusy/ShowHwBusy/HideHwBusy (MainWindow.HwBusy.cs). Root-level,
             spanning both rows, so it covers the whole window (tab strip, content, status
             bar) — not just the device content area. Semi-transparent (unlike PnlLoading)
             so the interface stays visible underneath, since this is a transient wait, not
             a full page swap. -->
        <Grid x:Name="PnlHwBusy" Grid.RowSpan="2" Panel.ZIndex="20" Background="#D91A1A1E"
              Visibility="Collapsed">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#F02A2A32" BorderBrush="#900000" BorderThickness="1"
                    CornerRadius="10" Padding="36,28">
                <StackPanel>
                    <TextBlock x:Name="TxtHwBusyMessage" FontSize="16" Foreground="White"
                               HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="380"
                               TextWrapping="Wrap"/>
                    <ProgressBar IsIndeterminate="True" Width="280" Height="3"
                                 Margin="0,18,0,0" Foreground="#900000" Background="#1A1A1E"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
