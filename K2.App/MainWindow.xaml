<Window x:Class="K2.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:K2.Core;assembly=K2.Core"
        xmlns:local="clr-namespace:K2.App"
        xmlns:themes="clr-namespace:K2.Core.Themes;assembly=K2.Core"
        Title="{loc:Get app_title}"
        Icon="Assets/K2_logo.png"
        Height="1024" Width="1600"
        MinHeight="768" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource K2WindowStyle}">

    <Window.Resources>
        <!-- BC-style key: same look for MacroPad and Everest.
             Face: horizontal gradient #3A→#40→#3A (like BC keyboard.css span::before).
             3D raise: dark platform below the face, face shifts down on press.
             DataTriggers (HasAction / IsHighlighted) are for MacroPad bindings;
             silently ignored on Everest buttons that have no matching DataContext. -->
        <!-- ============================================================
             KeyCapStyle — fedele replica del CSS di Base Camp:
             .keyboard span  → background #404040, border #1d1d1d,
             ::before         → gradiente laterale scuro,
             box-shadow       → ombra scura sopra/sotto (effetto "mount").
             Usato sia da MacroPad che da Everest.
             ============================================================ -->
        <!-- ============================================================
             KeyCapStyle — replica fedele di BC keyboard.css .keyboard span (keyboard_v3 / MacroPad):
               border: 7px solid #1d1d1d (tutti i lati)
               border-bottom: 10px solid transparent  → gap sotto = il Mount scuro si vede
               background: #404040
               ::before: gradiente scuro sui lati, highlight basso (#676767)
               hover: tutto #656565 + gradiente aggiornato
               active: translate(0, 3px) → Margin shift
             ============================================================ -->
        <Style x:Key="KeyCapStyle" TargetType="Button">
            <Setter Property="Background"       Value="#404040"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontFamily"       Value="Segoe UI, system-ui"/>
            <Setter Property="FontSize"         Value="8"/>
            <Setter Property="FontWeight"       Value="Normal"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderBrush"      Value="#1D1D1D"/>
            <!-- BC keyboard_v3: 7px border on all sides; bottom handled by the Face's Margin -->
            <Setter Property="BorderThickness"  Value="7,7,7,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!--
                          Layers (bottom → top):
                          0. LedHalo — glow bleeding outside Mount, Normal/Translucent keycap styles only
                          1. Mount — tracks BorderBrush (see below), visible in the gap under the Face
                          2. Face  — the actual key (bg #404040, thick borders like BC)
                             2a. SideGrad — dark side gradient (simulates ::before)
                             2b. Tint     — hover/press overlay
                             2c. Content

                          Keycap appearance (MacroPad Settings section, see MainWindow.MacroKeycapAppearance.cs
                          — same mechanism as Everest's EverestKeyStyle/MainWindow.KeycapAppearance.cs):
                          Background/BorderBrush are driven from code via the Button's own properties
                          (TemplateBinding below), never touched directly on Face, so the hover trigger
                          (which targets Face by name) keeps taking precedence on mouse-over. Mount's
                          Background is ALSO a TemplateBinding (to BorderBrush, not a plain literal) for
                          the same reason: a value set directly from code on Mount would permanently
                          outrank the Hover trigger below.
                        -->
                        <Grid>
                            <!-- 0. LED halo glow — BlurEffect feathers the edge so it fades out
                                 instead of ending in the hard-edged ring CornerRadius alone gives -->
                            <Border x:Name="LedHalo" Margin="-4" CornerRadius="8"
                                    Background="Transparent" IsHitTestVisible="False">
                                <Border.Effect>
                                    <BlurEffect Radius="8" KernelType="Gaussian"/>
                                </Border.Effect>
                            </Border>

                            <!-- 1. Mount: fills everything, visible under the Face (10px) -->
                            <Border x:Name="Mount"
                                    Background="{TemplateBinding BorderBrush}"
                                    CornerRadius="5"/>

                            <!-- 2. Face: 10px gap at the bottom reveals the Mount (border-bottom: 10px transparent) -->
                            <Border x:Name="Face"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <!-- 2a. SideGrad (::before): dark sides #3a3a3a, transparent center -->
                                    <Border x:Name="SideGrad" CornerRadius="3" IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#553A3A3A" Offset="0"/>
                                                <GradientStop Color="#003A3A3A" Offset="0.18"/>
                                                <GradientStop Color="#003A3A3A" Offset="0.82"/>
                                                <GradientStop Color="#553A3A3A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <!-- 2b. Tint overlay hover/press -->
                                    <Border x:Name="Tint" Background="Transparent" CornerRadius="3" IsHitTestVisible="False"/>
                                    <!-- 2c. Content -->
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="2"/>
                                </Grid>
                            </Border>

                            <!-- Mapped-key marker: small red triangle, MacroPad only (Everest/DisplayPad
                                 have their own equivalents) — same idea as DisplayPad's WarnTriangle, but
                                 flags "this key HAS an action" instead of "image without action". Replaces
                                 the previous approach of recoloring the whole keycap border, which the
                                 keycap-appearance feature (MainWindow.MacroKeycapAppearance.cs) already
                                 owns via Background/BorderBrush — this way the two never fight over the
                                 same properties. -->
                            <Polygon x:Name="MpMappedMarker"
                                     Points="0,10 10,10 10,0"
                                     Fill="#DDCC0000"
                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                     Margin="0,0,2,12"
                                     Visibility="Collapsed"
                                     IsHitTestVisible="False"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Hover: translucent white wash over the Face's CURRENT color (keycap
                                 color, live LED tint, physical-press flash, …) instead of replacing it
                                 with a flat gray — keeps whatever's actually showing recognizable, just
                                 lightened. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tint" Property="Background" Value="#26FFFFFF"/>
                            </Trigger>
                            <!-- Press: face drops 3px onto the Mount (BC: translate(0,3px)) -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Face" Property="Margin"     Value="0,3,0,7"/>
                                <Setter TargetName="Tint" Property="Background" Value="#33000000"/>
                            </Trigger>
                            <!-- MacroPad only: MacroPadKey.HasAction. Silently never matches on any
                                 other DataContext (e.g. a bare KeyCapStyle button with none). -->
                            <DataTrigger Binding="{Binding HasAction}" Value="True">
                                <Setter TargetName="MpMappedMarker" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MacroPad key: KeyCapStyle (7px/10px, incl. the mapped-key triangle marker) + DataTrigger IsHighlighted -->
        <Style x:Key="MacroKeyStyle" TargetType="Button" BasedOn="{StaticResource KeyCapStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <Setter Property="Background" Value="#900000"/>
                    <Setter Property="Foreground" Value="#10302F"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================
             EverestKeyStyle — BC .keyboard span base (Everest / Everest60):
               border: 5px sides, 2px top, 6px transparent bottom
               same Mount/gradient as KeyCapStyle, smaller values

             Keycap appearance (Settings > Aspetto tastiera Everest, see
             MainWindow.KeycapAppearance.cs): Background/BorderBrush are the
             live keycap color (Black/White/Custom) and, for Pudding/Reverse
             Pudding, the live LED color — both driven from code via the
             Button's own Background/BorderBrush properties (TemplateBinding
             below), never touched directly on Face, so the hover trigger
             (which targets Face by name) keeps taking precedence on mouse-over.
             LedHalo is a separate glow layer (Normal/Translucent styles only),
             bleeding outside Face/Mount into the gap between keys.
             ============================================================ -->
        <Style x:Key="EverestKeyStyle" TargetType="Button" BasedOn="{StaticResource KeyCapStyle}">
            <!-- Override borders: 5px sides, 2px top, 0 bottom (gap handled by Margin) -->
            <Setter Property="BorderThickness" Value="5,2,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- LED halo glow: bleeds outside Mount, Normal/Translucent keycap styles only.
                                 BlurEffect feathers the edge so it fades out instead of ending in the
                                 hard-edged ring CornerRadius alone gives. -->
                            <Border x:Name="LedHalo" Margin="-4" CornerRadius="7"
                                    Background="Transparent" IsHitTestVisible="False">
                                <Border.Effect>
                                    <BlurEffect Radius="6" KernelType="Gaussian"/>
                                </Border.Effect>
                            </Border>
                            <!-- Mount tracks BorderBrush via TemplateBinding (not a plain literal, and never
                                 set directly from code — see MainWindow.KeycapAppearance.cs): this way the
                                 Hover trigger below keeps overriding it on mouse-over. -->
                            <Border x:Name="Mount" Background="{TemplateBinding BorderBrush}" CornerRadius="4"/>
                            <!-- Face: 6px gap at the bottom (border-bottom: 6px transparent) -->
                            <Border x:Name="Face"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    Margin="0,0,0,6">
                                <Grid>
                                    <Border x:Name="SideGrad" CornerRadius="3" IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#553A3A3A" Offset="0"/>
                                                <GradientStop Color="#003A3A3A" Offset="0.18"/>
                                                <GradientStop Color="#003A3A3A" Offset="0.82"/>
                                                <GradientStop Color="#553A3A3A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border x:Name="Tint" Background="Transparent" CornerRadius="3" IsHitTestVisible="False"/>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="1"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Hover: translucent white wash over the Face's CURRENT color (keycap
                                 color, live LED tint, physical-press flash, …) instead of replacing it
                                 with a flat gray — keeps whatever's actually showing recognizable, just
                                 lightened. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tint" Property="Background" Value="#26FFFFFF"/>
                            </Trigger>
                            <!-- Press: face drops 3px (bottom 6→3, top +3) -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Face" Property="Margin"     Value="0,3,0,3"/>
                                <Setter TargetName="Tint" Property="Background" Value="#33000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================================
             DpKeyButtonStyle — faithful replica of Base Camp's DisplayPad key:
             .imagebtn  → key_button.png as a solid background (background-size: cover)
             img        → 52×52 user icon with CornerRadius 9 (border-radius 10px)
             ::before   → glossy overlay: white gradient + inset gray border
             Trigger hover → teal border; IsHighlighted → white border
             ============================================================ -->
        <Style x:Key="DpKeyButtonStyle" TargetType="Button">
            <Setter Property="Width"             Value="60"/>
            <Setter Property="Height"            Value="60"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <!-- 1. key_button.png — solid background (like background-size:cover) -->
                            <Image Source="pack://application:,,,/Assets/key_button.png"
                                   Stretch="Fill" IsHitTestVisible="False"/>

                            <!-- 2. 52×52 user icon, rounded corners (border-radius 10px) -->
                            <Border Width="52" Height="52"
                                    CornerRadius="9" ClipToBounds="True"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                                <Image x:Name="ImgIcon" Source="{Binding Preview}" Stretch="UniformToFill"/>
                            </Border>

                            <!-- 3. Glossy overlay — simulates ::before with inset box-shadow #727272 -->
                            <Border Margin="4" CornerRadius="9"
                                    BorderBrush="#60727272" BorderThickness="1"
                                    IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#28FFFFFF" Offset="0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.35"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- 4. Label (ContentPresenter = Button.Content = TextBlock passed in from code-behind) -->
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>

                            <!-- 5. Warning triangle: image present but no action configured -->
                            <Polygon x:Name="WarnTriangle"
                                     Points="0,10 10,10 10,0"
                                     Fill="#DDCC0000"
                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                     Margin="0,0,5,5"
                                     Visibility="Collapsed"
                                     IsHitTestVisible="False"/>

                            <!-- 6. Selection/hover border -->
                            <Border x:Name="SelBorder"
                                    CornerRadius="10"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelBorder" Property="BorderBrush" Value="#900000"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter TargetName="SelBorder" Property="BorderBrush"     Value="White"/>
                                <Setter TargetName="SelBorder" Property="BorderThickness" Value="3"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasImageNoAction}" Value="True">
                                <Setter TargetName="WarnTriangle" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!-- Imported "Play macro" action with no macro matched by name
                                 (BaseCampDbImporter.TranslateDefaultAction) — same "action not
                                 found" warning triangle as an image without an action. -->
                            <DataTrigger Binding="{Binding HasUnresolvedAction}" Value="True">
                                <Setter TargetName="WarnTriangle" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!-- Unresolved macro whose original BC name IS preserved
                                 ("***Name" value, ActionTypeHelper.UnresolvedMacroPrefix):
                                 yellow instead of red — nothing is lost, it just needs a
                                 same-named macro created/assigned. Declared after the red
                                 triggers so this Fill wins when both apply. -->
                            <DataTrigger Binding="{Binding HasUnresolvedNamedAction}" Value="True">
                                <Setter TargetName="WarnTriangle" Property="Fill" Value="#DDD9A400"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar section navigation tab style. Square tiles (2026-07-14, on
             request — same background/shape language as the Makalu DPI level
             tiles in MakaluRgbSettingsPanel.xaml.cs's BuildMkDpiLevelButtons:
             solid fill at rest, not just an accent border, uniform rounded
             corners instead of a flag-shaped left edge, and a bigger title
             instead of small text) — still stacked vertically inside the
             same 160px sidebar column as before, just taller/blockier per
             entry. Title sits top-left with padding (not centered — on
             request), via HorizontalContentAlignment/VerticalContentAlignment
             "Left"/"Top" both on the RadioButton and its ContentPresenter.
             ContentTemplate (not a plain ContentPresenter) is required for
             wrapping: TextWrapping isn't an inherited property, so a longer
             title (e.g. "Device settings") can still wrap onto a second line
             within the tile instead of clipping. -->
        <Style x:Key="SectionTabStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource K2TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource K2SurfaceAltBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource K2AppFontFamily}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="MinHeight" Value="120"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Left" FontWeight="Bold"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource K2BorderBrush}"
                                CornerRadius="8">
                            <Grid>
                                <!-- Decorative corner triangle: small/gray while inactive, bigger/white
                                     when this section is the active one (IsChecked trigger below). -->
                                <Polygon x:Name="CornerTriangle"
                                         Points="18,0 18,18 0,18"
                                         Fill="#54545E"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                         Margin="0,0,4,4"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Top"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource K2HoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource K2AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource K2AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource K2AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource K2AccentTextBrush}"/>
                                <Setter TargetName="CornerTriangle" Property="Points" Value="36,0 36,36 0,36"/>
                                <Setter TargetName="CornerTriangle" Property="Fill" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================================
             Common right-side action panel (all devices): every button
             and combo shown here uses the SAME Width/Height so the
             vertical stack lines up regardless of device (Everest /
             MacroPad / DisplayPad), grouped in coherent sections
             (Profile / Import / Device).
             ============================================================ -->
        <Style x:Key="K2SideActionButton" TargetType="Button" BasedOn="{StaticResource K2IconButton}">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style x:Key="K2SideActionAccentButton" TargetType="Button" BasedOn="{StaticResource K2IconAccentButton}">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style x:Key="K2SideActionCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- Profile picker: replaces K2SideActionCombo for the per-device profile
             selector (see MainWindow.{Device}.cs's Refresh...Profiles methods) — an
             always-visible list (no hidden dropdown) instead of a ComboBox, so more
             than a handful of profiles (DisplayPad has no hard cap) stay browsable.
             Same Width as every other sidebar control so the column doesn't resize. -->
        <!-- Row content for every device's profile list: name + a small gear button (right-
             aligned via the Auto column) that opens ProfileSettingsDialog (rename/delete/
             link-launch-executable — see MainWindow.xaml.cs's ProfileGear_PreviewMouseDown).
             Hidden by default (Visibility="Hidden", NOT Collapsed) and only shown on hover
             of the row it belongs to (MultiDataTrigger below, checking both IsRealProfile —
             hidden on the "+ New profile" placeholder row — and the ancestor ListBoxItem's
             IsMouseOver). Hidden (not Collapsed) is deliberate: it still reserves the
             button's width/height in the row's layout, so the row's size stays constant
             whether or not the gear is actually showing — Collapsed let the row shrink/grow
             on hover, which looked like the row "growing" every time the mouse entered it.
             The action itself is wired to PreviewMouseLeftButtonDown (not Click): this runs
             during the TUNNEL phase, before the row's own selection logic sees the gesture,
             so marking e.Handled there reliably suppresses the row selecting/switching
             profile — relying on Click instead was fragile (ButtonBase's Down/Up state
             machine could lose mouse capture if the row selection changed the ItemsSource
             mid-click) and didn't open the popup at all in practice. -->
        <DataTemplate x:Key="K2ProfileItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <!-- Vector gear traced from Grafiche/settings.png's alpha-channel silhouette
                     (Moore-neighbor boundary tracing + Douglas-Peucker simplification, done
                     once offline — see CHANGELOG 2026-07-21) instead of the PNG asset itself:
                     crisp at any size, no bitmap scaling involved. FillRule="EvenOdd" carves
                     the center hole (2nd subpath) out of the outer gear body (1st subpath).
                     Fill is the same muted gray the earlier attempts used — "contextual"
                     coloring: this spot matches the row label, not the accent color. -->
                <!-- No hover halo: overrides the default Button style's ControlTemplate (which
                     paints a hover Background/BorderBrush box behind the content) with a bare
                     ContentPresenter — this is a small inline icon button, not meant to show a
                     background box on hover. -->
                <Button x:Name="BtnGear" Grid.Column="1"
                        Width="22" Height="22" Padding="0" Margin="4,0,0,0"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Arrow"
                        Visibility="Hidden"
                        PreviewMouseLeftButtonDown="ProfileGear_PreviewMouseDown">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                    <Path x:Name="PathGear" Width="17" Height="17" Stretch="Uniform" Fill="#9A9AA2"
                          Data="M 11.06,4.64 L 13.17,4.64 L 13.55,6.33 L 15.00,6.98 L 16.59,6.05 L 18.05,7.50 L 17.11,9.05 L 17.67,10.45 L 19.45,10.92 L 19.45,13.03 L 17.72,13.45 L 17.11,14.86 L 18.00,16.50 L 16.59,17.91 L 15.05,17.02 L 13.64,17.53 L 13.17,19.31 L 11.06,19.31 L 10.69,17.67 L 9.28,17.02 L 7.64,17.91 L 6.19,16.45 L 7.12,14.91 L 6.52,13.45 L 4.78,13.03 L 4.78,10.88 L 6.47,10.50 L 7.12,9.05 L 6.19,7.50 L 7.64,6.05 L 9.23,6.98 L 10.59,6.42 Z M 11.81,9.33 L 12.80,9.42 L 13.88,9.98 L 14.39,10.64 L 14.77,11.72 L 14.67,12.66 L 14.11,13.73 L 13.69,14.11 L 13.08,14.44 L 12.19,14.67 L 11.02,14.39 L 10.22,13.88 L 9.66,12.98 L 9.42,12.09 L 9.61,11.11 L 10.08,10.27 L 10.92,9.61 Z"/>
                </Button>
            </Grid>
            <DataTemplate.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRealProfile}" Value="True"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="BtnGear" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter TargetName="PathGear" Property="Fill" Value="{StaticResource K2AccentTextBrush}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="K2SideProfileItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#9A9AA2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="ProfileItem_PreviewRightClick"/>
            <EventSetter Event="ContextMenuOpening" Handler="ProfileItem_ContextMenuOpening"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <!-- Stretch (not Left): K2ProfileItemTemplate's Grid needs the full row
                                 width so its "*" name column can actually push the gear button's
                                 Auto column to the row's right edge — Left-aligning the
                                 ContentPresenter sized the Grid down to its content's natural width
                                 instead, leaving the gear stuck right after the label text. -->
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E26"/>
                                <Setter Property="Foreground" Value="#DCDCE0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource K2AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource K2AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource K2AccentTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="K2SideProfileList" TargetType="ListBox">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="150"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Background" Value="#111115"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource K2SideProfileItemStyle}"/>
            <Setter Property="ItemTemplate" Value="{StaticResource K2ProfileItemTemplate}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="4">
                            <ScrollViewer Background="Transparent" CanContentScroll="False">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="K2SideGroupHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4A4A58"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <!-- Macro editor: block-style RadioButton for mutually-exclusive
             option rows (Delay / Playback) — same accent-highlight look
             as SectionTabStyle, but a full pill row instead of a tab. -->
        <Style x:Key="MacroOptionRowStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#B8B8C0"/>
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A30"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource K2AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource K2AccentTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Macro editor: small icon-only button for per-row input actions
             (move up/down, delete) — same glyph-in-Tag convention as
             K2IconButton, but compact and with no text label. -->
        <Style x:Key="MacroRowIconButton" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#808088"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="4" Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#333338"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Macro editor: library list item, styled like the device "SECTIONS"
             sidebar (accent-highlight-when-selected) instead of a plain ListBox. -->
        <Style x:Key="MacroLibraryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#9A9AA2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent"
                                CornerRadius="0,4,4,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E26"/>
                                <Setter Property="Foreground" Value="#DCDCE0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource K2AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource K2AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource K2AccentTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Macro editor: press/release chevron indicator on each input row -->
        <Style x:Key="MacroPressIndicatorStyle" TargetType="TextBlock">
            <Setter Property="Text" Value=""/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding ShowIndicator}" Value="True"/>
                        <Condition Binding="{Binding IsPress}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Text" Value="&#x25B2;"/>
                    <Setter Property="Foreground" Value="#4CAF50"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding ShowIndicator}" Value="True"/>
                        <Condition Binding="{Binding IsPress}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Text" Value="&#x25BC;"/>
                    <Setter Property="Foreground" Value="#E05252"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Outer grid: top tab strip + brightness bar + content panels -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- device tab strip -->
                <RowDefinition Height="Auto"/>
                <!-- brightness bar (shared, one control per device type) -->
                <RowDefinition Height="*"/>
                <!-- content panels -->
            </Grid.RowDefinitions>

            <!-- Top-level device tab strip (Everest static; MacroPad/DP added dynamically)
                 + Macro / gear-only Settings buttons, right-aligned on the same row. -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="3" BorderBrush="#2A2A32" BorderThickness="0,0,0,1"/>

                <TabControl x:Name="TcDevices" Grid.Column="0"
                            SelectionChanged="TcDevices_SelectionChanged">
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <TabPanel IsItemsHost="True" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                        </ControlTemplate>
                    </TabControl.Template>
                    <!-- Home: icon-only tab, always present (not gated by any device connection) —
                         the app's landing tab, always first regardless of what's plugged in. -->
                    <TabItem x:Name="TabHome" Tag="home" ToolTip="{loc:Get tab_home}">
                        <TabItem.Header>
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </TabItem.Header>
                    </TabItem>
                    <!-- Fixed device order: Everest Max > Everest 60 > Makalu > DisplayPad > MacroPad
                         (DisplayPad tabs inserted dynamically after TabMakalu by DpRefreshDevices).
                         Every tab starts Collapsed and is only made Visible once its device is
                         confirmed connected (see SetDeviceTabVisible in MainWindow.xaml.cs) — a
                         disconnected device must never show a tab. -->
                    <TabItem x:Name="TabEverest"   Tag="everest"   Header="{loc:Get tab_everest}"   Visibility="Collapsed"/>
                    <TabItem x:Name="TabEverest60" Tag="everest60" Header="{loc:Get tab_everest60}" Visibility="Collapsed"/>
                    <TabItem x:Name="TabMakalu"    Tag="makalu"    Header="{loc:Get tab_makalu}"    Visibility="Collapsed"/>
                    <!-- DisplayPad tabs added dynamically by DpRefreshDevices -->
                    <TabItem x:Name="TabMacroPad" Tag="macropad" Header="{loc:Get tab_macropad}" Visibility="Collapsed"/>
                </TabControl>

                <!-- Macro: icon + label button, left of Settings -->
                <Button x:Name="BtnMacroTab" Grid.Column="1"
                        Height="34" Margin="8,0,0,4" Padding="10,0"
                        VerticalAlignment="Center"
                        Background="Transparent" Foreground="{StaticResource K2TextMutedBrush}"
                        Cursor="Hand" Click="BtnMacroTab_Click"
                        ToolTip="{loc:Get tab_macro}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7">
                                <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                                    <TextBlock Text="&#xE7C8;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Get tab_macro}" Margin="6,0,0,0"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource K2HoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Settings: gear-icon-only button, always right-aligned. Same traced vector
                     gear as the per-profile gear (K2ProfileItemTemplate — see its doc comment
                     for how the Path Data was produced) — Fill stays bound to the button's own
                     Foreground (TemplateBinding), same "contextual color" approach: whatever
                     color this button is themed with (muted gray, matching the profile gear)
                     drives the icon. -->
                <Button x:Name="BtnSettingsTab" Grid.Column="2"
                        Width="34" Height="34" Margin="8,0,4,4"
                        VerticalAlignment="Center"
                        Background="Transparent" Foreground="{StaticResource K2TextMutedBrush}"
                        Cursor="Hand" Click="BtnSettingsTab_Click"
                        ToolTip="{loc:Get tab_settings}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7">
                                <Path Width="18" Height="18" Stretch="Uniform" Fill="{TemplateBinding Foreground}"
                                      Data="M 11.06,4.64 L 13.17,4.64 L 13.55,6.33 L 15.00,6.98 L 16.59,6.05 L 18.05,7.50 L 17.11,9.05 L 17.67,10.45 L 19.45,10.92 L 19.45,13.03 L 17.72,13.45 L 17.11,14.86 L 18.00,16.50 L 16.59,17.91 L 15.05,17.02 L 13.64,17.53 L 13.17,19.31 L 11.06,19.31 L 10.69,17.67 L 9.28,17.02 L 7.64,17.91 L 6.19,16.45 L 7.12,14.91 L 6.52,13.45 L 4.78,13.03 L 4.78,10.88 L 6.47,10.50 L 7.12,9.05 L 6.19,7.50 L 7.64,6.05 L 9.23,6.98 L 10.59,6.42 Z M 11.81,9.33 L 12.80,9.42 L 13.88,9.98 L 14.39,10.64 L 14.77,11.72 L 14.67,12.66 L 14.11,13.73 L 13.69,14.11 L 13.08,14.44 L 12.19,14.67 L 11.02,14.39 L 10.22,13.88 L 9.66,12.98 L 9.42,12.09 L 9.61,11.11 L 10.08,10.27 L 10.92,9.61 Z"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource K2HoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Brightness bar: top-right, below the settings icon + divider.
                 One StackPanel per device type; only the active device's is
                 shown (toggled in TcDevices_SelectionChanged / BtnSettingsTab_Click,
                 same as the Pnl* content panels below). -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,4,6">
                <StackPanel x:Name="BrEverest" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="{loc:Get brightness}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="SldEvBrightness" Minimum="0" Maximum="100" Value="100"
                            Width="140" TickFrequency="25" IsSnapToTickEnabled="True"
                            TickPlacement="BottomRight"
                            ValueChanged="SldEvBrightness_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblEvBrightness" Text="100%"
                               VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="40"/>
                </StackPanel>
                <StackPanel x:Name="BrMacroPad" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="{loc:Get brightness}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="SldMacroBrightness" Minimum="0" Maximum="100" Value="100"
                            Width="140" TickFrequency="25" IsSnapToTickEnabled="True"
                            TickPlacement="BottomRight"
                            ValueChanged="SldMacroBrightness_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblMacroBrightness" Text="100%"
                               VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="40"/>
                </StackPanel>
                <StackPanel x:Name="BrDisplayPad" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="{loc:Get brightness}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="SldDpBrightness" Minimum="0" Maximum="100" Value="100"
                            Width="140" TickFrequency="25" IsSnapToTickEnabled="True"
                            TickPlacement="BottomRight"
                            ValueChanged="SldDpBrightness_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblDpBrightness" Text="100%" VerticalAlignment="Center"
                               Margin="6,0,0,0" MinWidth="40"/>
                </StackPanel>
                <StackPanel x:Name="BrEverest60" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="{loc:Get brightness}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="SldEv60Brightness" Minimum="0" Maximum="100" Value="100"
                            Width="140" TickFrequency="25" IsSnapToTickEnabled="True"
                            TickPlacement="BottomRight"
                            ValueChanged="SldEv60Brightness_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblEv60Brightness" Text="100%" VerticalAlignment="Center"
                               Margin="6,0,0,0" MinWidth="40"/>
                </StackPanel>
                <StackPanel x:Name="BrMakalu" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="{loc:Get brightness}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="SldMkBrightness" Minimum="0" Maximum="100" Value="100"
                            Width="140" TickFrequency="25" IsSnapToTickEnabled="True"
                            TickPlacement="BottomRight"
                            ValueChanged="SldMkBrightness_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblMkBrightness" Text="100%" VerticalAlignment="Center"
                               Margin="6,0,0,0" MinWidth="40"/>
                </StackPanel>
            </StackPanel>

            <!-- Loading overlay — covers tab strip + content while AutoOpenDrivers runs.
                 Collapsed by code once all drivers are open. -->
            <Grid x:Name="PnlLoading" Grid.RowSpan="3" Panel.ZIndex="10" Background="#1A1A1E" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="Assets/K2_logo.png" Width="96" Height="96"
                           HorizontalAlignment="Center" Margin="0,0,0,16"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{loc:Get loading_drivers}"
                               FontSize="15" Foreground="#900000"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="280" Height="3"
                                 Margin="0,14,0,0" Foreground="#900000" Background="#2A2A32"/>
                </StackPanel>
            </Grid>

            <!-- Content panels: one visible at a time -->
            <Grid Grid.Row="2">

                <!-- ==================== Home ====================
                 Grid of cards, one per currently connected device (RefreshHomeTiles in
                 MainWindow.Home.cs) — inspired by Base Camp's own device picker. Only one
                 of PnlHomeEmpty/IcHomeTiles is visible at a time (nothing connected yet vs.
                 at least one tile), toggled by RefreshHomeTiles itself. -->
                <Grid x:Name="PnlHome">
                    <StackPanel x:Name="PnlHomeEmpty" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="Assets/K2_logo.png" Width="96" Height="96"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{loc:Get home_no_device}" FontSize="15"
                               Foreground="{StaticResource K2TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    </StackPanel>

                    <ScrollViewer x:Name="ScrHomeTiles" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="24">
                            <TextBlock Text="{loc:Get home_heading}" FontSize="15" FontWeight="SemiBold"
                                   Margin="4,0,0,14"/>
                            <ItemsControl x:Name="IcHomeTiles">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="HomeTile_Click" Cursor="Hand" Margin="0,0,21,21"
                                            Background="Transparent" BorderThickness="0" Padding="0"
                                            Height="Auto" Width="Auto"
                                            HorizontalContentAlignment="Stretch">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Card" Width="351" Height="247" CornerRadius="13"
                                                        Background="#221F26" BorderBrush="#2A2A32"
                                                        BorderThickness="1" ClipToBounds="True">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="5"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0"
                                                                Background="{StaticResource K2AccentBrush}"
                                                                CornerRadius="5,0,0,5"/>
                                                            <Image Grid.Column="1" Source="{Binding ImagePath}"
                                                               Stretch="Uniform" HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               Width="{Binding ImageWidth}" Height="{Binding ImageHeight}"
                                                               Margin="0,0,-13,-13"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                   FontSize="29" FontWeight="Bold"
                                                                   Foreground="{StaticResource K2TextBrush}"
                                                                   Margin="23,23,13,13" TextWrapping="Wrap"
                                                                   VerticalAlignment="Top"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Card" Property="BorderBrush"
                                                                Value="{StaticResource K2AccentBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ==================== Everest Max ==================== -->
                <Grid x:Name="PnlEverest" Visibility="Collapsed">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <!-- Fixed (not Auto): keeps the sidebar/content start position
                             identical across devices regardless of which toolbar
                             buttons/breadcrumb happen to be visible for this device. -->
                            <RowDefinition Height="32"/>
                            <!-- toolbar -->
                            <RowDefinition Height="*"/>
                            <!-- 3-pane main -->
                        </Grid.RowDefinitions>

                        <!-- ── Toolbar ── -->
                        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <!-- Debug-only: open/close driver manually -->
                            <Button x:Name="BtnEvOpen"    Content="{loc:Get open_driver}"   Click="BtnEvOpen_Click"
                                Style="{StaticResource K2IconAccentButton}" Tag="&#xE768;" Visibility="Collapsed"/>
                            <Button x:Name="BtnEvClose"   Content="{loc:Get close_driver}"  Margin="8,0,0,0" Click="BtnEvClose_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE711;" Visibility="Collapsed"/>
                            <!-- Debug-only: AP controls -->
                            <Separator x:Name="SepEvApDbg" Margin="10,0" Visibility="Collapsed"/>
                            <Button x:Name="BtnEvApOn"  Content="AP ON"  Padding="10,4"
                                Click="BtnEvApOn_Click"  Visibility="Collapsed"/>
                            <Button x:Name="BtnEvApOff" Content="AP OFF" Padding="10,4" Margin="6,0,0,0"
                                Click="BtnEvApOff_Click" Visibility="Collapsed"/>
                            <Separator x:Name="SepEvSdkDbg" Margin="10,0" Visibility="Collapsed"/>
                            <TextBlock x:Name="LblEvSdk" Margin="16,6,0,0" FontStyle="Italic" Foreground="#9A9AA2" Visibility="Collapsed"/>
                        </WrapPanel>

                        <!-- ── 3-pane: sidebar | device-image + bottom-panel ── -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <!-- sidebar -->
                                <ColumnDefinition Width="*"/>
                                <!-- right side -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- common actions (all devices) -->
                            </Grid.ColumnDefinitions>

                            <!-- Left sidebar: section navigation -->
                            <Border Grid.Column="0" Background="#111115" CornerRadius="6"
                                Margin="0,0,8,0" Padding="4">
                                <StackPanel>
                                    <TextBlock Text="SECTIONS" FontSize="9" Foreground="#4A4A58"
                                           Margin="14,8,0,6" FontWeight="Bold"/>
                                    <RadioButton x:Name="RbSecKeyMapping"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_key_binding}" GroupName="EvSections"
                                             IsChecked="True" Checked="EvSection_Changed"/>
                                    <RadioButton x:Name="RbSecRgb"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get rgb_lighting}" GroupName="EvSections"
                                             Checked="EvSection_Changed"/>
                                    <RadioButton x:Name="RbSecDial"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="Display Dial" GroupName="EvSections"
                                             Checked="EvSection_Changed"/>
                                    <RadioButton x:Name="RbSecSettings"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_settings}" GroupName="EvSections"
                                             Checked="EvSection_Changed"/>
                                    <!-- Debug-only sections -->
                                    <Separator x:Name="SepSectionDbg" Style="{StaticResource K2SideSeparator}"
                                           Margin="8,8" Visibility="Collapsed"/>
                                    <RadioButton x:Name="RbSecUsb"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get usb_recorder}" GroupName="EvSections"
                                             Visibility="Collapsed" Checked="EvSection_Changed"/>
                                </StackPanel>
                            </Border>

                            <!-- Right: device image (top, fixed height) + settings panel (bottom, grows) -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <!-- Fixed height across all devices, matching MacroPad's box height
                                     when rotated to vertical orientation (Positioning section,
                                     90°/270°): the canvas is 510x370, but RotateTransform swaps its
                                     rendered footprint to 370x510, so 510 + 8px padding each side = 526
                                     is the tallest a device box needs to be. -->
                                    <RowDefinition Height="526"/>
                                    <!-- device -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- HW capture bar (media dock / crown only) -->
                                    <RowDefinition Height="*"/>
                                    <!-- settings: grows with window height -->
                                </Grid.RowDefinitions>

                                <!-- Device image with interactive overlay. The Preview mouse handlers +
                                 CvsEvRubberBand implement Custom Lighting's rectangular multi-LED
                                 selection (drag a square over keys/border squares to paint them all —
                                 see EvDeviceBox_* in MainWindow.CustomLighting.cs). Preview (tunnel)
                                 events so a drag can START on a key Button without the Button
                                 swallowing the gesture; a plain click still reaches the Button
                                 normally because the rubber band only engages past a small drag
                                 threshold. -->
                                <Border Grid.Row="0" Background="#18181C" CornerRadius="6" Padding="8"
                                    x:Name="BdrEvDeviceBox"
                                    PreviewMouseLeftButtonDown="EvDeviceBox_MouseDown"
                                    PreviewMouseMove="EvDeviceBox_MouseMove"
                                    PreviewMouseLeftButtonUp="EvDeviceBox_MouseUp">
                                  <Grid>
                                    <DockPanel>
                                        <StackPanel x:Name="SpEvLayout" Orientation="Horizontal"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <!-- +20% zoom on request: LayoutTransform (not RenderTransform)
                                             so the Grid/Border around it re-measures at the scaled size
                                             and WPF's hit-testing keeps mapping clicks to the right Button
                                             automatically — no changes needed to KeyDef X/Y/W/H math. -->
                                            <StackPanel.LayoutTransform>
                                                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                            </StackPanel.LayoutTransform>
                                            <!-- Left column: dock overlay + keyboard body -->
                                            <Grid x:Name="GrdEvKeyColumn">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Canvas x:Name="CvsEvKeyboard" Grid.Row="1"
                                                    Width="642" Height="260" ClipToBounds="True">
                                                    <Canvas.Background>
                                                        <ImageBrush x:Name="BrushEvKeyBg" ImageSource="Assets/keybg.png" Stretch="Fill"/>
                                                    </Canvas.Background>
                                                </Canvas>
                                                <!-- Border/side-LED paint overlay (Custom Lighting only): 31
                                                 small squares around the main board's bezel, built in code
                                                 (BuildBorderSquares/PlaceEdge, MainWindow.CustomLighting.cs).
                                                 SAME Grid.Row + SAME Width/Height as CvsEvKeyboard (not
                                                 bigger — a same-size sibling in the same cell overlaps it
                                                 exactly with zero extra alignment math and, critically,
                                                 doesn't grow the row / shift CvsEvKeyboard's own position the
                                                 way a larger centered sibling would). No ClipToBounds, so
                                                 squares positioned via negative/overflowing Canvas.Left/Top
                                                 in code render outside the nominal 642x260 rect just fine.
                                                 Declared AFTER CvsEvKeyboard (+ explicit ZIndex) to paint on
                                                 top of it. -->
                                                <!-- NO Background here: a Transparent background would be
                                                 hit-testable and, sitting at ZIndex 2 over the whole board,
                                                 swallowed every key click while paint mode was on (root cause
                                                 of "keys won't paint on single click", 2026-07-22). A null
                                                 background lets clicks fall through to the keys while the
                                                 border squares (children with their own background) stay
                                                 clickable. -->
                                                <Canvas x:Name="CvsEvBorderMain" Grid.Row="1"
                                                    Width="642" Height="260"
                                                    Panel.ZIndex="2"
                                                    Visibility="Collapsed"/>
                                                <!-- Dock overlay: keytop art + a transparent Canvas holding the
                                                 clickable hotspots (4 media buttons + 2 crown rotation buttons,
                                                 the latter positioned above the artwork via negative Canvas.Top).
                                                 GrdEvDock keeps the Left/Right alignment toggle previously on
                                                 ImgEvDock (see UpdateKeyboardLayout), so the hotspots follow it. -->
                                                <Grid x:Name="GrdEvDock" Grid.Row="0" Width="200"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,-32" Panel.ZIndex="1"
                                                  Visibility="Collapsed">
                                                    <Image x:Name="ImgEvDock" Source="Assets/keytop.png" Stretch="Uniform"/>
                                                    <Canvas x:Name="CvsEvDock" Width="200" Height="64"/>
                                                </Grid>
                                            </Grid>
                                            <!-- Numpad + display keys, wrapped in a Grid (was a bare Canvas)
                                             so a same-size border overlay can share its cell — same reasoning
                                             as CvsEvBorderMain above. The Margin/VerticalAlignment that used
                                             to live on CvsEvNumpad itself move to the wrapping Grid so the
                                             pair positions identically to before. -->
                                            <Grid x:Name="GrdEvNumpadColumn" Margin="6,0,0,0" VerticalAlignment="Bottom">
                                                <Canvas x:Name="CvsEvNumpad" Width="166" Height="260"
                                                    ClipToBounds="True">
                                                    <Canvas.Background>
                                                        <ImageBrush x:Name="BrushEvBoardRight" ImageSource="Assets/board_right.png" Stretch="Fill"/>
                                                    </Canvas.Background>
                                                </Canvas>
                                                <!-- Same null-background reasoning as CvsEvBorderMain above. -->
                                                <Canvas x:Name="CvsEvBorderNumpad" Width="166" Height="260"
                                                    Panel.ZIndex="2"
                                                    Visibility="Collapsed"/>
                                            </Grid>
                                        </StackPanel>
                                    </DockPanel>
                                    <!-- Rubber-band overlay for rectangular multi-LED selection: same
                                     Grid cell as the DockPanel so it covers the whole device box;
                                     IsHitTestVisible=False so it never steals clicks — the Border's
                                     Preview handlers drive it. -->
                                    <Canvas x:Name="CvsEvRubberBand" IsHitTestVisible="False">
                                        <Rectangle x:Name="RectEvRubberBand" Visibility="Collapsed"
                                               Stroke="#5BBEC3" StrokeThickness="1"
                                               StrokeDashArray="3 2" Fill="#335BBEC3"/>
                                    </Canvas>
                                  </Grid>
                                </Border>

                                <!-- HW capture bar: feedback-only text for the media dock / crown "Capture
                                 matrixId…" context-menu action (MainWindow.DockActions.cs) — no button
                                 here anymore (the old standalone "Capture HW Key" trigger was removed;
                                 the only way to start a capture now is that per-slot context-menu item).
                                 Only relevant when a dock is physically attached, so it mirrors
                                 GrdEvDock's visibility (see MainWindow.Layout.cs). -->
                                <WrapPanel x:Name="PnlHwCaptureBar" Grid.Row="1" Orientation="Horizontal"
                                       Margin="0,8,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="LblCapturedKey" Text=""
                                           VerticalAlignment="Center" Foreground="#900000"/>
                                </WrapPanel>

                                <!-- Bottom settings panel: grows with the window (Row="*" above); MinHeight
                                 keeps its old fixed size as a floor so it doesn't collapse below the
                                 tallest section (Key Binding/RGB vs. Display Dial vs. USB Recorder).
                                 NOTE: no outer ScrollViewer anymore — that used to wrap ALL sections,
                                 but a ScrollViewer gives its content infinite available height, so
                                 nothing inside it can ever "fill remaining space" (a plain
                                 MaxHeight/Height-binding on LvEvKeys below either stayed too small or,
                                 worse, could compute TALLER than what's actually visible and silently
                                 render past the bottom of the window — exactly the "disappears below"
                                 bug this replaced). Each section now owns its own overflow behavior
                                 instead: Key Binding's Grid+ListView genuinely stretch (Grid.Row="0"
                                 below is "*", a real bounded size once nothing wraps it in a
                                 ScrollViewer); RGB/Dial/Settings/USB Recorder each have their own
                                 ScrollViewer (RGB already did; the other three were wrapped to match).
                                 MinHeight=220 (not 270, the value from the very first pass of this
                                 fix): the fixed chrome above this Border (tab strip + brightness bar +
                                 toolbar + status bar + margins, ~145px) plus the fixed 526px device row
                                 plus this floor must all fit inside the window's default Height (see
                                 Window.Height below) — 270 pushed that sum ~44px past 897, so on launch
                                 the bottom of the key list/buttons rendered past the window's bottom
                                 edge (Border doesn't clip by default, same root cause as the bug
                                 described above, just reintroduced via the floor value instead of a
                                 converter). Ev60(150)/Makalu(180)/MacroPad(130)/DisplayPad(90) all stay
                                 under that budget, which is why only Everest Max showed it. -->
                                <Border x:Name="BdrEvSettingsPanel" Grid.Row="1" Background="#14141A"
                                    BorderBrush="#2A2A32" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,10,0,0"
                                    MinHeight="220" Grid.RowSpan="2">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <!-- active section content: fills the Border -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- debug SDK log -->
                                        </Grid.RowDefinitions>

                                        <!-- ─── All section panels (one visible at a time) ─── -->
                                        <Grid Grid.Row="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="151*"/>
                                                <RowDefinition Height="9*"/>
                                            </Grid.RowDefinitions>

                                            <!-- ── KEY BINDING (mapped keys — click a key on the device
                                             graphic above to configure its action). A Grid (not
                                             StackPanel): StackPanel always sizes
                                             children to their natural/desired height regardless of
                                             available space, so it can never stretch a child to fill —
                                             only a Grid cell (default child alignment = Stretch)
                                             actually lets LvEvKeys grow with the window. Same
                                             hint-row + list/buttons layout as MacroPad's
                                             PnlMpSecKeyBinding (shared "key_binding_hint" string) — kept
                                             in sync across every device's Key Binding section except
                                             Makalu, per user request. ── -->
                                            <Grid x:Name="PnlSecKeyMapping" Grid.RowSpan="2" Visibility="Collapsed">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <!-- hint text -->
                                                    <RowDefinition Height="*"/>
                                                    <!-- list + buttons: fills remaining height -->
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="{loc:Get key_binding_hint}" Foreground="#9A9AA2"
                                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                                                <Grid Grid.Row="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="170"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ListView Grid.Column="0" x:Name="LvEvKeys" Margin="0,0,8,0"
                                                          SelectionChanged="LvEvKeys_SelectionChanged">
                                                        <ListView.ItemContainerStyle>
                                                            <Style TargetType="ListViewItem">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                        <Setter Property="Background" Value="#900000"/>
                                                                        <Setter Property="Foreground" Value="#10302F"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ListView.ItemContainerStyle>
                                                        <ListView.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Display}" FontFamily="Consolas" Padding="2"/>
                                                            </DataTemplate>
                                                        </ListView.ItemTemplate>
                                                    </ListView>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                                        <Button x:Name="BtnEvMapKeys" Content="{loc:Get remap_keys}"
                                                            Click="BtnEvMapKeys_Click"
                                                            Style="{StaticResource K2IconButton}" Tag="&#xE8CB;"
                                                            HorizontalAlignment="Stretch" Margin="0,0,0,10"
                                                            Visibility="Collapsed"/>
                                                        <Separator x:Name="SepEvMapKeysDbg" Style="{StaticResource K2SideSeparator}"
                                                               Margin="0,0,0,10" Visibility="Collapsed"/>
                                                        <Button x:Name="BtnEvConfig" Content="{loc:Get ev_configure}"
                                                            Padding="8,4" Click="BtnEvConfig_Click"
                                                            HorizontalAlignment="Stretch" Margin="0,0,0,4"
                                                            IsEnabled="False"/>
                                                        <Button x:Name="BtnEvRemove" Content="{loc:Get ev_remove}"
                                                            Padding="8,4" Click="BtnEvRemove_Click"
                                                            HorizontalAlignment="Stretch"
                                                            IsEnabled="False"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>

                                            <!-- ── RGB & LIGHTING ── -->
                                            <ScrollViewer x:Name="PnlSecRgb"
                                                      MaxHeight="220" VerticalScrollBarVisibility="Auto" VerticalAlignment="Top" Visibility="Collapsed">
                                                <StackPanel>
                                                    <!-- Preset effects row 1: effect/speed/on-off (left) + sync (right) —
                                                     same Grid layout as MacroPad's PnlMpSecLed. -->
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{loc:Get rgb_effect}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <ComboBox x:Name="CbEvEffect" Width="140" Margin="0,0,12,0"
                                                                  SelectionChanged="CbEvEffect_SelectionChanged"
                                                                  DropDownOpened="CbEvEffect_DropDownOpened"
                                                                  DropDownClosed="CbEvEffect_DropDownClosed"/>
                                                            <StackPanel x:Name="PnlEvSpeed" Orientation="Horizontal" Margin="0,0,12,0">
                                                                <TextBlock Text="{loc:Get rgb_speed}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                <Slider x:Name="SldEvSpeed" Minimum="0" Maximum="100" Width="110"
                                                                    TickFrequency="25" IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                                                                    ValueChanged="SldEvSpeed_ValueChanged" VerticalAlignment="Center"/>
                                                                <TextBlock x:Name="LblEvSpeed" Text="50%" VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="36"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{loc:Get led_backlight_label}" VerticalAlignment="Center" Margin="12,0,8,0"/>
                                                            <CheckBox x:Name="CkEvBacklight" Style="{StaticResource K2InlineSwitch}"
                                                                VerticalAlignment="Center" IsChecked="True" Click="CkEvBacklight_Click"/>
                                                        </StackPanel>
                                                        <!-- Right-aligned to match CkSettingsSync's position in the
                                                         Settings section below (PnlSecSettings) — both sit in a
                                                         same-width panel, so HorizontalAlignment="Right" with the
                                                         same base 10px margin lines them up when switching
                                                         sections. Nudged a further 15px left per user request
                                                         (2026-07-21) via the extra margin. Replaces the old
                                                         hardcoded Margin="888,0,10,0" left-offset hack. -->
                                                        <CheckBox x:Name="CkEvSync" Content="{loc:Get rgb_sync_profiles}"
                                                              VerticalAlignment="Center" Click="CkEvSync_Click" Grid.ColumnSpan="2"
                                                              HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                    </Grid>
                                                    <!-- Backlight auto-off — moved here from Settings (user request
                                                     2026-07-21): lives next to the backlight switch above, sized
                                                     like everything else in this panel (no Height/Padding override,
                                                     unlike the Settings-panel version this replaced). -->

                                                    <!-- Normal-effect controls (Row 2 direction + Row 3 color mode) vs.
                                                     Custom Lighting — mutually exclusive, toggled by CbEvEffect's
                                                     selection (UpdateEvCapabilities): only one is ever Visible, so
                                                     they're just two overlapping children of the same Grid cell
                                                     (no ColumnDefinitions needed — a 2-column split was tried first
                                                     but left a stray unnecessary scrollbar in PnlSecRgb, root cause
                                                     not pinned down; removed 2026-07-22 rather than chase it further
                                                     since the columns were never really needed once Custom moved to
                                                     the left/full-width per the same day's follow-up request). -->
                                                    <Grid Margin="0,0,0,10">
                                                        <StackPanel x:Name="PnlEvNormalControls">
                                                            <!-- Row 2: direction (only when the effect supports it) -->
                                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                <StackPanel x:Name="PnlEvDirection" Orientation="Horizontal">
                                                                    <TextBlock Text="{loc:Get rgb_direction}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                    <Border Style="{StaticResource K2SegmentedGroupBorder}">
                                                                        <UniformGrid x:Name="GridEvDirection" Rows="1"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </WrapPanel>
                                                            <!-- Row 3: color mode (Single/Double/Rainbow, one mutually-exclusive
                                                             vertical radio group) + swatches. -->
                                                            <WrapPanel Orientation="Horizontal">
                                                                <StackPanel Orientation="Vertical" Margin="0,0,20,0" VerticalAlignment="Center">
                                                                    <RadioButton x:Name="RbEvColorSingle" Content="{loc:Get rgb_single}" GroupName="EvColorMode"
                                                                        Margin="0,0,0,6" Checked="RbEvColorMode_Checked" ToolTip="{loc:Get rgb_single_tip}"/>
                                                                    <RadioButton x:Name="RbEvColorDouble" Content="{loc:Get rgb_double}" GroupName="EvColorMode"
                                                                        Margin="0,0,0,6" Checked="RbEvColorMode_Checked" ToolTip="{loc:Get rgb_double_tip}"/>
                                                                    <RadioButton x:Name="RbEvRainbow" Content="{loc:Get rgb_rainbow}" GroupName="EvColorMode"
                                                                        Checked="RbEvColorMode_Checked" ToolTip="{loc:Get rgb_rainbow_tip}"/>
                                                                </StackPanel>
                                                                <StackPanel x:Name="PnlEvColor1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                                                    <TextBlock Text="{loc:Get rgb_primary}" VerticalAlignment="Center" Margin="0,0,4,0" Padding="0,0,5,0"/>
                                                                    <Button x:Name="BtnEvColor1" Width="30" Height="30"
                                                                        Background="#900000" BorderThickness="2"
                                                                        BorderBrush="#3A3A40" Click="BtnEvColor_Click" Tag="1"/>
                                                                </StackPanel>
                                                                <StackPanel x:Name="PnlEvColor2" Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="{loc:Get rgb_secondary}" VerticalAlignment="Center" Margin="0,0,4,0" Padding="0,0,5,0"/>
                                                                    <Button x:Name="BtnEvColor2" Width="30" Height="30"
                                                                        Background="#1A1A1E" BorderThickness="2"
                                                                        BorderBrush="#3A3A40" Click="BtnEvColor_Click" Tag="2" Padding="12,6,12,6"/>
                                                                </StackPanel>
                                                                <StackPanel x:Name="PnlEvColor3" Orientation="Horizontal"
                                                                        Margin="20,0,0,0" Visibility="Collapsed">
                                                                    <TextBlock Text="{loc:Get rgb_tertiary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                    <Button x:Name="BtnEvColor3" Width="30" Height="30"
                                                                        Background="#1A1A1E" BorderThickness="2"
                                                                        BorderBrush="#3A3A40" Click="BtnEvColor_Click" Tag="3"/>
                                                                </StackPanel>
                                                            </WrapPanel>
                                                        </StackPanel>

                                                        <!-- Per-key custom lighting section — was hidden 2026-07-14 (user
                                                         request at the time: hide LED painting/ring sections on every
                                                         device with a Lighting section), re-enabled 2026-07-22 (explicit
                                                         user request: full LED-painting system with border LEDs,
                                                         emulating Base Camp's own Custom section — see
                                                         MainWindow.CustomLighting.cs and CHANGELOG). Moved to the right
                                                         column + shown only for CbEvEffect="Custom" same session. -->
                                                        <StackPanel x:Name="PnlEvCustomLighting" Visibility="Collapsed">
                                                            <TextBlock Text="{loc:Get custom_lighting}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                            <TextBlock Text="{loc:Get custom_paint_hint}"
                                                               Foreground="#9A9AA2" FontStyle="Italic"
                                                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                            <!-- Paint effect: which effect newly-painted keys get. Only
                                                             "Static" actually sends per-key colors today — the others
                                                             are UI-ready but not yet wired to a wire protocol (no
                                                             confirmed way to run a dynamic effect on a painted key
                                                             subset — see TODO.md/CHANGELOG 2026-07-22): BtnCustomApply_Click
                                                             logs and no-ops instead of sending misleading data. Border
                                                             squares only paintable under Static (matches Base Camp: "con
                                                             gli effetti dinamici si possono dipingere solo i led dei
                                                             keycap" — user description). Dropdown hidden (user request
                                                             2026-07-22, since only Static works) — stays Collapsed but
                                                             in the tree so CbCustomPaintEffect keeps its SelectedIndex=0
                                                             (Static) default from InitCustomLightingPanel; re-enabling
                                                             other effects later is a one-line Visibility flip. -->
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                                <StackPanel x:Name="PnlCustomPaintEffect" Orientation="Horizontal" Visibility="Collapsed">
                                                                    <TextBlock Text="{loc:Get custom_paint_effect}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                    <ComboBox x:Name="CbCustomPaintEffect" Width="130"
                                                                          SelectionChanged="CbCustomPaintEffect_SelectionChanged"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{loc:Get custom_color}" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                                                <Button x:Name="BtnCustomBrushColor" Width="30" Height="30"
                                                                Background="#FF0000" BorderThickness="2"
                                                                BorderBrush="#3A3A40" Click="BtnCustomBrushColor_Click"/>
                                                            </StackPanel>
                                                            <WrapPanel Orientation="Horizontal">
                                                                <Button x:Name="BtnCustomApply"   Content="{loc:Get apply}"           Padding="8,2" Margin="0,0,4,0" Click="BtnCustomApply_Click"  Style="{StaticResource K2IconAccentButton}" Tag="&#xE73E;"/>
                                                                <Button x:Name="BtnCustomFillAll" Content="{loc:Get custom_fill_all}" Padding="8,2" Margin="0,0,4,0" Click="BtnCustomFillAll_Click" Style="{StaticResource K2IconButton}"       Tag="&#xE771;"/>
                                                                <Button x:Name="BtnCustomClear"   Content="{loc:Get custom_clear}"    Padding="8,2"                   Click="BtnCustomClear_Click"   Style="{StaticResource K2IconButton}"       Tag="&#xE74D;"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <CheckBox x:Name="CkEvAutoOffEnable" Content="{loc:Get backlight_auto_off_enable}"
      Click="CkEvAutoOffEnable_Click" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                                        <TextBlock Text="{loc:Get backlight_auto_off_seconds}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBox x:Name="TxtEvAutoOffSeconds" Width="70" TextAlignment="Center"
     LostFocus="TxtEvAutoOffSeconds_LostFocus" VerticalAlignment="Center" Height="25" Padding="3,2,3,0" TextChanged="TxtEvAutoOffSeconds_TextChanged"/>
                                                        <TextBlock Text="{loc:Get unit_seconds}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </ScrollViewer>

                                            <!-- ── DISPLAY DIAL ── (own ScrollViewer: no outer one anymore, see
                                             the comment on BdrEvSettingsPanel above) -->
                                            <ScrollViewer x:Name="PnlSecDial"
                                                      VerticalScrollBarVisibility="Auto" Grid.RowSpan="2" Visibility="Collapsed">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="20"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Left: show/hide menu pages — 2 columns x 4 rows, toggle-switch rows -->
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{loc:Get dial_pages_visible}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="14"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <CheckBox x:Name="CkDialClock"    Style="{StaticResource K2ToggleRow}" Tag="&#xEC92;" Content="{loc:Get dial_clock}"      Click="CkDial_Click"/>
                                                                    <CheckBox x:Name="CkDialProfile"  Style="{StaticResource K2ToggleRow}" Tag="&#xE77B;" Content="{loc:Get dial_profile}"    Click="CkDial_Click"/>
                                                                    <CheckBox x:Name="CkDialLighting" Style="{StaticResource K2ToggleRow}" Tag="&#xEA80;" Content="{loc:Get dial_lighting}"   Click="CkDial_Click"/>
                                                                    <CheckBox x:Name="CkDialVolume"   Style="{StaticResource K2ToggleRow}" Tag="&#xE994;" Content="{loc:Get dial_volume}"     Click="CkDial_Click"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2">
                                                                    <CheckBox x:Name="CkDialBright"   Style="{StaticResource K2ToggleRow}" Tag="&#xE706;" Content="{loc:Get dial_brightness}" Click="CkDial_Click"/>
                                                                    <CheckBox x:Name="CkDialPCInfo"   Style="{StaticResource K2ToggleRow}" Tag="&#xE977;" Content="{loc:Get dial_pcinfo}"     Click="CkDial_Click"/>
                                                                    <CheckBox x:Name="CkDialAPM"      Style="{StaticResource K2ToggleRow}" Tag="&#xE916;" Content="{loc:Get dial_apm}"        Click="CkDial_Click"/>
                                                                    <CheckBox x:Name="CkDialCustom"   Style="{StaticResource K2ToggleRow}" Tag="&#xE765;" Content="{loc:Get dial_custom}"     Click="CkDial_Click"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <WrapPanel Orientation="Horizontal" Margin="0,12,0,-24" HorizontalAlignment="Right">
                                                                <TextBlock Text="{loc:Get dial_menu_color}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                <Button x:Name="BtnDialMenuColor" Width="30" Height="30"
                                                                Background="#F3CC23" BorderThickness="2"
                                                                BorderBrush="#3A3A40" Click="BtnDialMenuColor_Click"/>
                                                            </WrapPanel>

                                                            <TextBlock Text="{loc:Get dial_clock_section}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                            <WrapPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                                <TextBlock Text="{loc:Get dial_clock_style_label}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                <Border Style="{StaticResource K2SegmentedGroupBorder}" Width="140" Margin="0,0,16,0">
                                                                    <UniformGrid Rows="1">
                                                                        <RadioButton x:Name="RbDialClockDigital" Content="{loc:Get dial_clock_digital}" GroupName="DialClockStyle" Style="{StaticResource K2SegmentedButton}" Checked="RbDialClockStyle_Checked" themes:K2Segment.CornerRadius="6,0,0,6"/>
                                                                        <RadioButton x:Name="RbDialClockAnalog" Content="{loc:Get dial_clock_analog}" GroupName="DialClockStyle" Style="{StaticResource K2SegmentedButton}" Checked="RbDialClockStyle_Checked" themes:K2Segment.CornerRadius="0,6,6,0"/>
                                                                    </UniformGrid>
                                                                </Border>
                                                                <StackPanel x:Name="PnlDialClockFormat" Orientation="Horizontal">
