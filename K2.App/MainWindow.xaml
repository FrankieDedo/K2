                                            <!-- ── SETTINGS ── (own ScrollViewer, same reason as Display Dial above).
                                             VerticalAlignment="Top" (not "Center", the original value): Center
                                             left a large empty strip above the content whenever this section is
                                             shorter than the tallest section (Key Binding/RGB) sharing the same
                                             Border — flagged by user (screenshot, 2026-07-21). -->
                                            <ScrollViewer x:Name="PnlSecSettings"
                                                      VerticalScrollBarVisibility="Auto" VerticalAlignment="Top" Height="283" Grid.RowSpan="2" Visibility="Collapsed">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
