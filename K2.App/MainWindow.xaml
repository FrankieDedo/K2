                                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Get unit_seconds}" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                                                                <CheckBox Grid.Row="1" Grid.Column="0" x:Name="CkDialTurnOffEnable"
