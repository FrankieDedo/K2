                                                                    <ComboBox x:Name="CbDialScreenSaverFunction" Width="180"
                                                                      SelectionChanged="CbDialScreenSaverFunction_SelectionChanged" Margin="5,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                                                    <Button x:Name="BtnDialLoadImage" Content="{loc:Get dial_load_image}"
                                                                    Padding="8,2" Margin="5,10,0,0" Click="BtnDialLoadImage_Click"
