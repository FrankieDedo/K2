<Window x:Class="K2.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:K2.Core;assembly=K2.Core"
        Title="{loc:Get app_title}"
        Icon="Assets/K2_logo.png"
        Height="897" Width="1426"
        MinHeight="713" MinWidth="1196"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource K2WindowStyle}">

    <Window.Resources>
        <!-- BC-style key: same look for MacroPad and Everest.
             Face: horizontal gradient #3A→#40→#3A (like BC keyboard.css span::before).
             3D raise: dark platform below the face, face shifts down on press.
             DataTriggers (HasAction / IsHighlighted) are for MacroPad bindings;
             silently ignored on Everest buttons that have no matching DataContext. -->
        <!-- ============================================================
             KeyCapStyle — fedele replica del CSS di Base Camp:
             .keyboard span  → background #404040, border #1d1d1d,
             ::before         → gradiente laterale scuro,
             box-shadow       → ombra scura sopra/sotto (effetto "mount").
             Usato sia da MacroPad che da Everest.
             ============================================================ -->
        <!-- ============================================================
             KeyCapStyle — replica fedele di BC keyboard.css .keyboard span (keyboard_v3 / MacroPad):
               border: 7px solid #1d1d1d (tutti i lati)
               border-bottom: 10px solid transparent  → gap sotto = il Mount scuro si vede
               background: #404040
               ::before: gradiente scuro sui lati, highlight basso (#676767)
               hover: tutto #656565 + gradiente aggiornato
               active: translate(0, 3px) → Margin shift
             ============================================================ -->
        <Style x:Key="KeyCapStyle" TargetType="Button">
            <Setter Property="Background"       Value="#404040"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontFamily"       Value="Segoe UI, system-ui"/>
            <Setter Property="FontSize"         Value="8"/>
            <Setter Property="FontWeight"       Value="Normal"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderBrush"      Value="#1D1D1D"/>
            <!-- BC keyboard_v3: 7px border on all sides; bottom handled by the Face's Margin -->
            <Setter Property="BorderThickness"  Value="7,7,7,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!--
                          Layers (bottom → top):
                          0. LedHalo — glow bleeding outside Mount, Normal/Translucent keycap styles only
                          1. Mount — tracks BorderBrush (see below), visible in the gap under the Face
                          2. Face  — the actual key (bg #404040, thick borders like BC)
                             2a. SideGrad — dark side gradient (simulates ::before)
                             2b. Tint     — hover/press overlay
                             2c. Content

                          Keycap appearance (MacroPad Settings section, see MainWindow.MacroKeycapAppearance.cs
                          — same mechanism as Everest's EverestKeyStyle/MainWindow.KeycapAppearance.cs):
                          Background/BorderBrush are driven from code via the Button's own properties
                          (TemplateBinding below), never touched directly on Face, so the hover trigger
                          (which targets Face by name) keeps taking precedence on mouse-over. Mount's
                          Background is ALSO a TemplateBinding (to BorderBrush, not a plain literal) for
                          the same reason: a value set directly from code on Mount would permanently
                          outrank the Hover trigger below.
                        -->
                        <Grid>
                            <!-- 0. LED halo glow — BlurEffect feathers the edge so it fades out
                                 instead of ending in the hard-edged ring CornerRadius alone gives -->
                            <Border x:Name="LedHalo" Margin="-4" CornerRadius="8"
                                    Background="Transparent" IsHitTestVisible="False">
                                <Border.Effect>
                                    <BlurEffect Radius="8" KernelType="Gaussian"/>
                                </Border.Effect>
                            </Border>

                            <!-- 1. Mount: fills everything, visible under the Face (10px) -->
                            <Border x:Name="Mount"
                                    Background="{TemplateBinding BorderBrush}"
                                    CornerRadius="5"/>

                            <!-- 2. Face: 10px gap at the bottom reveals the Mount (border-bottom: 10px transparent) -->
                            <Border x:Name="Face"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <!-- 2a. SideGrad (::before): dark sides #3a3a3a, transparent center -->
                                    <Border x:Name="SideGrad" CornerRadius="3" IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#553A3A3A" Offset="0"/>
                                                <GradientStop Color="#003A3A3A" Offset="0.18"/>
                                                <GradientStop Color="#003A3A3A" Offset="0.82"/>
                                                <GradientStop Color="#553A3A3A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <!-- 2b. Tint overlay hover/press -->
                                    <Border x:Name="Tint" Background="Transparent" CornerRadius="3" IsHitTestVisible="False"/>
                                    <!-- 2c. Content -->
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="2"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Hover: translucent white wash over the Face's CURRENT color (keycap
                                 color, live LED tint, physical-press flash, …) instead of replacing it
                                 with a flat gray — keeps whatever's actually showing recognizable, just
                                 lightened. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tint" Property="Background" Value="#26FFFFFF"/>
                            </Trigger>
                            <!-- Press: face drops 3px onto the Mount (BC: translate(0,3px)) -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Face" Property="Margin"     Value="0,3,0,7"/>
                                <Setter TargetName="Tint" Property="Background" Value="#33000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MacroPad key: KeyCapStyle (7px/10px) + DataTriggers HasAction / IsHighlighted -->
        <Style x:Key="MacroKeyStyle" TargetType="Button" BasedOn="{StaticResource KeyCapStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasAction}" Value="True">
                    <Setter Property="BorderBrush" Value="#4FB87A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <Setter Property="Background" Value="#900000"/>
                    <Setter Property="Foreground" Value="#10302F"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================
             EverestKeyStyle — BC .keyboard span base (Everest / Everest60):
               border: 5px sides, 2px top, 6px transparent bottom
               same Mount/gradient as KeyCapStyle, smaller values

             Keycap appearance (Settings > Aspetto tastiera Everest, see
             MainWindow.KeycapAppearance.cs): Background/BorderBrush are the
             live keycap color (Black/White/Custom) and, for Pudding/Reverse
             Pudding, the live LED color — both driven from code via the
             Button's own Background/BorderBrush properties (TemplateBinding
             below), never touched directly on Face, so the hover trigger
             (which targets Face by name) keeps taking precedence on mouse-over.
             LedHalo is a separate glow layer (Normal/Translucent styles only),
             bleeding outside Face/Mount into the gap between keys.
             ============================================================ -->
        <Style x:Key="EverestKeyStyle" TargetType="Button" BasedOn="{StaticResource KeyCapStyle}">
            <!-- Override borders: 5px sides, 2px top, 0 bottom (gap handled by Margin) -->
            <Setter Property="BorderThickness" Value="5,2,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- LED halo glow: bleeds outside Mount, Normal/Translucent keycap styles only.
                                 BlurEffect feathers the edge so it fades out instead of ending in the
                                 hard-edged ring CornerRadius alone gives. -->
                            <Border x:Name="LedHalo" Margin="-4" CornerRadius="7"
                                    Background="Transparent" IsHitTestVisible="False">
                                <Border.Effect>
                                    <BlurEffect Radius="6" KernelType="Gaussian"/>
                                </Border.Effect>
                            </Border>
                            <!-- Mount tracks BorderBrush via TemplateBinding (not a plain literal, and never
                                 set directly from code — see MainWindow.KeycapAppearance.cs): this way the
                                 Hover trigger below keeps overriding it on mouse-over. -->
                            <Border x:Name="Mount" Background="{TemplateBinding BorderBrush}" CornerRadius="4"/>
                            <!-- Face: 6px gap at the bottom (border-bottom: 6px transparent) -->
                            <Border x:Name="Face"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    Margin="0,0,0,6">
                                <Grid>
                                    <Border x:Name="SideGrad" CornerRadius="3" IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#553A3A3A" Offset="0"/>
                                                <GradientStop Color="#003A3A3A" Offset="0.18"/>
                                                <GradientStop Color="#003A3A3A" Offset="0.82"/>
                                                <GradientStop Color="#553A3A3A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border x:Name="Tint" Background="Transparent" CornerRadius="3" IsHitTestVisible="False"/>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="1"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Hover: translucent white wash over the Face's CURRENT color (keycap
                                 color, live LED tint, physical-press flash, …) instead of replacing it
                                 with a flat gray — keeps whatever's actually showing recognizable, just
                                 lightened. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tint" Property="Background" Value="#26FFFFFF"/>
                            </Trigger>
                            <!-- Press: face drops 3px (bottom 6→3, top +3) -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Face" Property="Margin"     Value="0,3,0,3"/>
                                <Setter TargetName="Tint" Property="Background" Value="#33000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================================
             DpKeyButtonStyle — faithful replica of Base Camp's DisplayPad key:
             .imagebtn  → key_button.png as a solid background (background-size: cover)
             img        → 52×52 user icon with CornerRadius 9 (border-radius 10px)
             ::before   → glossy overlay: white gradient + inset gray border
             Trigger hover → teal border; IsHighlighted → white border
             ============================================================ -->
        <Style x:Key="DpKeyButtonStyle" TargetType="Button">
            <Setter Property="Width"             Value="60"/>
            <Setter Property="Height"            Value="60"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <!-- 1. key_button.png — solid background (like background-size:cover) -->
                            <Image Source="pack://application:,,,/Assets/key_button.png"
                                   Stretch="Fill" IsHitTestVisible="False"/>

                            <!-- 2. 52×52 user icon, rounded corners (border-radius 10px) -->
                            <Border Width="52" Height="52"
                                    CornerRadius="9" ClipToBounds="True"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                                <Image x:Name="ImgIcon" Source="{Binding Preview}" Stretch="UniformToFill"/>
                            </Border>

                            <!-- 3. Glossy overlay — simulates ::before with inset box-shadow #727272 -->
                            <Border Margin="4" CornerRadius="9"
                                    BorderBrush="#60727272" BorderThickness="1"
                                    IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#28FFFFFF" Offset="0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.35"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- 4. Label (ContentPresenter = Button.Content = TextBlock passed in from code-behind) -->
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>

                            <!-- 5. Warning triangle: image present but no action configured -->
                            <Polygon x:Name="WarnTriangle"
                                     Points="0,10 10,10 10,0"
                                     Fill="#DDCC0000"
                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                     Margin="0,0,5,5"
                                     Visibility="Collapsed"
                                     IsHitTestVisible="False"/>

                            <!-- 6. Selection/hover border -->
                            <Border x:Name="SelBorder"
                                    CornerRadius="10"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelBorder" Property="BorderBrush" Value="#900000"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter TargetName="SelBorder" Property="BorderBrush"     Value="White"/>
                                <Setter TargetName="SelBorder" Property="BorderThickness" Value="3"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasImageNoAction}" Value="True">
                                <Setter TargetName="WarnTriangle" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar section navigation tab style -->
        <Style x:Key="SectionTabStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#9A9AA2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Roboto Medium, Segoe UI"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent"
                                CornerRadius="0,4,4,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E26"/>
                                <Setter Property="Foreground" Value="#DCDCE0"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource K2AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource K2AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource K2AccentTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================================
             Common right-side action panel (all devices): every button
             and combo shown here uses the SAME Width/Height so the
             vertical stack lines up regardless of device (Everest /
             MacroPad / DisplayPad), grouped in coherent sections
             (Profile / Import / Device).
             ============================================================ -->
        <Style x:Key="K2SideActionButton" TargetType="Button" BasedOn="{StaticResource K2IconButton}">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style x:Key="K2SideActionAccentButton" TargetType="Button" BasedOn="{StaticResource K2IconAccentButton}">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style x:Key="K2SideActionCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="K2SideGroupHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4A4A58"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <!-- Macro editor: block-style RadioButton for mutually-exclusive
             option rows (Delay / Playback) — same accent-highlight look
             as SectionTabStyle, but a full pill row instead of a tab. -->
        <Style x:Key="MacroOptionRowStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#B8B8C0"/>
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A30"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource K2AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource K2AccentTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Macro editor: small icon-only button for per-row input actions
             (move up/down, delete) — same glyph-in-Tag convention as
             K2IconButton, but compact and with no text label. -->
        <Style x:Key="MacroRowIconButton" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#808088"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="4" Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#333338"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Macro editor: library list item, styled like the device "SECTIONS"
             sidebar (accent-highlight-when-selected) instead of a plain ListBox. -->
        <Style x:Key="MacroLibraryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#9A9AA2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent"
                                CornerRadius="0,4,4,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E26"/>
                                <Setter Property="Foreground" Value="#DCDCE0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource K2AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource K2AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource K2AccentTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Macro editor: press/release chevron indicator on each input row -->
        <Style x:Key="MacroPressIndicatorStyle" TargetType="TextBlock">
            <Setter Property="Text" Value=""/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding ShowIndicator}" Value="True"/>
                        <Condition Binding="{Binding IsPress}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Text" Value="&#x25B2;"/>
                    <Setter Property="Foreground" Value="#4CAF50"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding ShowIndicator}" Value="True"/>
                        <Condition Binding="{Binding IsPress}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Text" Value="&#x25BC;"/>
                    <Setter Property="Foreground" Value="#E05252"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Outer grid: top tab strip + brightness bar + content panels -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- device tab strip -->
                <RowDefinition Height="Auto"/>  <!-- brightness bar (shared, one control per device type) -->
                <RowDefinition Height="*"/>     <!-- content panels -->
            </Grid.RowDefinitions>

            <!-- Top-level device tab strip (Everest static; MacroPad/DP added dynamically)
                 + Macro / gear-only Settings buttons, right-aligned on the same row. -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="3" BorderBrush="#2A2A32" BorderThickness="0,0,0,1"/>

                <TabControl x:Name="TcDevices" Grid.Column="0"
                            SelectionChanged="TcDevices_SelectionChanged">
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <TabPanel IsItemsHost="True" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                        </ControlTemplate>
                    </TabControl.Template>
                    <TabItem x:Name="TabEverest"   Tag="everest"   Header="{loc:Get tab_everest}"/>
                    <TabItem x:Name="TabMacroPad" Tag="macropad" Header="{loc:Get tab_macropad}"/>
                    <!-- DisplayPad tabs added dynamically by DpRefreshDevices -->
                </TabControl>

                <!-- Macro: icon + label button, left of Settings -->
                <Button x:Name="BtnMacroTab" Grid.Column="1"
                        Height="34" Margin="8,0,0,4" Padding="10,0"
                        VerticalAlignment="Center"
                        Background="Transparent" Foreground="{StaticResource K2TextMutedBrush}"
                        Cursor="Hand" Click="BtnMacroTab_Click"
                        ToolTip="{loc:Get tab_macro}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7">
                                <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                                    <TextBlock Text="&#xE7C8;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Get tab_macro}" Margin="6,0,0,0"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource K2HoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Settings: gear-icon-only button, always right-aligned -->
                <Button x:Name="BtnSettingsTab" Grid.Column="2"
                        Width="34" Height="34" Margin="8,0,4,4"
                        VerticalAlignment="Center"
                        Background="Transparent" Foreground="{StaticResource K2TextMutedBrush}"
                        Cursor="Hand" Click="BtnSettingsTab_Click"
                        ToolTip="{loc:Get tab_settings}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource K2HoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Brightness bar: top-right, below the settings icon + divider.
                 One StackPanel per device type; only the active device's is
                 shown (toggled in TcDevices_SelectionChanged / BtnSettingsTab_Click,
                 same as the Pnl* content panels below). -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,4,6">
                <StackPanel x:Name="BrEverest" Orientation="Horizontal">
                    <TextBlock Text="{loc:Get brightness}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="SldEvBrightness" Minimum="0" Maximum="100" Value="100"
                            Width="140" TickFrequency="25" IsSnapToTickEnabled="True"
                            TickPlacement="BottomRight"
                            ValueChanged="SldEvBrightness_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblEvBrightness" Text="100%"
                               VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="40"/>
                </StackPanel>
                <StackPanel x:Name="BrMacroPad" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="{loc:Get brightness}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="SldMacroBrightness" Minimum="0" Maximum="100" Value="100"
                            Width="140" TickFrequency="25" IsSnapToTickEnabled="True"
                            TickPlacement="BottomRight"
                            ValueChanged="SldMacroBrightness_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblMacroBrightness" Text="100%"
                               VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="40"/>
                </StackPanel>
                <StackPanel x:Name="BrDisplayPad" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="{loc:Get brightness}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="SldDpBrightness" Minimum="0" Maximum="100" Value="100"
                            Width="140" TickFrequency="25" IsSnapToTickEnabled="True"
                            TickPlacement="BottomRight"
                            ValueChanged="SldDpBrightness_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblDpBrightness" Text="100%" VerticalAlignment="Center"
                               Margin="6,0,0,0" MinWidth="40"/>
                </StackPanel>
            </StackPanel>

            <!-- Loading overlay — covers tab strip + content while AutoOpenDrivers runs.
                 Collapsed by code once all drivers are open. -->
            <Grid x:Name="PnlLoading" Grid.RowSpan="3" Panel.ZIndex="10" Background="#1A1A1E">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="Assets/K2_logo.png" Width="96" Height="96"
                           HorizontalAlignment="Center" Margin="0,0,0,16"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{loc:Get loading_drivers}"
                               FontSize="15" Foreground="#900000"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="280" Height="3"
                                 Margin="0,14,0,0" Foreground="#900000" Background="#2A2A32"/>
                </StackPanel>
            </Grid>

            <!-- Content panels: one visible at a time -->
            <Grid Grid.Row="2">

            <!-- ==================== Everest Max ==================== -->
            <Grid x:Name="PnlEverest">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <!-- Fixed (not Auto): keeps the sidebar/content start position
                             identical across devices regardless of which toolbar
                             buttons/breadcrumb happen to be visible for this device. -->
                        <RowDefinition Height="32"/>    <!-- toolbar -->
                        <RowDefinition Height="*"/>     <!-- 3-pane main -->
                    </Grid.RowDefinitions>

                    <!-- ── Toolbar ── -->
                    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <!-- Debug-only: open/close driver manually -->
                        <Button x:Name="BtnEvOpen"    Content="{loc:Get open_driver}"   Click="BtnEvOpen_Click"
                                Style="{StaticResource K2IconAccentButton}" Tag="&#xE768;" Visibility="Collapsed"/>
                        <Button x:Name="BtnEvClose"   Content="{loc:Get close_driver}"  Margin="8,0,0,0" Click="BtnEvClose_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE711;" Visibility="Collapsed"/>
                        <!-- Debug-only: AP controls -->
                        <Separator x:Name="SepEvApDbg" Margin="10,0" Visibility="Collapsed"/>
                        <Button x:Name="BtnEvApOn"  Content="AP ON"  Padding="10,4"
                                Click="BtnEvApOn_Click"  Visibility="Collapsed"/>
                        <Button x:Name="BtnEvApOff" Content="AP OFF" Padding="10,4" Margin="6,0,0,0"
                                Click="BtnEvApOff_Click" Visibility="Collapsed"/>
                        <Separator x:Name="SepEvSdkDbg" Margin="10,0" Visibility="Collapsed"/>
                        <TextBlock x:Name="LblEvSdk" Margin="16,6,0,0" FontStyle="Italic" Foreground="#9A9AA2" Visibility="Collapsed"/>
                    </WrapPanel>

                    <!-- ── 3-pane: sidebar | device-image + bottom-panel ── -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>  <!-- sidebar -->
                            <ColumnDefinition Width="*"/>    <!-- right side -->
                            <ColumnDefinition Width="Auto"/> <!-- common actions (all devices) -->
                        </Grid.ColumnDefinitions>

                        <!-- Left sidebar: section navigation -->
                        <Border Grid.Column="0" Background="#111115" CornerRadius="6"
                                Margin="0,0,8,0" Padding="4">
                            <StackPanel>
                                <TextBlock Text="SECTIONS" FontSize="9" Foreground="#4A4A58"
                                           Margin="14,8,0,6" FontWeight="Bold"/>
                                <RadioButton x:Name="RbSecKeyMapping"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_key_binding}" GroupName="EvSections"
                                             IsChecked="True" Checked="EvSection_Changed"/>
                                <RadioButton x:Name="RbSecRgb"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get rgb_lighting}" GroupName="EvSections"
                                             Checked="EvSection_Changed"/>
                                <RadioButton x:Name="RbSecDial"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="Display Dial" GroupName="EvSections"
                                             Checked="EvSection_Changed"/>
                                <RadioButton x:Name="RbSecSettings"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_settings}" GroupName="EvSections"
                                             Checked="EvSection_Changed"/>
                                <!-- Debug-only sections -->
                                <Separator x:Name="SepSectionDbg" Style="{StaticResource K2SideSeparator}"
                                           Margin="8,8" Visibility="Collapsed"/>
                                <RadioButton x:Name="RbSecUsb"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get usb_recorder}" GroupName="EvSections"
                                             Visibility="Collapsed" Checked="EvSection_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- Right: device image (top) + settings panel (bottom) -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" MinHeight="160"/>  <!-- device -->
                                <RowDefinition Height="Auto"/>               <!-- settings -->
                            </Grid.RowDefinitions>

                            <!-- Device image with interactive overlay -->
                            <Border Grid.Row="0" Background="#18181C" CornerRadius="6" Padding="8">
                                <DockPanel>
                                <StackPanel x:Name="SpEvLayout" Orientation="Horizontal"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- +20% zoom on request: LayoutTransform (not RenderTransform)
                                             so the Grid/Border around it re-measures at the scaled size
                                             and WPF's hit-testing keeps mapping clicks to the right Button
                                             automatically — no changes needed to KeyDef X/Y/W/H math. -->
                                        <StackPanel.LayoutTransform>
                                            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                        </StackPanel.LayoutTransform>
                                        <!-- Left column: dock overlay + keyboard body -->
                                        <Grid x:Name="GrdEvKeyColumn">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Canvas x:Name="CvsEvKeyboard" Grid.Row="1"
                                                    Width="642" Height="260" ClipToBounds="True">
                                                <Canvas.Background>
                                                    <ImageBrush x:Name="BrushEvKeyBg" ImageSource="Assets/keybg.png" Stretch="Fill"/>
                                                </Canvas.Background>
                                            </Canvas>
                                            <!-- Dock overlay: keytop art + a transparent Canvas holding the
                                                 clickable hotspots (4 media buttons + 2 crown rotation buttons,
                                                 the latter positioned above the artwork via negative Canvas.Top).
                                                 GrdEvDock keeps the Left/Right alignment toggle previously on
                                                 ImgEvDock (see UpdateKeyboardLayout), so the hotspots follow it. -->
                                            <Grid x:Name="GrdEvDock" Grid.Row="0" Width="200"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,-32" Panel.ZIndex="1"
                                                  Visibility="Collapsed">
                                                <Image x:Name="ImgEvDock" Source="Assets/keytop.png" Stretch="Uniform"/>
                                                <Canvas x:Name="CvsEvDock" Width="200" Height="64"/>
                                            </Grid>
                                        </Grid>
                                        <!-- Numpad + display keys -->
                                        <Canvas x:Name="CvsEvNumpad" Width="166" Height="260"
                                                ClipToBounds="True" Margin="6,0,0,0" VerticalAlignment="Bottom">
                                            <Canvas.Background>
                                                <ImageBrush x:Name="BrushEvBoardRight" ImageSource="Assets/board_right.png" Stretch="Fill"/>
                                            </Canvas.Background>
                                        </Canvas>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Bottom settings panel: sections switch here. Fixed Height (not
                                 Auto) so the panel doesn't resize/jump when switching between
                                 sections of very different natural height (Key Binding/RGB vs.
                                 Display Dial vs. USB Recorder) — a ScrollViewer absorbs any
                                 section taller than the fixed area instead of clipping it. -->
                            <Border Grid.Row="1" Background="#14141A"
                                    BorderBrush="#2A2A32" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,8,0,0"
                                    Height="270">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>  <!-- active section content -->
                                        <RowDefinition Height="Auto"/>  <!-- debug SDK log -->
                                    </Grid.RowDefinitions>

                                    <!-- ─── All section panels (one visible at a time) ─── -->
                                    <Grid Grid.Row="0">

                                        <!-- ── KEY BINDING (mapped keys + HW capture utility for the
                                             media dock / crown / display-key hotspots drawn on the
                                             device graphic above) ── -->
                                        <StackPanel x:Name="PnlSecKeyMapping">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="170"/>
                                                </Grid.ColumnDefinitions>
                                                <ListView Grid.Column="0" x:Name="LvEvKeys" MaxHeight="180" Margin="0,0,8,0">
                                                    <ListView.ItemContainerStyle>
                                                        <Style TargetType="ListViewItem">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                    <Setter Property="Background" Value="#900000"/>
                                                                    <Setter Property="Foreground" Value="#10302F"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListView.ItemContainerStyle>
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Display}" FontFamily="Consolas" Padding="2"/>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                                    <Button x:Name="BtnEvCapture" Content="{loc:Get ev_capture_key}"
                                                            Click="BtnEvCapture_Click"
                                                            Style="{StaticResource K2IconButton}" Tag="&#xE765;"
                                                            HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                                                    <Button x:Name="BtnEvMapKeys" Content="{loc:Get remap_keys}"
                                                            Click="BtnEvMapKeys_Click"
                                                            Style="{StaticResource K2IconButton}" Tag="&#xE8CB;"
                                                            HorizontalAlignment="Stretch" Margin="0,0,0,10"
                                                            Visibility="Collapsed"/>
                                                    <Separator x:Name="SepEvMapKeysDbg" Style="{StaticResource K2SideSeparator}"
                                                               Margin="0,0,0,10" Visibility="Collapsed"/>
                                                    <Button x:Name="BtnEvConfig" Content="{loc:Get ev_configure}"
                                                            Padding="8,4" Click="BtnEvConfig_Click"
                                                            HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                                                    <Button x:Name="BtnEvRemove" Content="{loc:Get ev_remove}"
                                                            Padding="8,4" Click="BtnEvRemove_Click"
                                                            HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                            </Grid>
                                            <Separator Style="{StaticResource K2SideSeparator}" Margin="0,10,0,8"/>
                                            <WrapPanel Orientation="Horizontal">
                                                <Button x:Name="BtnCaptureHwKey" Content="{loc:Get dock_capture_hw}"
                                                        Padding="8,2" Click="BtnCaptureHwKey_Click"
                                                        Style="{StaticResource K2IconButton}" Tag="&#xE765;"/>
                                                <TextBlock x:Name="LblCapturedKey" Text="" Margin="8,0,0,0"
                                                           VerticalAlignment="Center" Foreground="#900000"/>
                                            </WrapPanel>
                                        </StackPanel>

                                        <!-- ── RGB & LIGHTING ── -->
                                        <ScrollViewer x:Name="PnlSecRgb" Visibility="Collapsed"
                                                      MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <!-- Preset effects row 1 -->
                                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <TextBlock Text="{loc:Get rgb_effect}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <ComboBox x:Name="CbEvEffect" Width="140" Margin="0,0,12,0"
                                                              SelectionChanged="CbEvEffect_SelectionChanged"
                                                              DropDownOpened="CbEvEffect_DropDownOpened"
                                                              DropDownClosed="CbEvEffect_DropDownClosed"/>
                                                    <TextBlock Text="{loc:Get rgb_speed}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <ComboBox x:Name="CbEvSpeed" Width="95" Margin="0,0,12,0"
                                                              SelectionChanged="CbEvEffectParam_Changed"/>
                                                    <TextBlock Text="{loc:Get rgb_direction}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <ComboBox x:Name="CbEvDirection" Width="130" Margin="0,0,12,0"
                                                              SelectionChanged="CbEvEffectParam_Changed"/>
                                                    <CheckBox x:Name="CkEvRainbow" Content="{loc:Get rgb_rainbow}" Margin="0,0,10,0"
                                                              Click="CkEvRainbow_Click" ToolTip="{loc:Get rgb_rainbow_tip}"/>
                                                    <CheckBox x:Name="CkEvSync" Content="{loc:Get rgb_sync_profiles}"
                                                              Click="CkEvSync_Click"/>
                                                </WrapPanel>
                                                <!-- Preset effects row 2: colors + brightness + actions -->
                                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock Text="{loc:Get rgb_primary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <Button x:Name="BtnEvColor1" Width="40" Height="22"
                                                            Background="#900000" BorderThickness="2"
                                                            BorderBrush="#3A3A40" Click="BtnEvColor_Click" Tag="1"
                                                            Margin="0,0,10,0"/>
                                                    <StackPanel x:Name="PnlEvColor2" Orientation="Horizontal" Margin="0,0,10,0">
                                                        <TextBlock Text="{loc:Get rgb_secondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <Button x:Name="BtnEvColor2" Width="40" Height="22"
                                                                Background="#1A1A1E" BorderThickness="2"
                                                                BorderBrush="#3A3A40" Click="BtnEvColor_Click" Tag="2"/>
                                                    </StackPanel>
                                                    <StackPanel x:Name="PnlEvColor3" Orientation="Horizontal"
                                                                Margin="0,0,10,0" Visibility="Collapsed">
                                                        <TextBlock Text="{loc:Get rgb_tertiary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <Button x:Name="BtnEvColor3" Width="40" Height="22"
                                                                Background="#1A1A1E" BorderThickness="2"
                                                                BorderBrush="#3A3A40" Click="BtnEvColor_Click" Tag="3"/>
                                                    </StackPanel>
                                                    <Button x:Name="BtnEvLightOff"   Content="OFF"               Padding="6,2" Margin="0,0,4,0" Click="BtnEvLightOff_Click"/>
                                                    <Button x:Name="BtnEvLightOn"    Content="ON"                Padding="6,2" Margin="0,0,4,0" Click="BtnEvLightOn_Click"/>
                                                    <Button x:Name="BtnEvLightReset" Content="{loc:Get reset}"   Padding="6,2" Margin="0,0,4,0" Click="BtnEvLightReset_Click"/>
                                                    <Button x:Name="BtnEvLightSave"  Content="{loc:Get save}"    Padding="6,2" Click="BtnEvLightSave_Click"
                                                            ToolTip="Makes the applied effect permanent (survives unplug/restart)."/>
                                                </WrapPanel>
                                                <!-- Per-key custom lighting section -->
                                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{loc:Get custom_lighting}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <TextBlock Text="{loc:Get custom_paint_hint}"
                                                           Foreground="#9A9AA2" FontStyle="Italic"
                                                           TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <CheckBox x:Name="CkCustomPaint" Content="{loc:Get custom_paint_mode}"
                                                              Foreground="White" Margin="0,0,12,0"
                                                              Checked="CkCustomPaint_Checked"
                                                              Unchecked="CkCustomPaint_Checked"/>
                                                    <TextBlock Text="{loc:Get custom_color}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <Button x:Name="BtnCustomBrushColor" Width="40" Height="22"
                                                            Background="#900000" BorderThickness="2"
                                                            BorderBrush="#3A3A40" Click="BtnCustomBrushColor_Click"/>
                                                </WrapPanel>
                                                <WrapPanel Orientation="Horizontal">
                                                    <Button x:Name="BtnCustomApply"   Content="{loc:Get apply_to_device}"  Padding="8,2" Margin="0,0,4,0" Click="BtnCustomApply_Click"  Style="{StaticResource K2IconAccentButton}" Tag="&#xE73E;"/>
                                                    <Button x:Name="BtnCustomRead"    Content="{loc:Get read_from_device}" Padding="8,2" Margin="0,0,4,0" Click="BtnCustomRead_Click"    Style="{StaticResource K2IconButton}"       Tag="&#xE72C;"/>
                                                    <Button x:Name="BtnCustomFillAll" Content="{loc:Get custom_fill_all}" Padding="8,2" Margin="0,0,4,0" Click="BtnCustomFillAll_Click" Style="{StaticResource K2IconButton}"       Tag="&#xE771;"/>
                                                    <Button x:Name="BtnCustomClear"   Content="{loc:Get custom_clear}"    Padding="8,2"                   Click="BtnCustomClear_Click"   Style="{StaticResource K2IconButton}"       Tag="&#xE74D;"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <!-- ── DISPLAY DIAL ── -->
                                        <StackPanel x:Name="PnlSecDial" Visibility="Collapsed">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Left: show/hide menu pages — 2 columns x 4 rows, toggle-switch rows -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{loc:Get dial_pages_visible}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <CheckBox x:Name="CkDialClock"    Style="{StaticResource K2ToggleRow}" Tag="&#xEC92;" Content="{loc:Get dial_clock}"      Click="CkDial_Click"/>
                                                            <CheckBox x:Name="CkDialProfile"  Style="{StaticResource K2ToggleRow}" Tag="&#xE77B;" Content="{loc:Get dial_profile}"    Click="CkDial_Click"/>
                                                            <CheckBox x:Name="CkDialLighting" Style="{StaticResource K2ToggleRow}" Tag="&#xEA80;" Content="{loc:Get dial_lighting}"   Click="CkDial_Click"/>
                                                            <CheckBox x:Name="CkDialVolume"   Style="{StaticResource K2ToggleRow}" Tag="&#xE994;" Content="{loc:Get dial_volume}"     Click="CkDial_Click"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <CheckBox x:Name="CkDialBright"   Style="{StaticResource K2ToggleRow}" Tag="&#xE706;" Content="{loc:Get dial_brightness}" Click="CkDial_Click"/>
                                                            <CheckBox x:Name="CkDialPCInfo"   Style="{StaticResource K2ToggleRow}" Tag="&#xE977;" Content="{loc:Get dial_pcinfo}"     Click="CkDial_Click"/>
                                                            <CheckBox x:Name="CkDialAPM"      Style="{StaticResource K2ToggleRow}" Tag="&#xE916;" Content="{loc:Get dial_apm}"        Click="CkDial_Click"/>
                                                            <CheckBox x:Name="CkDialCustom"   Style="{StaticResource K2ToggleRow}" Tag="&#xE765;" Content="{loc:Get dial_custom}"     Click="CkDial_Click"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>

                                                <!-- Right: clock type, screensaver, turn-off, menu color, actions -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{loc:Get dial_clock_section}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="{loc:Get dial_clock_label}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <ComboBox x:Name="CbDialClockType" Width="70" Margin="0,0,16,0"
                                                                  SelectionChanged="CbDialClockType_SelectionChanged"/>
                                                        <TextBlock Text="{loc:Get dial_clock_style_label}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <ComboBox x:Name="CbDialClockStyle" Width="80"
                                                                  SelectionChanged="CbDialClockStyle_SelectionChanged"/>
                                                    </WrapPanel>

                                                    <TextBlock Text="{loc:Get dial_screensaver_section}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <!-- Fixed-width label column so both rows' entries share the same left edge -->
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="20"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <CheckBox Grid.Row="0" Grid.Column="0" x:Name="CkDialScreenSaverEnable"
                                                                  Content="{loc:Get dial_screensaver}" VerticalAlignment="Center"
                                                                  ToolTip="{loc:Get dial_screensaver_enable_tip}"
                                                                  Click="CkDialScreenSaverEnable_Click"/>
                                                        <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TxtDialScreenSaver" Margin="0,0,6,0"
                                                                  TextChanged="TxtDialScreenSaver_TextChanged"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Get unit_seconds}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{loc:Get dial_screensaver_function_label}"
                                                                   VerticalAlignment="Center" Margin="6,0,6,0"/>
                                                        <ComboBox Grid.Row="0" Grid.Column="4" x:Name="CbDialScreenSaverFunction"
                                                                  HorizontalAlignment="Left" Width="150"
                                                                  SelectionChanged="CbDialScreenSaverFunction_SelectionChanged"/>

                                                        <CheckBox Grid.Row="1" Grid.Column="0" x:Name="CkDialTurnOffEnable"
                                                                  Content="{loc:Get dial_autooff}" VerticalAlignment="Center" Margin="0,8,0,0"
                                                                  ToolTip="{loc:Get dial_turnoff_enable_tip}"
                                                                  Click="CkDialTurnOffEnable_Click"/>
                                                        <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TxtDialTurnOff" Margin="0,8,6,0"
                                                                  TextChanged="TxtDialTurnOff_TextChanged"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{loc:Get unit_seconds}"
                                                                   VerticalAlignment="Center" Margin="0,8,0,0"/>
                                                    </Grid>

                                                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="{loc:Get dial_menu_color}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <Button x:Name="BtnDialMenuColor" Width="40" Height="22"
                                                                Background="#F3CC23" BorderThickness="2"
                                                                BorderBrush="#3A3A40" Click="BtnDialMenuColor_Click"/>
                                                    </WrapPanel>

                                                    <WrapPanel Orientation="Horizontal">
                                                        <Button x:Name="BtnDialApply" Content="{loc:Get apply_to_device}"
                                                                Padding="8,2" Margin="0,0,4,0" Click="BtnDialApply_Click"
                                                                Style="{StaticResource K2IconAccentButton}" Tag="&#xE73E;"/>
                                                        <Button x:Name="BtnDialRead" Content="{loc:Get read_from_device}"
                                                                Padding="8,2" Margin="0,0,4,0" Click="BtnDialRead_Click"
                                                                Style="{StaticResource K2IconButton}" Tag="&#xE72C;"/>
                                                        <Button x:Name="BtnDialReset" Content="{loc:Get reset_display_dial}"
                                                                Padding="8,2" Click="BtnDialReset_Click"
                                                                Style="{StaticResource K2IconButton}" Tag="&#xE777;"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>

                                        <!-- ── SETTINGS ── -->
                                        <StackPanel x:Name="PnlSecSettings" Visibility="Collapsed">
                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <CheckBox x:Name="CkSettingsSync" Content="{loc:Get settings_sync_profiles}"
                                                          Click="CkSettingsSync_Click"/>
                                            </WrapPanel>

                                            <TextBlock Text="{loc:Get settings_game_mode}" FontWeight="SemiBold" Margin="0,0,0,6"
                                                       ToolTip="{loc:Get settings_game_mode_tip}"/>
                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <CheckBox x:Name="CkGameModeShiftTab" Content="{loc:Get settings_disable_shift_tab}"
                                                          Margin="0,0,12,0" Click="CkGameMode_Click"/>
                                                <CheckBox x:Name="CkGameModeAltF4" Content="{loc:Get settings_disable_alt_f4}"
                                                          Margin="0,0,12,0" Click="CkGameMode_Click"/>
                                                <CheckBox x:Name="CkGameModeWinKey" Content="{loc:Get settings_disable_win_key}"
                                                          Margin="0,0,12,0" Click="CkGameMode_Click"/>
                                                <CheckBox x:Name="CkGameModeAltTab" Content="{loc:Get settings_disable_alt_tab}"
                                                          Click="CkGameMode_Click"/>
                                            </WrapPanel>

                                            <TextBlock Text="{loc:Get settings_indicator_leds}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <CheckBox x:Name="CkCoreIndicatorLed" Content="{loc:Get settings_enable_core_led}"
                                                          Click="CkCoreIndicatorLed_Click"/>
                                            </WrapPanel>

                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="{loc:Get settings_keyboard_color}" VerticalAlignment="Center"
                                                           FontWeight="SemiBold" Margin="0,0,6,0"/>
                                                <ComboBox x:Name="CbSettingsKeyboardColor" Width="120"
                                                          SelectionChanged="CbSettingsKeyboardColor_SelectionChanged"/>
                                            </WrapPanel>

                                            <TextBlock Text="{loc:Get settings_keycap_group}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="{loc:Get settings_keycap_color}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <RadioButton x:Name="RbEvKeycapBlack" Content="{loc:Get settings_keycap_black}"
                                                             GroupName="EvKeycapColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbEvKeycapColor_Checked"/>
                                                <RadioButton x:Name="RbEvKeycapWhite" Content="{loc:Get settings_keycap_white}"
                                                             GroupName="EvKeycapColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbEvKeycapColor_Checked"/>
                                                <RadioButton x:Name="RbEvKeycapCustom" Content="{loc:Get settings_keycap_custom}"
                                                             GroupName="EvKeycapColor" VerticalAlignment="Center"
                                                             Margin="0,0,6,0" Checked="RbEvKeycapColor_Checked"/>
                                                <Button x:Name="BtnEvKeycapCustomColor" Width="32" Height="20"
                                                        Background="#404040" BorderThickness="2" BorderBrush="#3A3A40"
                                                        Click="BtnEvKeycapCustomColor_Click"/>
                                            </WrapPanel>
                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="{loc:Get settings_keycap_text_color}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <RadioButton x:Name="RbEvKeycapTextBlack" Content="{loc:Get settings_keycap_black}"
                                                             GroupName="EvKeycapTextColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbEvKeycapTextColor_Checked"/>
                                                <RadioButton x:Name="RbEvKeycapTextWhite" Content="{loc:Get settings_keycap_white}"
                                                             GroupName="EvKeycapTextColor" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Checked="RbEvKeycapTextColor_Checked"/>
                                                <RadioButton x:Name="RbEvKeycapTextCustom" Content="{loc:Get settings_keycap_custom}"
                                                             GroupName="EvKeycapTextColor" VerticalAlignment="Center"
                                                             Margin="0,0,6,0" Checked="RbEvKeycapTextColor_Checked"/>
                                                <Button x:Name="BtnEvKeycapTextColor" Width="32" Height="20"
                                                        Background="White" BorderThickness="2" BorderBrush="#3A3A40"
                                                        Click="BtnEvKeycapTextColor_Click"/>
                                            </WrapPanel>
                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{loc:Get settings_keycap_style}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <ComboBox x:Name="CbEvKeycapStyle" Width="230"
                                                          SelectionChanged="CbEvKeycapStyle_SelectionChanged"/>
                                            </WrapPanel>
                                            <TextBlock Text="{loc:Get settings_keycap_hint}" Foreground="#9A9AA2"
                                                       TextWrapping="Wrap" Margin="0,0,0,10" FontSize="12"/>

                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="{loc:Get ev_layout}" VerticalAlignment="Center"
                                                           FontWeight="SemiBold" Margin="0,0,6,0"/>
                                                <ComboBox x:Name="CbEvKeyboardLayout" Width="200" Margin="0,0,16,0"/>
                                            </WrapPanel>

                                            <Button x:Name="BtnSettingsFactoryReset" Content="{loc:Get settings_factory_reset}"
                                                    Padding="8,2" Click="BtnSettingsFactoryReset_Click"
                                                    Style="{StaticResource K2IconButton}" Tag="&#xE777;"/>
                                        </StackPanel>

                                        <!-- ── USB RECORDER (debug only) ── -->
                                        <Grid x:Name="PnlSecUsb" Visibility="Collapsed">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="{loc:Get usb_interface}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <ComboBox x:Name="CbUsbInterface" Width="200" Margin="0,0,8,0"/>
                                                <Button x:Name="BtnUsbRefresh" Content="{loc:Get usb_detect}" Padding="6,2"
                                                        Margin="0,0,8,0" Click="BtnUsbRefresh_Click"
                                                        Style="{StaticResource K2IconButton}" Tag="&#xE72C;"/>
                                                <TextBlock Text="{loc:Get usb_label}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBox x:Name="TxtUsbLabel" Width="120" Margin="0,0,8,0" Text="basecamp"/>
                                                <Button x:Name="BtnUsbRecord" Content="Start" Padding="8,2"
                                                        Click="BtnUsbRecord_Click"
                                                        Style="{StaticResource K2IconAccentButton}" Tag="&#xE7C8;"/>
                                            </WrapPanel>
                                            <TextBlock Grid.Row="1" x:Name="LblUsbStatus" Margin="0,0,0,4"
                                                       FontStyle="Italic" Foreground="#9A9AA2"
                                                       Text="{loc:Get usb_ready}"/>
                                            <Expander Grid.Row="2" Header="{loc:Get usb_results}" IsExpanded="False"
                                                      x:Name="ExpUsbResults" Visibility="Collapsed">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="100"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBox Grid.Row="0" x:Name="TxtUsbResults"
                                                             IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                                             VerticalScrollBarVisibility="Auto"
                                                             HorizontalScrollBarVisibility="Auto"
                                                             TextWrapping="NoWrap" AcceptsReturn="True"/>
                                                    <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                        <Button x:Name="BtnUsbSave"       Content="{loc:Get usb_save_report}" Padding="6,2" Margin="0,0,6,0" Click="BtnUsbSave_Click"/>
                                                        <Button x:Name="BtnUsbOpenFolder" Content="{loc:Get act_folder}"      Padding="6,2"                   Click="BtnUsbOpenFolder_Click"/>
                                                    </WrapPanel>
                                                </Grid>
                                            </Expander>
                                        </Grid>

                                    </Grid><!-- end section panels grid -->

                                    <!-- SDK Log: debug only, always at bottom of settings panel -->
                                    <GroupBox Grid.Row="1" x:Name="GbEvLog" Header="{loc:Get ev_sdk_log}"
                                              Visibility="Collapsed" Margin="0,10,0,0">
                                        <TextBox x:Name="TxtEvLog"
                                                 IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 TextWrapping="NoWrap" AcceptsReturn="True"
                                                 MaxHeight="100"/>
                                    </GroupBox>
                                </Grid>
                                </ScrollViewer>
                            </Border><!-- end settings panel -->

                        </Grid><!-- end right column -->

                        <!-- Common actions (same rule for all devices): uniform width/height,
                             vertical stack, grouped Profile / Import / Device -->
                        <Border Grid.Column="2" Background="#111115" CornerRadius="6"
                                Margin="8,0,0,0" Padding="10" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{loc:Get profile}" Style="{StaticResource K2SideGroupHeader}"/>
                                <ComboBox x:Name="CbEvProfile" Style="{StaticResource K2SideActionCombo}"
                                          SelectionChanged="CbEvProfile_SelectionChanged"/>
                                <Button x:Name="BtnEvRenameProfile" Content="{loc:Get rename_profile}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8D3;"
                                        Click="BtnEvRenameProfile_Click"/>
                                <Button x:Name="BtnEvDeleteProfile" Content="{loc:Get delete_profile}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE74D;"
                                        Click="BtnEvDeleteProfile_Click"/>

                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                <TextBlock Text="{loc:Get import}" Style="{StaticResource K2SideGroupHeader}"/>
                                <Button x:Name="BtnEvImportXml" Content="{loc:Get dp_import_xml}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8E5;"
                                        Click="BtnEvImportXml_Click"/>
                                <Button x:Name="BtnEvImportBc" Content="{loc:Get import_bc}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8B5;"
                                        Click="BtnEvImportBc_Click"/>

                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                <TextBlock Text="{loc:Get export}" Style="{StaticResource K2SideGroupHeader}"/>
                                <Button x:Name="BtnEvExportProfiles" Content="{loc:Get export_profiles_btn}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE896;"
                                        Click="BtnEvExportProfiles_Click"/>

                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                <TextBlock Text="{loc:Get device}" Style="{StaticResource K2SideGroupHeader}"/>
                                <Button x:Name="BtnEvRename" Content="{loc:Get rename_device}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8D3;"
                                        Click="BtnEvRename_Click"/>

                                <StackPanel x:Name="PnlEvDebugGroup" Visibility="Collapsed">
                                    <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                    <TextBlock Text="{loc:Get debug_group}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <Button x:Name="BtnEvRefresh" Content="{loc:Get refresh}"
                                            Style="{StaticResource K2SideActionButton}" Tag="&#xE72C;"
                                            Click="BtnEvRefresh_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid><!-- end 3-pane -->
                </Grid>
            </Grid><!-- end PnlEverest -->

            <!-- ==================== MacroPad ==================== -->
            <Grid x:Name="PnlMacroPad" Visibility="Collapsed">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>    <!-- toolbar (fixed, see PnlEverest) -->
                        <RowDefinition Height="*"/>     <!-- main area -->
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <!-- Debug-only: open/close driver manually -->
                        <Button x:Name="BtnOpen"    Content="{loc:Get open_driver}"     Click="BtnOpen_Click"
                                Style="{StaticResource K2IconAccentButton}" Tag="&#xE768;" Visibility="Collapsed"/>
                        <Button x:Name="BtnClose"   Content="{loc:Get close_driver}"    Margin="8,0,0,0" Click="BtnClose_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE711;" Visibility="Collapsed"/>
                        <!-- Debug-only: AP controls -->
                        <Button x:Name="BtnApOn"   Content="AP Enable ON"  Padding="10,4" Visibility="Collapsed" Click="BtnApOn_Click"/>
                        <Button x:Name="BtnApOff"  Content="AP Enable OFF" Padding="10,4" Margin="6,0,0,0" Visibility="Collapsed" Click="BtnApOff_Click"/>
                        <Separator x:Name="SepMpApDbg" Margin="10,0" Visibility="Collapsed"/>
                        <!-- Debug-only: remap keys (see project rule) -->
                        <Button x:Name="BtnMapKeys" Content="{loc:Get remap_keys}" Click="BtnMapKeys_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE765;" Visibility="Collapsed"/>
                        <TextBlock x:Name="LblSdk" Margin="16,6,0,0" FontStyle="Italic" Foreground="#9A9AA2" Visibility="Collapsed"/>
                    </WrapPanel>

                    <!-- ── sidebar (specific) | canvas + settings | common actions | debug ── -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>  <!-- sidebar -->
                            <ColumnDefinition Width="*"/>    <!-- canvas + settings -->
                            <ColumnDefinition Width="Auto"/> <!-- common actions (all devices) -->
                            <ColumnDefinition Width="Auto"/> <!-- debug -->
                        </Grid.ColumnDefinitions>

                        <!-- Left sidebar: device-specific section navigation -->
                        <Border Grid.Column="0" Background="#111115" CornerRadius="6"
                                Margin="0,0,8,0" Padding="4">
                            <StackPanel>
                                <TextBlock Text="SECTIONS" FontSize="9" Foreground="#4A4A58"
                                           Margin="14,8,0,6" FontWeight="Bold"/>
                                <RadioButton x:Name="RbMpSecKeyBinding"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_key_binding}" GroupName="MpSections"
                                             IsChecked="True" Checked="MpSection_Changed"/>
                                <RadioButton x:Name="RbMpSecOrientation"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get positioning}" GroupName="MpSections"
                                             Checked="MpSection_Changed"/>
                                <RadioButton x:Name="RbMpSecLed"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get led_lighting}" GroupName="MpSections"
                                             Checked="MpSection_Changed"/>
                                <RadioButton x:Name="RbMpSecSettings"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_settings}" GroupName="MpSections"
                                             Checked="MpSection_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- Middle: keys canvas (top) + settings panel (bottom).
                             No margin here (matches PnlEverest): the gap before the
                             common-actions column comes from that column's own left
                             margin, so this box is exactly as wide as Everest's. -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" MinHeight="160"/>  <!-- device -->
                                <RowDefinition Height="Auto"/>               <!-- settings -->
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#18181C" CornerRadius="6" Padding="8">
                                <Canvas x:Name="CvsMacroKeys" Width="510" Height="370" ClipToBounds="True"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas.Background>
                                        <ImageBrush ImageSource="Assets/mkd_bg.png" Stretch="Fill"/>
                                    </Canvas.Background>
                                </Canvas>
                            </Border>

                            <!-- Bottom settings panel: sections switch here. Fixed Height (not
                                 Auto) so the panel doesn't resize/jump when switching between
                                 Key Binding / Orientation / LED Lighting. -->
                            <Border Grid.Row="1" Background="#14141A"
                                    BorderBrush="#2A2A32" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,8,0,0"
                                    Height="130">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid>

                                    <!-- ── KEY BINDING (keys are configured directly on the grid above) ── -->
                                    <StackPanel x:Name="PnlMpSecKeyBinding" Orientation="Horizontal">
                                        <TextBlock Text="{loc:Get key_binding_hint}" Foreground="#9A9AA2"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- ── ORIENTATION ── -->
                                    <StackPanel x:Name="PnlMpSecOrientation" Orientation="Horizontal" Visibility="Collapsed">
                                        <TextBlock Text="{loc:Get positioning}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="CbMacroRotation" Width="190"
                                                  SelectionChanged="CbMacroRotation_SelectionChanged"/>
                                    </StackPanel>

                                    <!-- ── LED LIGHTING ── -->
                                    <Grid x:Name="PnlMpSecLed" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,6">
                                            <TextBlock Text="{loc:Get rgb_effect}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox x:Name="CbMacroEffect" Width="140"
                                                      SelectionChanged="CbMacroEffect_SelectionChanged"
                                                      DropDownOpened="CbMacroEffect_DropDownOpened"
                                                      DropDownClosed="CbMacroEffect_DropDownClosed"/>
                                        </StackPanel>
                                        <StackPanel x:Name="PnlMpSpeed" Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,6">
                                            <TextBlock Text="{loc:Get rgb_speed}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox x:Name="CbMacroSpeed" Width="90"
                                                      SelectionChanged="CbMacroEffectParam_Changed"/>
                                        </StackPanel>
                                        <StackPanel x:Name="PnlMpDirection" Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,6">
                                            <TextBlock Text="{loc:Get rgb_direction}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox x:Name="CbMacroDirection" Width="180"
                                                      SelectionChanged="CbMacroEffectParam_Changed"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal" Margin="0,0,16,6">
                                            <CheckBox x:Name="CkMacroRainbow" Content="{loc:Get rgb_rainbow}" Margin="0,0,10,0"
                                                      VerticalAlignment="Center" Click="CkMacroRainbow_Click" ToolTip="{loc:Get rgb_rainbow_tip}"/>
                                            <CheckBox x:Name="CkMacroSync" Content="{loc:Get led_sync_profiles}"
                                                      VerticalAlignment="Center" Click="CkMacroSync_Click"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" Margin="0,0,0,6">
                                            <Button x:Name="BtnMacroLightOff"   Content="{loc:Get led_backlight_off}"  Padding="8,3" Margin="0,0,6,0" Click="BtnMacroLightOff_Click"/>
                                            <Button x:Name="BtnMacroLightOn"    Content="{loc:Get led_backlight_on}"   Padding="8,3" Margin="0,0,6,0" Click="BtnMacroLightOn_Click"/>
                                            <Button x:Name="BtnMacroLightReset" Content="{loc:Get led_reset_effects}"  Padding="8,3" Margin="0,0,6,0" Click="BtnMacroLightReset_Click"/>
                                            <Button x:Name="BtnMacroLightSave"  Content="{loc:Get led_save_flash}"     Padding="8,3" Click="BtnMacroLightSave_Click"
                                                    ToolTip="Makes the applied effect permanent (survives unplug/restart)."/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,4,16,0">
                                            <TextBlock Text="{loc:Get rgb_primary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <Button x:Name="BtnMacroColor1" Width="50" Height="26"
                                                    Background="#900000" BorderThickness="2"
                                                    BorderBrush="#3A3A40" Click="BtnMacroColor_Click" Tag="1"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,4,16,0">
                                            <TextBlock Text="{loc:Get rgb_secondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <Button x:Name="BtnMacroColor2" Width="50" Height="26"
                                                    Background="#1A1A1E" BorderThickness="2"
                                                    BorderBrush="#3A3A40" Click="BtnMacroColor_Click" Tag="2"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="0,4,16,0">
                                            <TextBlock Text="{loc:Get rgb_tertiary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <Button x:Name="BtnMacroColor3" Width="50" Height="26"
                                                    Background="#1A1A1E" BorderThickness="2"
                                                    BorderBrush="#3A3A40" Click="BtnMacroColor_Click" Tag="3"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- ── SETTINGS (keycap appearance, same as Everest) ── -->
                                    <StackPanel x:Name="PnlMpSecSettings" Visibility="Collapsed">
                                        <TextBlock Text="{loc:Get settings_keycap_group}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="{loc:Get settings_keycap_color}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <RadioButton x:Name="RbMpKeycapBlack" Content="{loc:Get settings_keycap_black}"
                                                         GroupName="MpKeycapColor" VerticalAlignment="Center"
                                                         Margin="0,0,10,0" Checked="RbMpKeycapColor_Checked"/>
                                            <RadioButton x:Name="RbMpKeycapWhite" Content="{loc:Get settings_keycap_white}"
                                                         GroupName="MpKeycapColor" VerticalAlignment="Center"
                                                         Margin="0,0,10,0" Checked="RbMpKeycapColor_Checked"/>
                                            <RadioButton x:Name="RbMpKeycapCustom" Content="{loc:Get settings_keycap_custom}"
                                                         GroupName="MpKeycapColor" VerticalAlignment="Center"
                                                         Margin="0,0,6,0" Checked="RbMpKeycapColor_Checked"/>
                                            <Button x:Name="BtnMpKeycapCustomColor" Width="32" Height="20"
                                                    Background="#404040" BorderThickness="2" BorderBrush="#3A3A40"
                                                    Click="BtnMpKeycapCustomColor_Click"/>
                                        </WrapPanel>
                                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="{loc:Get settings_keycap_text_color}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <RadioButton x:Name="RbMpKeycapTextBlack" Content="{loc:Get settings_keycap_black}"
                                                         GroupName="MpKeycapTextColor" VerticalAlignment="Center"
                                                         Margin="0,0,10,0" Checked="RbMpKeycapTextColor_Checked"/>
                                            <RadioButton x:Name="RbMpKeycapTextWhite" Content="{loc:Get settings_keycap_white}"
                                                         GroupName="MpKeycapTextColor" VerticalAlignment="Center"
                                                         Margin="0,0,10,0" Checked="RbMpKeycapTextColor_Checked"/>
                                            <RadioButton x:Name="RbMpKeycapTextCustom" Content="{loc:Get settings_keycap_custom}"
                                                         GroupName="MpKeycapTextColor" VerticalAlignment="Center"
                                                         Margin="0,0,6,0" Checked="RbMpKeycapTextColor_Checked"/>
                                            <Button x:Name="BtnMpKeycapTextColor" Width="32" Height="20"
                                                    Background="White" BorderThickness="2" BorderBrush="#3A3A40"
                                                    Click="BtnMpKeycapTextColor_Click"/>
                                        </WrapPanel>
                                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{loc:Get settings_keycap_style}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox x:Name="CbMpKeycapStyle" Width="230"
                                                      SelectionChanged="CbMpKeycapStyle_SelectionChanged"/>
                                        </WrapPanel>
                                        <TextBlock Text="{loc:Get settings_keycap_hint}" Foreground="#9A9AA2"
                                                   TextWrapping="Wrap" Margin="0,0,0,4" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <!-- Common actions (same rule for all devices): uniform width/height,
                             vertical stack, grouped Profile / Import / Device.
                             Left-only margin (not on the device box) mirrors PnlEverest exactly,
                             so column 1 keeps the same width in both. The gap before the (normally
                             collapsed) debug column lives on that column's own left margin instead,
                             so it doesn't cost width here in the common (non-debug) case. -->
                        <Border Grid.Column="2" Background="#111115" CornerRadius="6"
                                Margin="8,0,0,0" Padding="10" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{loc:Get profile}" Style="{StaticResource K2SideGroupHeader}"/>
                                <ComboBox x:Name="CbProfile" Style="{StaticResource K2SideActionCombo}"
                                          SelectionChanged="CbProfile_SelectionChanged"/>
                                <Button x:Name="BtnMpRenameProfile" Content="{loc:Get rename_profile}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8D3;"
                                        Click="BtnMpRenameProfile_Click"/>
                                <Button x:Name="BtnMpDeleteProfile" Content="{loc:Get delete_profile}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE74D;"
                                        Click="BtnMpDeleteProfile_Click"/>

                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                <TextBlock Text="{loc:Get import}" Style="{StaticResource K2SideGroupHeader}"/>
                                <Button x:Name="BtnMpImportXml" Content="{loc:Get dp_import_xml}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8E5;"
                                        Click="BtnMpImportXml_Click"/>
                                <Button x:Name="BtnMpImportBc" Content="{loc:Get import_bc}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8B5;"
                                        Click="BtnMpImportBc_Click"/>

                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                <TextBlock Text="{loc:Get export}" Style="{StaticResource K2SideGroupHeader}"/>
                                <Button x:Name="BtnMpExportProfiles" Content="{loc:Get export_profiles_btn}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE896;"
                                        Click="BtnMpExportProfiles_Click"/>

                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                <TextBlock Text="{loc:Get device}" Style="{StaticResource K2SideGroupHeader}"/>
                                <Button x:Name="BtnMpRename" Content="{loc:Get rename_device}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8D3;"
                                        Click="BtnMpRename_Click"/>

                                <StackPanel x:Name="PnlMpDebugGroup" Visibility="Collapsed">
                                    <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                    <TextBlock Text="{loc:Get debug_group}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <Button x:Name="BtnRefresh" Content="{loc:Get refresh}"
                                            Style="{StaticResource K2SideActionButton}" Tag="&#xE72C;"
                                            Click="BtnRefresh_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Debug panel: visible only in debug mode -->
                        <Grid x:Name="PnlMpDebugRight" Grid.Column="3" Width="380" Visibility="Collapsed" Margin="8,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <GroupBox x:Name="GbMpDevices" Grid.Row="0" Header="{loc:Get mp_connected_devices}">
                                <ListView x:Name="LvDevices" Height="120">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Device"  Width="90"  DisplayMemberBinding="{Binding Label}"/>
                                            <GridViewColumn Header="{loc:Get dp_fw}"    Width="55"  DisplayMemberBinding="{Binding FirmwareVersion}"/>
                                            <GridViewColumn Header="VID"     Width="60"  DisplayMemberBinding="{Binding Vid}"/>
                                            <GridViewColumn Header="PID"     Width="60"  DisplayMemberBinding="{Binding Pid}"/>
                                            <GridViewColumn Header="Prof."   Width="45"  DisplayMemberBinding="{Binding CurrentProfile}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </GroupBox>
                            <GroupBox x:Name="GbMpLog" Grid.Row="1" Header="{loc:Get mp_event_log}" Margin="0,8,0,0">
                                <TextBox x:Name="TxtLog"
                                         IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap" AcceptsReturn="True"/>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid><!-- end PnlMacroPad -->

            <!-- ==================== DisplayPad ==================== -->
            <Grid x:Name="PnlDisplayPad" Visibility="Collapsed">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>    <!-- toolbar (fixed, see PnlEverest) -->
                        <RowDefinition Height="*"/>     <!-- main area -->
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <!-- Debug-only: open/close driver manually -->
                        <Button x:Name="BtnDpOpen"    Content="{loc:Get open_driver}"    Click="BtnDpOpen_Click"
                                Style="{StaticResource K2IconAccentButton}" Tag="&#xE768;" Visibility="Collapsed"/>
                        <Button x:Name="BtnDpClose"   Content="{loc:Get close_driver}"   Margin="8,0,0,0" Click="BtnDpClose_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE711;" Visibility="Collapsed"/>
                        <Separator x:Name="SepDpOpenDbg" Margin="10,0" Visibility="Collapsed"/>
                        <!-- Folder navigation: interface-only, independent of any physical/software
                             key's "Back" action — always available to leave a sub-page even if the
                             user removes/never assigns a Back key inside it. Visible only when inside
                             a sub-page (toggled by UpdateDpBreadcrumb); accent-styled so it isn't missed. -->
                        <Button x:Name="BtnDpBack" Content="{loc:Get dp_back}"
                                Margin="0,0,0,0" Style="{StaticResource K2IconAccentButton}" Tag="&#xE72B;"
                                Click="BtnDpBack_Click" Visibility="Collapsed"/>
                        <TextBlock x:Name="LblDpBreadcrumb" Text="" VerticalAlignment="Center"
                                   Margin="6,0,0,0" Foreground="#9A9AA2" FontStyle="Italic"/>
                        <!-- Debug-only: remap/reset keys (see project rule) -->
                        <Separator x:Name="SepDpMapKeysDbg" Margin="10,0" Visibility="Collapsed"/>
                        <Button x:Name="BtnDpMapKeys"  Content="{loc:Get remap_keys}"    Click="BtnDpMapKeys_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE765;" Visibility="Collapsed"/>
                        <Button x:Name="BtnDpResetAll" Content="{loc:Get dp_reset_keys}" Margin="8,0,0,0" Click="BtnDpResetAll_Click"
                                Style="{StaticResource K2IconButton}" Tag="&#xE777;" Visibility="Collapsed"/>
                        <TextBlock x:Name="LblDpSdk" Margin="16,6,0,0" FontStyle="Italic" Foreground="#9A9AA2" Visibility="Collapsed"/>
                    </WrapPanel>

                    <!-- ── sidebar (specific) | canvas + settings | common actions | debug ── -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>  <!-- sidebar -->
                            <ColumnDefinition Width="*"/>    <!-- canvas + settings -->
                            <ColumnDefinition Width="Auto"/> <!-- common actions (all devices) -->
                            <ColumnDefinition Width="Auto"/> <!-- debug -->
                        </Grid.ColumnDefinitions>

                        <!-- Left sidebar: device-specific section navigation -->
                        <Border Grid.Column="0" Background="#111115" CornerRadius="6"
                                Margin="0,0,8,0" Padding="4">
                            <StackPanel>
                                <TextBlock Text="SECTIONS" FontSize="9" Foreground="#4A4A58"
                                           Margin="14,8,0,6" FontWeight="Bold"/>
                                <RadioButton x:Name="RbDpSecKeyBinding"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get ev_key_binding}" GroupName="DpSections"
                                             IsChecked="True" Checked="DpSection_Changed"/>
                                <RadioButton x:Name="RbDpSecRotation"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get positioning}" GroupName="DpSections"
                                             Checked="DpSection_Changed"/>
                                <RadioButton x:Name="RbDpSecPages"
                                             Style="{StaticResource SectionTabStyle}"
                                             Content="{loc:Get dp_pages}" GroupName="DpSections"
                                             Checked="DpSection_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- Middle: keys canvas (top) + settings panel (bottom).
                             No margin here (matches PnlEverest): the gap before the
                             common-actions column comes from that column's own left
                             margin, so this box is exactly as wide as Everest's. -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" MinHeight="160"/>  <!-- device -->
                                <RowDefinition Height="Auto"/>               <!-- settings -->
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#18181C" CornerRadius="6" Padding="8">
                                <Canvas x:Name="CvsDpKeys" Width="510" Height="370" ClipToBounds="True"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas.Background>
                                        <ImageBrush ImageSource="Assets/mkd_bg.png" Stretch="Fill"/>
                                    </Canvas.Background>
                                </Canvas>
                            </Border>

                            <!-- Bottom settings panel: sections switch here. Fixed Height (not
                                 Auto) so the panel doesn't resize/jump when switching between
                                 Key Binding / Rotation. -->
                            <Border Grid.Row="1" Background="#14141A"
                                    BorderBrush="#2A2A32" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,8,0,0"
                                    Height="90">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid>

                                    <!-- ── KEY BINDING (keys are configured directly on the grid above) ── -->
                                    <StackPanel x:Name="PnlDpSecKeyBinding" Orientation="Horizontal">
                                        <TextBlock Text="{loc:Get key_binding_hint}" Foreground="#9A9AA2"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- ── ROTATION ── -->
                                    <StackPanel x:Name="PnlDpSecRotation" Orientation="Horizontal" Visibility="Collapsed">
                                        <TextBlock Text="{loc:Get positioning}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="CbDpRotation" Width="190" Margin="0,0,12,0"
                                                  SelectionChanged="CbDpRotation_SelectionChanged"/>
                                        <Button x:Name="BtnDpRotateCcw" Content="{loc:Get dp_rotate_icons_ccw}" Margin="0,0,6,0"
                                                Style="{StaticResource K2IconButton}" Tag="&#xE14A;"
                                                Click="BtnDpRotateCcw_Click"/>
                                        <Button x:Name="BtnDpRotateCw"  Content="{loc:Get dp_rotate_icons_cw}"
                                                Style="{StaticResource K2IconButton}" Tag="&#xE14A;"
                                                Click="BtnDpRotateCw_Click"/>
                                    </StackPanel>

                                    <!-- ── PAGES (folder sub-pages created for this device+profile) ── -->
                                    <StackPanel x:Name="PnlDpSecPages" Orientation="Vertical" Visibility="Collapsed">
                                        <TextBlock x:Name="LblDpNoPages" Text="{loc:Get dp_no_pages}"
                                                   Foreground="#9A9AA2" TextWrapping="Wrap" Visibility="Collapsed"/>
                                        <ItemsControl x:Name="LstDpPages">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="RowBorder" Padding="6,3" CornerRadius="4"
                                                            Background="Transparent">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                                       Foreground="#CCCCCC" VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <Button x:Name="BtnRowDelete" Grid.Column="1"
                                                                    Content="{loc:Get dp_delete_page}"
                                                                    Style="{StaticResource K2IconButton}" Tag="&#xE74D;"
                                                                    Visibility="Collapsed" Margin="8,0,0,0"
                                                                    CommandParameter="{Binding PageId}"
                                                                    Click="BtnDpDeletePage_Click"/>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <Trigger SourceName="RowBorder" Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnRowDelete" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="RowBorder" Property="Background" Value="#1E1E24"/>
                                                        </Trigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <!-- Common actions (same rule for all devices): uniform width/height,
                             vertical stack, grouped Profile / Import / Device.
                             Left-only margin (not on the device box) mirrors PnlEverest exactly,
                             so column 1 keeps the same width in both. The gap before the (normally
                             collapsed) debug column lives on that column's own left margin instead,
                             so it doesn't cost width here in the common (non-debug) case. -->
                        <Border Grid.Column="2" Background="#111115" CornerRadius="6"
                                Margin="8,0,0,0" Padding="10" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{loc:Get profile}" Style="{StaticResource K2SideGroupHeader}"/>
                                <ComboBox x:Name="CbDpProfile" Style="{StaticResource K2SideActionCombo}"
                                          SelectionChanged="CbDpProfile_SelectionChanged"/>
                                <Button x:Name="BtnDpRenameProfile" Content="{loc:Get rename_profile}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8D3;"
                                        Click="BtnDpRenameProfile_Click"/>
                                <Button x:Name="BtnDpDeleteProfile" Content="{loc:Get delete_profile}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE74D;"
                                        Click="BtnDpDeleteProfile_Click"/>

                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                <TextBlock Text="{loc:Get dp_fullscreen_group}" Style="{StaticResource K2SideGroupHeader}"/>
                                <Button x:Name="BtnDpFullscreen" Content="{loc:Get dp_fullscreen_set}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE91B;"
                                        Click="BtnDpFullscreen_Click"/>
                                <Button x:Name="BtnDpFullscreenClear" Content="{loc:Get dp_fullscreen_clear}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE74D;"
                                        Click="BtnDpFullscreenClear_Click"/>

                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                <TextBlock Text="{loc:Get import}" Style="{StaticResource K2SideGroupHeader}"/>
                                <Button x:Name="BtnDpImportXml" Content="{loc:Get dp_import_xml}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8E5;"
                                        Click="BtnDpImportXml_Click"/>
                                <Button x:Name="BtnDpImportBc" Content="{loc:Get dp_import_bc}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE896;"
                                        Click="BtnDpImportBc_Click"/>

                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                <TextBlock Text="{loc:Get export}" Style="{StaticResource K2SideGroupHeader}"/>
                                <Button x:Name="BtnDpExportProfiles" Content="{loc:Get export_profiles_btn}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE896;"
                                        Click="BtnDpExportProfiles_Click"/>

                                <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                <TextBlock Text="{loc:Get device}" Style="{StaticResource K2SideGroupHeader}"/>
                                <Button x:Name="BtnDpRename" Content="{loc:Get rename_device}"
                                        Style="{StaticResource K2SideActionButton}" Tag="&#xE8D3;"
                                        Click="BtnDpRename_Click"/>

                                <StackPanel x:Name="PnlDpDebugGroup" Visibility="Collapsed">
                                    <Separator Style="{StaticResource K2SideSeparator}" Margin="0,4,0,10"/>
                                    <TextBlock Text="{loc:Get debug_group}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <Button x:Name="BtnDpRefresh" Content="{loc:Get refresh}"
                                            Style="{StaticResource K2SideActionButton}" Tag="&#xE72C;"
                                            Click="BtnDpRefresh_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Debug panel: visible only in debug mode -->
                        <Grid x:Name="PnlDpDebugRight" Grid.Column="3" Width="380" Visibility="Collapsed" Margin="8,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <GroupBox x:Name="GbDpDevices" Grid.Row="0" Header="{loc:Get dp_connected_devices}">
                                <ListView x:Name="LvDpDevices" Height="120">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Device"         Width="100" DisplayMemberBinding="{Binding Label}"/>
                                            <GridViewColumn Header="{loc:Get dp_fw}" Width="80"  DisplayMemberBinding="{Binding FirmwareVersion}"/>
                                            <GridViewColumn Header="{loc:Get dp_lum}" Width="60" DisplayMemberBinding="{Binding Brightness}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </GroupBox>
                            <GroupBox x:Name="GbDpLog" Grid.Row="1" Header="{loc:Get dp_log}" Margin="0,8,0,0">
                                <TextBox x:Name="TxtDpLog"
                                         IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap" AcceptsReturn="True"/>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid><!-- end PnlDisplayPad -->

            <!-- ==================== Macro (top-level section) ==================== -->
            <Grid x:Name="PnlMacro" Visibility="Collapsed">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{loc:Get keyboard_macro}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Macro library (always visible) — same look as the device
                             "SECTIONS" sidebar: dark rounded card, accent-highlighted
                             selection, stretching to fill the column's full height.
                             New/Delete above the card, Import below it. -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{loc:Get macro_library}" Style="{StaticResource K2SideGroupHeader}"/>
                            <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                                <Button x:Name="BtnMacroNew"       Content="{loc:Get macro_new}"       Padding="8,2" Margin="0,0,4,0" Click="BtnMacroNew_Click"       Style="{StaticResource K2IconButton}" Tag="&#xE710;"/>
                                <Button x:Name="BtnMacroDuplicate" Content="{loc:Get macro_duplicate}" Padding="8,2" Margin="0,0,4,0" Click="BtnMacroDuplicate_Click" Style="{StaticResource K2IconButton}" Tag="&#xE8C8;"/>
                                <Button x:Name="BtnMacroDelete"    Content="{loc:Get delete}"          Padding="8,2" Click="BtnMacroDelete_Click"    Style="{StaticResource K2IconButton}" Tag="&#xE74D;"/>
                            </WrapPanel>
                            <Border Grid.Row="2" Background="#111115" CornerRadius="6" Padding="4">
                                <ListBox x:Name="LbMacros"
                                         Background="Transparent" BorderThickness="0"
                                         ItemContainerStyle="{StaticResource MacroLibraryItemStyle}"
                                         SelectionChanged="LbMacros_SelectionChanged"
                                         DisplayMemberPath="Name">
                                    <!-- Bare-bones template (no default WPF/Fluent chrome): the
                                         stock ListBox template has its own "disabled" visual state
                                         that paints a system-light/white background regardless of
                                         the Background set above, and its fixed-size chrome doesn't
                                         stretch to fill a "*" row the way this bare ScrollViewer
                                         does. Same technique as LvMacroInputs below. -->
                                    <ListBox.Template>
                                        <ControlTemplate TargetType="ListBox">
                                            <ScrollViewer Background="Transparent" Padding="2"
                                                          CanContentScroll="False">
                                                <ItemsPresenter/>
                                            </ScrollViewer>
                                        </ControlTemplate>
                                    </ListBox.Template>
                                </ListBox>
                            </Border>
                            <Button Grid.Row="3" x:Name="BtnMacroImportBC" Content="{loc:Get macro_import_bc}"
                                    Padding="8,2" Margin="0,6,0,0" Click="BtnMacroImportBC_Click"
                                    Style="{StaticResource K2IconButton}" Tag="&#xE8B5;"
                                    HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- Selected macro editor -->
                        <Grid x:Name="SpMacroSettings" Grid.Column="2" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="{loc:Get macro_name}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="TxtMacroName" Width="220"
                                         Background="#2A2A2E" Foreground="White"
                                         TextChanged="TxtMacroName_TextChanged"/>
                            </WrapPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="190"/>
                                </Grid.ColumnDefinitions>

                                <!-- Settings column: Devices / Delay / Playback, stacked -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Get macro_section_devices}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <CheckBox x:Name="CkMacroMouse" Content="{loc:Get macro_record_mouse}"
                                              Margin="0,0,0,6" Click="CkMacroDevice_Click"/>
                                    <CheckBox x:Name="CkMacroMouseMovement" Content="{loc:Get macro_record_mouse_movement}"
                                              Margin="20,0,0,6" FontSize="12" Click="CkMacroDevice_Click"/>
                                    <CheckBox x:Name="CkMacroKeyboard" Content="{loc:Get macro_record_keyboard}"
                                              Margin="0,0,0,18" Click="CkMacroDevice_Click"/>

                                    <TextBlock Text="{loc:Get macro_delay}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <RadioButton x:Name="RbMacroDelayRecorded" GroupName="MacroDelayGroup"
                                                 Content="{loc:Get macro_delay_recorded}"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroDelay_Checked"/>
                                    <RadioButton x:Name="RbMacroDelayCustom" GroupName="MacroDelayGroup"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroDelay_Checked">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{loc:Get macro_delay_custom}" VerticalAlignment="Center"/>
                                            <TextBox x:Name="TxtMacroCustomDelay" Width="66" Margin="8,0,4,0"
                                                     Padding="5,2" Background="#2A2A2E" Foreground="White"
                                                     TextChanged="TxtMacroCustomDelay_TextChanged"/>
                                            <TextBlock Text="ms" VerticalAlignment="Center" Opacity="0.7"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton x:Name="RbMacroDelayNone" GroupName="MacroDelayGroup"
                                                 Content="{loc:Get macro_delay_none}" Margin="0,0,0,18"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroDelay_Checked"/>

                                    <TextBlock Text="{loc:Get macro_playback}" Style="{StaticResource K2SideGroupHeader}"/>
                                    <RadioButton x:Name="RbMacroPlaybackOnce" GroupName="MacroPlaybackGroup"
                                                 Content="{loc:Get macro_playback_once}"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroPlayback_Checked"/>
                                    <RadioButton x:Name="RbMacroPlaybackHold" GroupName="MacroPlaybackGroup"
                                                 Content="{loc:Get macro_playback_held}"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroPlayback_Checked"/>
                                    <RadioButton x:Name="RbMacroPlaybackRepeat" GroupName="MacroPlaybackGroup"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroPlayback_Checked">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{loc:Get macro_repeat_short}" VerticalAlignment="Center"/>
                                            <TextBox x:Name="TxtMacroRepeatN" Width="66" Margin="8,0,4,0"
                                                     Padding="5,2" Background="#2A2A2E" Foreground="White"
                                                     TextChanged="TxtMacroRepeatN_TextChanged"/>
                                            <TextBlock Text="{loc:Get macro_times_suffix}" VerticalAlignment="Center" Opacity="0.7"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton x:Name="RbMacroPlaybackToggle" GroupName="MacroPlaybackGroup"
                                                 Content="{loc:Get macro_playback_toggle}"
                                                 Style="{StaticResource MacroOptionRowStyle}" Checked="RbMacroPlayback_Checked"/>
                                </StackPanel>

                                <!-- Inputs / commands -->
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{loc:Get macro_section_inputs}"
                                                   Style="{StaticResource K2SideGroupHeader}" VerticalAlignment="Center"/>
                                        <CheckBox Grid.Column="1" x:Name="CkMacroShowPressRelease"
                                                  Content="{loc:Get macro_show_press_release}"
                                                  Tag="&#xE7C8;" Style="{StaticResource K2ToggleRow}"
                                                  Click="CkMacroShowPressRelease_Click"/>
                                    </Grid>

                                    <Border Grid.Row="1" Background="#18181C" BorderBrush="{StaticResource K2BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" MinHeight="260">
                                        <ListView x:Name="LvMacroInputs" Background="Transparent" BorderThickness="0"
                                                  ScrollViewer.CanContentScroll="False">
                                            <ListView.Template>
                                                <ControlTemplate TargetType="ListView">
                                                    <ScrollViewer Background="Transparent" Padding="4">
                                                        <ItemsPresenter/>
                                                    </ScrollViewer>
                                                </ControlTemplate>
                                            </ListView.Template>
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Focusable" Value="False"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListViewItem">
                                                                <ContentPresenter/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#232328" CornerRadius="6" Margin="4,3" Padding="10,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="24"/>
                                                                <ColumnDefinition Width="16"/>
                                                                <ColumnDefinition Width="22"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Number}"
                                                                       Foreground="#68686E" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Style="{StaticResource MacroPressIndicatorStyle}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Glyph}"
                                                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                       Foreground="#9A9AA2" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding Label}"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding DelayMs, StringFormat={}{0} ms}"
                                                                       Foreground="#68686E" FontSize="11"
                                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                            <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="10,0,0,0">
                                                                <Button Tag="&#xE70E;" CommandParameter="{Binding}" Click="BtnMacroInputMoveUp_Click"
                                                                        Style="{StaticResource MacroRowIconButton}" ToolTip="{loc:Get macro_move_up}"/>
                                                                <Button Tag="&#xE70D;" CommandParameter="{Binding}" Click="BtnMacroInputMoveDown_Click"
                                                                        Style="{StaticResource MacroRowIconButton}" ToolTip="{loc:Get macro_move_down}"/>
                                                                <Button Tag="&#xE74D;" CommandParameter="{Binding}" Click="BtnMacroInputDelete_Click"
                                                                        Style="{StaticResource MacroRowIconButton}" ToolTip="{loc:Get macro_delete_input}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Border>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button x:Name="BtnMacroRecord" Content="{loc:Get macro_start_recording}"
                                                Padding="12,6" Margin="0,0,8,0" Click="BtnMacroRecord_Click"
                                                Style="{StaticResource K2IconAccentButton}" Tag="&#xE7C8;"/>
                                        <Button x:Name="BtnMacroPlay" Content="{loc:Get macro_play}"
                                                Padding="10,6" Margin="0,0,8,0" Click="BtnMacroPlay_Click"
                                                Style="{StaticResource K2IconButton}" Tag="&#xE768;"/>
                                        <Button x:Name="BtnMacroStop" Content="{loc:Get stop}"
                                                Padding="10,6" Margin="0,0,8,0" Click="BtnMacroStop_Click"
                                                Style="{StaticResource K2IconButton}" Tag="&#xE71A;"/>
                                        <TextBlock x:Name="TblMacroInputCount" Text="0 actions"
                                                   VerticalAlignment="Center" Foreground="#808080" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Assigned to -->
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{loc:Get macro_section_assigned}" Style="{StaticResource K2SideGroupHeader}"
                                               ToolTip="{loc:Get macro_assigned_help}"/>
                                    <ItemsControl x:Name="LvMacroAssignments">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#232328" CornerRadius="6" Margin="0,0,0,6" Padding="8,6">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding KeyLabel}" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding Subtitle}" Foreground="#808088"
                                                                   FontSize="11" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="TblMacroNotAssigned" Text="{loc:Get macro_not_assigned}"
                                               Foreground="#606068" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid><!-- end PnlMacro -->

            <!-- ==================== General Settings ==================== -->
            <Grid x:Name="PnlSettings" Visibility="Collapsed">
                <StackPanel Margin="24" MaxWidth="480" HorizontalAlignment="Left">
                    <TextBlock Text="{loc:Get tab_settings}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <GroupBox x:Name="GbAppGeneral" Header="{loc:Get settings_general}" Margin="0,0,0,20">
                        <StackPanel Margin="8">
                            <CheckBox x:Name="CkCloseToTray" Content="{loc:Get settings_close_to_tray}"
                                      Click="CkCloseToTray_Click" FontSize="14"/>
                            <CheckBox x:Name="CkK2Autostart" Content="{loc:Get settings_k2_autostart}"
                                      Click="CkK2Autostart_Click" FontSize="14" Margin="0,12,0,0"/>
                            <CheckBox x:Name="CkStartMinToTray" Content="{loc:Get settings_start_min_tray}"
                                      Click="CkStartMinToTray_Click" FontSize="14" Margin="0,12,0,0"/>
                            <TextBlock Text="{loc:Get settings_start_min_tray_hint}" Foreground="#9A9AA2"
                                       TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>
                        </StackPanel>
                    </GroupBox>

                    <CheckBox x:Name="CkAppDebugMode" Content="{loc:Get settings_debug_mode}"
                              Click="CkAppDebugMode_Click" FontSize="14"/>
                    <TextBlock Text="{loc:Get settings_debug_mode_hint}" Foreground="#9A9AA2"
                               TextWrapping="Wrap" Margin="20,4,0,20" FontSize="12"/>

                    <GroupBox x:Name="GbAppLogLevel" Header="{loc:Get settings_log_level}" Margin="0,4,0,0">
                        <StackPanel Margin="8">
                            <RadioButton x:Name="RbLogOff"     Content="{loc:Get log_off}"
                                         GroupName="AppLogLevel" Margin="0,4" Checked="RbLogLevel_Checked"/>
                            <RadioButton x:Name="RbLogNormal"  Content="{loc:Get log_normal}"
                                         GroupName="AppLogLevel" Margin="0,4" Checked="RbLogLevel_Checked"/>
                            <RadioButton x:Name="RbLogVerbose" Content="{loc:Get log_verbose}"
                                         GroupName="AppLogLevel" Margin="0,4" Checked="RbLogLevel_Checked"/>
                        </StackPanel>
                    </GroupBox>

                    <CheckBox x:Name="CkDpNativeEngine" Content="{loc:Get settings_dp_native}"
                              Click="CkDpNativeEngine_Click" FontSize="14" Margin="0,20,0,0"/>
                    <TextBlock Text="{loc:Get settings_dp_native_hint}" Foreground="#9A9AA2"
                               TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>

                    <CheckBox x:Name="CkEvNativeEngine" Content="{loc:Get settings_ev_native}"
                              Click="CkEvNativeEngine_Click" FontSize="14" Margin="0,16,0,0"/>
                    <TextBlock Text="{loc:Get settings_ev_native_hint}" Foreground="#9A9AA2"
                               TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>

                    <CheckBox x:Name="CkKillBcWorker" Content="{loc:Get settings_kill_bc_worker}"
                              Click="CkKillBcWorker_Click" FontSize="14" Margin="0,16,0,0"/>
                    <TextBlock Text="{loc:Get settings_kill_bc_worker_hint}" Foreground="#9A9AA2"
                               TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>

                    <CheckBox x:Name="CkBcAutostart" Content="{loc:Get settings_bc_autostart}"
                              Click="CkBcAutostart_Click" FontSize="14" Margin="0,16,0,0"/>
                    <TextBlock x:Name="TxtBcAutostartHint" Text="{loc:Get settings_bc_autostart_hint}"
                               Foreground="#9A9AA2" TextWrapping="Wrap" Margin="20,4,0,0" FontSize="12"/>
                </StackPanel>
            </Grid><!-- end PnlSettings -->

            </Grid><!-- end content panels -->
        </Grid><!-- end outer device Grid -->

        <!-- Status bar -->
        <StatusBar Grid.Row="1" Margin="0,8,0,0">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True"/>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem DockPanel.Dock="Right" Padding="0,0,4,0">
                <Button x:Name="BtnLang" Click="BtnLang_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Padding="6,2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F310; "/>
                        <TextBlock x:Name="TxtLangLabel" Text="EN"/>
                    </StackPanel>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="English"    Tag="en" Click="MnuLang_Click"/>
                            <MenuItem Header="Italiano"   Tag="it" Click="MnuLang_Click"/>
                            <MenuItem Header="Español"    Tag="es" Click="MnuLang_Click"/>
                            <MenuItem Header="Français"   Tag="fr" Click="MnuLang_Click"/>
                            <MenuItem Header="Deutsch"    Tag="de" Click="MnuLang_Click"/>
                            <MenuItem Header="Português"  Tag="pt" Click="MnuLang_Click"/>
                            <MenuItem Header="Polski"     Tag="pl" Click="MnuLang_Click"/>
                            <MenuItem Header="日本語"      Tag="ja" Click="MnuLang_Click"/>
                            <MenuItem Header="中文"        Tag="zh" Click="MnuLang_Click"/>
                            <MenuItem Header="한국어"      Tag="ko" Click="MnuLang_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="LblStatus" Text="{loc:Get driver_not_opened}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
