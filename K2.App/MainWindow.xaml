                                                            Click="BtnEvKeycapTextColor_Click" Margin="5,0,0,0"/>
                                                        </WrapPanel>
                                                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                            <TextBlock Text="{loc:Get settings_keycap_style}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <ComboBox x:Name="CbEvKeycapStyle" Width="240"
                                                              SelectionChanged="CbEvKeycapStyle_SelectionChanged" Margin="4,3,0,0"/>
                                                        </WrapPanel>
                                                        <WrapPanel Orientation="Horizontal" Margin="0,5,0,4">
                                                            <CheckBox x:Name="CkEvKeycapTranslucentLegend" Content="{loc:Get settings_keycap_translucent_legend}"
