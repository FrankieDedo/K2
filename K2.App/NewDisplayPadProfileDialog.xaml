<Window x:Class="K2.App.NewDisplayPadProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:K2.Core;assembly=K2.Core"
        Title="{loc:Get new_profile_dialog_title}"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Style="{DynamicResource K2WindowStyle}">

    <StackPanel Margin="16">
        <TextBlock Text="{loc:Get new_profile_dialog_title}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <RadioButton x:Name="RbGeneric" Content="{loc:Get new_profile_generic}"
                     GroupName="NewDpProfileKind" IsChecked="True"
                     Checked="RbKind_Checked" Margin="0,0,0,8"/>
        <RadioButton x:Name="RbDedicated" Content="{loc:Get new_profile_dedicated}"
                     GroupName="NewDpProfileKind"
                     Checked="RbKind_Checked" Margin="0,0,0,8"/>

        <StackPanel x:Name="PnlDedicated" Margin="24,0,0,8" IsEnabled="False">
            <TextBlock Text="{loc:Get new_profile_dedicated_hint}"
                       Foreground="#AAA" FontSize="11" Margin="0,0,0,6"
                       TextWrapping="Wrap"/>
            <ComboBox x:Name="CbDedicatedType" SelectedIndex="0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{loc:Get new_profile_create_btn}"
                    IsDefault="True"
                    MinWidth="80"
                    Style="{StaticResource K2IconAccentButton}"
                    Click="BtnCreate_Click"
                    Margin="0,0,8,0"/>
            <Button Content="{loc:Get cancel}"
                    IsCancel="True"
                    MinWidth="80"/>
        </StackPanel>
    </StackPanel>
</Window>
